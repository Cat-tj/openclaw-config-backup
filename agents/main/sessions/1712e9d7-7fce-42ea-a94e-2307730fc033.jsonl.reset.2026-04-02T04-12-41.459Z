{"type":"message","id":"5368bc54","parentId":"6117cdf2","timestamp":"2026-04-01T18:08:38.910Z","message":{"role":"toolResult","toolCallId":"tooluse_JD6Gc0GdzVmqbVjSmeqslo","toolName":"read","content":[{"type":"text","text":"app.post('/api/ai-dm/chat', async (req, res) => {\n  const { characterData, conversationHistory, playerAction, genre } = req.body;\n  if (!characterData) return res.status(400).json({ error: 'Character data required' });\n\n  // Build context from conversation history\n  let historyText = '';\n  if (conversationHistory && conversationHistory.length > 0) {\n    // If history is too long, only keep recent + a summary note\n    const recentHistory = conversationHistory.slice(-30);\n    historyText = recentHistory.map(m => {\n      if (m.role === 'dm') return `DM: ${m.text}`;\n      if (m.role === 'player') return `Player: ${m.text}`;\n      if (m.role === 'system') return `[System: ${m.text}]`;\n      return m.text;\n    }).join('\\n\\n');\n  }\n\n  const genreHint = genre ? `Adventure genre: ${genre}.` : '';\n\n  const aiPrompt = `You are a D&D 2024 Dungeon Master running a solo adventure. Be dramatic, engaging, and immersive.\n\nCHARACTER:\nName: ${characterData.name || 'Unknown'}\nSpecies: ${characterData.species || '?'}, Class: ${characterData.className || '?'}, Level: ${characterData.level || 1}\nHP: ${characterData.currentHP || '?'}/${characterData.maxHP || '?'}, AC: ${characterData.ac || '?'}\nSTR: ${characterData.str || 10}, DEX: ${characterData.dex || 10}, CON: ${characterData.con || 10}, INT: ${characterData.int || 10}, WIS: ${characterData.wis || 10}, CHA: ${characterData.cha || 10}\n${characterData.notes ? `Notes/Equipment: ${characterData.notes}` : ''}\n\n${genreHint}\n\nSTORY SO FAR:\n${historyText || '(New adventure - set the opening scene)'}\n\n${playerAction ? `PLAYER ACTION: ${playerAction}` : 'Begin the adventure with a vivid opening scene.'}\n\nINSTRUCTIONS:\n- Respond with vivid narrative (2-4 paragraphs). Include NPC dialogue in quotes.\n- If a skill check or combat is needed, specify the roll required.\n- Track the story. Be dramatic and engaging.\n- IMPORTANT: Return ONLY valid JSON (no markdown, no code fences) with these fields:\n\n[857 more lines in file. Use offset=1698 to continue.]"}],"isError":false,"timestamp":1775066918901}}
