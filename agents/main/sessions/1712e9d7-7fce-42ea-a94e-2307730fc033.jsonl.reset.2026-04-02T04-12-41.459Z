{"type":"message","id":"1f58363e","parentId":"cf9a2a48","timestamp":"2026-04-01T18:08:42.805Z","message":{"role":"toolResult","toolCallId":"tooluse_jeZ00uZPuUbocAv1bgrhWx","toolName":"read","content":[{"type":"text","text":"{\n  \"narrative\": \"Your narrative text here (2-4 paragraphs, use \\\\n for line breaks)\",\n  \"rollRequired\": null or {\"type\": \"d20\", \"skill\": \"Stealth\", \"modifier\": \"Dexterity\", \"dc\": 15, \"description\": \"Roll a d20 + Dexterity modifier for Stealth\"},\n  \"combatState\": null or {\"inCombat\": true, \"enemies\": [{\"name\": \"Goblin\", \"hp\": 7, \"ac\": 15}], \"description\": \"Combat begins!\"},\n  \"location\": \"Current location name\",\n  \"suggestions\": [\"suggestion 1\", \"suggestion 2\", \"suggestion 3\"]\n}`;\n\n  try {\n    const response = await fetch('http://127.0.0.1:3001/voice/chat', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ agentId: 'sarael', message: aiPrompt })\n    });\n    const data = await response.json();\n    const rawText = data.response || data.message || JSON.stringify(data);\n\n    let result;\n    try {\n      result = JSON.parse(rawText);\n    } catch {\n      // Try to extract JSON from response\n      const fenceMatch = rawText.match(/```(?:json)?\\s*([\\s\\S]*?)```/);\n      if (fenceMatch) {\n        try { result = JSON.parse(fenceMatch[1].trim()); } catch {}\n      }\n      if (!result) {\n        const jsonMatch = rawText.match(/\\{[\\s\\S]*\\}/);\n        if (jsonMatch) {\n          try { result = JSON.parse(jsonMatch[0]); } catch {}\n        }\n      }\n      if (!result) {\n        // Fallback: wrap raw text as narrative\n        result = {\n          narrative: rawText,\n          rollRequired: null,\n          combatState: null,\n          location: null,\n          suggestions: []\n\n[817 more lines in file. Use offset=1738 to continue.]"}],"isError":false,"timestamp":1775066922795}}
