{"type":"message","id":"01400cbe","parentId":"6fc8fd67","timestamp":"2026-04-01T18:09:15.512Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"tooluse_dBmI6c5GvzckXZAbKRk7cC","name":"edit","arguments":{"file":"/home/openclaw/dnd-app/backend/server.js","newText":"    magicItemNames: magicItems.map(i => i.name),\n    featNames: feats.map(f => f.name),\n    backgroundNames: backgrounds.map(b => b.name),\n  });\n});\n\n// ============================================================\n// AI TRANSLATION (English → Indonesian)\n// ============================================================\nconst TRANSLATE_CACHE_FILE = path.join(DATA_DIR, 'translate-cache.json');\n\nfunction loadTranslateCache() {\n  try {\n    if (fs.existsSync(TRANSLATE_CACHE_FILE)) {\n      return JSON.parse(fs.readFileSync(TRANSLATE_CACHE_FILE, 'utf8'));\n    }\n  } catch {}\n  return {};\n}\n\nfunction saveTranslateCache(cache) {\n  try {\n    fs.writeFileSync(TRANSLATE_CACHE_FILE, JSON.stringify(cache));\n  } catch (e) { console.error('Failed to save translate cache:', e.message); }\n}\n\nlet translateCache = loadTranslateCache();\nlet translateSaveTimer = null;\n\nfunction debounceSaveTranslateCache() {\n  if (translateSaveTimer) clearTimeout(translateSaveTimer);\n  translateSaveTimer = setTimeout(() => saveTranslateCache(translateCache), 5000);\n}\n\napp.post('/api/translate', async (req, res) => {\n  const { text, category, name } = req.body;\n  if (!text) return res.status(400).json({ error: 'text required' });\n\n  // Cache key based on category + name or text hash\n  const cacheKey = category && name ? `${category}:${name}` : text.substring(0, 100);\n  \n  if (translateCache[cacheKey]) {\n    return res.json({ translated: translateCache[cacheKey], cached: true });\n  }\n\n  const prompt = `Translate the following D&D game content from English to Indonesian (Bahasa Indonesia). \nKeep game mechanics terms in English (hit points, armor class, saving throw, ability check, spell slot, etc.).\nKeep proper nouns, spell names, monster names, and item names in English.\nTranslate descriptions, flavor text, and explanations to natural Indonesian.\nDo NOT add any commentary or notes — return ONLY the translated text.\n\nText to translate:\n${text}`;\n\n  try {\n    const response = await fetch('http://127.0.0.1:3001/voice/chat', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ agentId: 'sarael', message: prompt })\n    });\n    const data = await response.json();\n    const translated = data.response || data.message || text;\n\n    // Cache it\n    translateCache[cacheKey] = translated;\n    debounceSaveTranslateCache();\n\n    res.json({ translated, cached: false });\n  } catch (e) {\n    console.error('Translation failed:', e.message);\n    res.status(500).json({ error: 'Translation failed', fallback: text });\n  }\n});\n\nserver.listen(PORT, () => {\n  console.log(`D&D 2024 App running on port ${PORT}`);\n});","oldText":"    magicItemNames: magicItems.map(i => i.name),\n    featNames: feats.map(f => f.name),\n    backgroundNames: backgrounds.map(b => b.name),\n  });\n});\n\nserver.listen(PORT, () => {\n  console.log(`D&D 2024 App running on port ${PORT}`);\n});"}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-opus-4-6-v1","usage":{"input":1,"output":968,"cacheRead":134671,"cacheWrite":201,"totalTokens":135841,"cost":{"input":0.000005,"output":0.024200000000000003,"cacheRead":0.06733549999999999,"cacheWrite":0.00125625,"total":0.09279675}},"stopReason":"toolUse","timestamp":1775066936820}}
