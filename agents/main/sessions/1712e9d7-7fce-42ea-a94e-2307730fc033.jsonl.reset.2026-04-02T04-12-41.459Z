n, { type: 'token_move', data: msg.data, userId: info.userId });\n        }\n        break;\n      }\n      case 'grid_update': {\n        const info = wsUserMap.get(ws);\n        if (info) {\n          // Persist grid settings\n          const rooms = readJSON('rooms.json');\n          if (rooms[info.roomPin]) {\n            rooms[info.roomPin].gridSettings = msg.data;\n            writeJSON('rooms.json', rooms);\n          }\n          broadcastToRoom(info.roomPin, { type: 'grid_update', data: msg.data, userId: info.userId });\n        }\n        break;\n      }\n      case 'token_add': {\n        const info = wsUserMap.get(ws);\n        if (info) {\n          const rooms = readJSON('rooms.json');\n          if (rooms[info.roomPin]) {\n            if (!rooms[info.roomPin].tokens) rooms[info.roomPin].tokens = {};\n            if (msg.data && msg.data.id) {\n              rooms[info.roomPin].tokens[msg.data.id] = msg.data;\n            }\n            writeJSON('rooms.json', rooms);\n          }\n          broadcastToRoom(info.roomPin, { type: 'token_add', data: msg.data, userId: info.userId });\n        }\n        break;\n      }\n      case 'token_remove': {\n        const info = wsUserMap.get(ws);\n        if (info) {\n          const rooms = readJSON('rooms.json');\n          if (rooms[info.roomPin]) {\n            if (rooms[info.roomPin].tokens && msg.data && msg.data.id) {\n              delete rooms[info.roomPin].tokens[msg.data.id];\n            }\n            writeJSON('rooms.json', rooms);\n          }\n          broadcastToRoom(info.roomPin, { type: 'token_remove', data: msg.data, userId: info.userId });\n        }\n        break;\n      }\n      case 'fog_reveal': {\n        const info = wsUserMap.get(ws);\n        if (info) {\n          // Persist fog state\n          const rooms = readJSON('rooms.json');\n          if (rooms[info.roomPin]) {\n            if (!rooms[info.roomPin].fogRevealed) rooms[info.roomPin].fogRevealed = [];\n            rooms[info.roomPin].fogRevealed.push(msg.data);\n            writeJSON('rooms.json', rooms);\n          }\n          broadcastToRoom(info.roomPin, { type: 'fog_reveal', data: msg.data, userId: info.userId });\n        }\n        break;\n      }"}]}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-opus-4-6-v1","usage":{"input":1,"output":1379,"cacheRead":96775,"cacheWrite":700,"totalTokens":98855,"cost":{"input":0.000005,"output":0.034475,"cacheRead":0.0483875,"cacheWrite":0.004375,"total":0.0872425}},"stopReason":"toolUse","timestamp":1775056602600}}
