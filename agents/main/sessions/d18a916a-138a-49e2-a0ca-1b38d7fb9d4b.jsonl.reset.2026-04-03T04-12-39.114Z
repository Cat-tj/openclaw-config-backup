{"type":"message","id":"a481ef91","parentId":"a6fb6ccd","timestamp":"2026-04-02T04:38:45.881Z","message":{"role":"toolResult","toolCallId":"tooluse_QIMKo3vxMjyPZWhUA6psNq","toolName":"read","content":[{"type":"text","text":"    let badges = '';\n    if (s.concentration) badges += `<span class=\"spell-concentration-badge\">${isID ? 'Konsentrasi' : 'Concentration'}</span>`;\n    if (s.ritual) badges += `<span class=\"spell-ritual-badge\">Ritual</span>`;\n\n    return `\n      <div class=\"comp-detail-title\">${escapeHtml(s.name)}${badges}</div>\n      <div class=\"comp-detail-subtitle\">${lvlText} ${escapeHtml(school)}</div>\n      <dl class=\"spell-detail-props\">\n        <dt>${isID ? 'Waktu Rapal' : 'Casting Time'}</dt><dd>${escapeHtml(s.castingTime || '—')}</dd>\n        <dt>${isID ? 'Jangkauan' : 'Range'}</dt><dd>${escapeHtml(s.range || '—')}</dd>\n        <dt>${isID ? 'Komponen' : 'Components'}</dt><dd>${escapeHtml(s.components || '—')}${s.materialDetail ? ` <em>(${escapeHtml(s.materialDetail)})</em>` : ''}</dd>\n        <dt>${isID ? 'Durasi' : 'Duration'}</dt><dd>${escapeHtml(s.duration || '—')}</dd>\n      </dl>\n      <div class=\"comp-detail-section\">\n        <h3>${isID ? 'Deskripsi' : 'Description'}</h3>\n        <div class=\"comp-desc-text\"><p>${formatDesc(s.description)}</p></div>\n      </div>\n      ${s.higherLevels ? `\n        <div class=\"comp-detail-section\">\n          <h3>${isID ? 'Pada Level Lebih Tinggi' : 'At Higher Levels'}</h3>\n          <div class=\"comp-desc-text\"><p>${formatDesc(s.higherLevels)}</p></div>\n        </div>` : ''}\n      ${classes ? `<div class=\"comp-detail-tags\">${classes.split(', ').map(c => `<span class=\"comp-detail-tag\">${escapeHtml(c)}</span>`).join('')}</div>` : ''}\n    `;\n  }\n\n  function renderClassDetail(c) {\n    const isID = _lang === 'id';\n\n    // Proficiencies section\n    let profHtml = '<div class=\"comp-detail-section\"><h3>Proficiencies</h3>';\n    if (c.profArmor?.length) profHtml += `<p><strong>Armor:</strong> ${escapeHtml(c.profArmor.join(', '))}</p>`;\n    if (c.profWeapons?.length) profHtml += `<p><strong>Weapons:</strong> ${escapeHtml(c.profWeapons.join(', '))}</p>`;\n    if (c.profTools?.length) profHtml += `<p><strong>Tools:</strong> ${escapeHtml(c.profTools.join(', '))}</p>`;\n    if (c.profSaves?.length) profHtml += `<p><strong>Saving Throws:</strong> ${escapeHtml(c.profSaves.join(', '))}</p>`;\n    if (c.profSkills?.length) profHtml += `<p><strong>Skills (choose 2):</strong> ${escapeHtml(c.profSkills.join(', '))}</p>`;\n    profHtml += '</div>';\n\n    // Features by level\n    let featHtml = '<div class=\"comp-detail-section\"><h3>Features by Level</h3><div class=\"class-features-list\">';\n    const features = c.features || [];\n    let currentLevel = -1;\n    features.forEach(f => {\n      if (f.level !== currentLevel) {\n        currentLevel = f.level;\n      }\n      featHtml += `\n        <div class=\"class-feature-item\">\n          <div class=\"feature-header\">\n            <span class=\"feature-name\">${escapeHtml(f.name)}</span>\n            <span class=\"feature-level\">Lvl ${f.level}</span>\n          </div>\n          <div class=\"feature-body\">${formatDesc(f.entries)}</div>\n        </div>`;\n    });\n    featHtml += '</div></div>';\n\n    // Subclasses\n    let scHtml = '';\n    if (c.subclasses && c.subclasses.length > 0) {\n      scHtml = `<div class=\"comp-detail-section\"><h3>${isID ? 'Subkelas' : 'Subclasses'} (${c.subclasses.length})</h3>`;\n      c.subclasses.forEach(sc => {\n        const scFeats = (sc.features || []);\n        scHtml += `\n          <div class=\"subclass-group\">\n            <div class=\"subclass-group-header\">\n              <span>${escapeHtml(sc.name)}</span>\n              <span style=\"font-size:0.8rem;color:var(--text-dim)\">${scFeats.length} features ▾</span>\n            </div>\n            <div class=\"subclass-group-body\">\n              <div class=\"class-features-list\">`;\n        scFeats.forEach(f => {\n          scHtml += `\n                <div class=\"class-feature-item\">\n                  <div class=\"feature-header\">\n                    <span class=\"feature-name\">${escapeHtml(f.name)}</span>\n                    <span class=\"feature-level\">Lvl ${f.level}</span>\n                  </div>\n                  <div class=\"feature-body\">${formatDesc(f.entries)}</div>\n                </div>`;\n\n[187 more lines in file. Use offset=9300 to continue.]"}],"isError":false,"timestamp":1775104725872}}
