{"type":"message","id":"68375fb9","parentId":"26b25deb","timestamp":"2026-04-05T06:08:40.634Z","message":{"role":"toolResult","toolCallId":"tooluse_FF0qRuBe10ZkODvOOAQD8w","toolName":"read","content":[{"type":"text","text":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<link rel=\"manifest\" href=\"/manifest.json\"><meta name=\"theme-color\" content=\"#060a14\"><meta name=\"apple-mobile-web-app-capable\" content=\"yes\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>MAGI</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n<script src=\"https://unpkg.com/lucide@latest\"></script>\n<style>\n*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}\n:root{\n  --bg:#0a0e1a;--glass:rgba(255,255,255,.025);\n  --border:rgba(255,255,255,.06);--border2:rgba(255,255,255,.1);\n  --text:#e8eaf0;--text2:#a0a6b8;--text3:#6b7185;\n  --primary:#6366f1;--accent:#34d399;--warn:#f59e0b;\n  --r:12px;--r-lg:16px;\n  --ease:cubic-bezier(.22,1,.36,1);\n}\nbody{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}\nbody::before{content:'';position:fixed;top:-200px;left:-100px;width:600px;height:600px;background:radial-gradient(circle,rgba(99,102,241,.07),transparent 70%);z-index:0;pointer-events:none}\nbody::after{content:'';position:fixed;bottom:-200px;right:-100px;width:700px;height:700px;background:radial-gradient(circle,rgba(52,211,153,.05),transparent 70%);z-index:0;pointer-events:none}\n\n.page{max-width:720px;margin:0 auto;padding:60px 24px 80px;position:relative;z-index:1}\n\n.hero{text-align:center;margin-bottom:56px}\n.hero-logo{font-size:48px;font-weight:800;background:linear-gradient(135deg,var(--primary),var(--accent),#A78BFA);background-size:200% auto;-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:shimmer 4s linear infinite;letter-spacing:-1.5px}\n@keyframes shimmer{to{background-position:200% center}}\n.hero-sub{font-size:13px;color:var(--text3);margin-top:6px;font-weight:400}\n.hero-pill{display:inline-flex;align-items:center;gap:6px;margin-top:16px;padding:5px 14px;border-radius:99px;background:rgba(52,211,153,.06);border:1px solid rgba(52,211,153,.12);font-size:10px;color:var(--accent);font-weight:500}\n.hero-pill .dot{width:5px;height:5px;border-radius:50%;background:var(--accent);box-shadow:0 0 6px rgba(52,211,153,.5);animation:pulse 2s ease-in-out infinite}\n@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}\n\n.apps{display:flex;flex-direction:column;gap:10px;margin-bottom:48px}\n\n.app{display:flex;align-items:center;gap:18px;padding:22px 24px;border-radius:var(--r-lg);border:1px solid var(--border);background:var(--glass);backdrop-filter:blur(16px);cursor:pointer;transition:all .3s var(--ease);text-decoration:none;position:relative;overflow:hidden}\n.app::after{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.05),transparent)}\n.app:hover{transform:translateY(-2px);border-color:var(--border2);box-shadow:0 10px 30px rgba(0,0,0,.2);background:rgba(255,255,255,.035)}\n.app:active{transform:translateY(0)}\n\n.app-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0}\n.app-icon svg{width:22px;height:22px}\n.app-body{flex:1;min-width:0}\n.app-name{font-size:15px;font-weight:700;color:var(--text);display:flex;align-items:center;gap:8px}\n.app-desc{font-size:11px;color:var(--text3);line-height:1.6;margin-top:3px}\n.app-arrow{color:var(--text3);opacity:.4;transition:all .2s;display:flex}\n.app:hover .app-arrow{opacity:.8;transform:translateX(3px)}\n\n.tag{font-size:8px;font-weight:700;padding:2px 7px;border-radius:4px;text-transform:uppercase;letter-spacing:.5px}\n.tag-live{background:rgba(52,211,153,.1);color:var(--accent)}\n.tag-soon{background:rgba(245,158,11,.08);color:var(--warn)}\n.tag-build{background:rgba(99,102,241,.1);color:var(--primary)}\n\n.sep{display:flex;align-items:center;gap:10px;margin:8px 0}\n.sep-line{flex:1;height:1px;background:var(--border)}\n.sep-text{font-size:9px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:1.5px}\n\n.footer{text-align:center;margin-top:40px}\n.footer-text{font-size:10px;color:var(--text3);line-height:2}\n\n@media(max-width:500px){\n  .page{padding:36px 16px 60px}\n  .hero-logo{font-size:36px}\n  .app{padding:16px 18px;gap:14px}\n  .app-icon{width:42px;height:42px}\n  .app-icon svg{width:20px;height:20px}\n}\n</style>\n</head>\n<body>\n<div class=\"page\">\n\n  <div class=\"hero\">\n    <div class=\"hero-logo\">MAGI</div>\n    <div class=\"hero-sub\">Your apps, one place.</div>\n    <div class=\"hero-pill\"><span class=\"dot\"></span> <span id=\"statusText\">Checking...</span></div>\n  </div>\n\n  <div class=\"apps\" id=\"apps\"></div>\n\n  <div class=\"footer\">\n    <div class=\"footer-text\">MAGI v2 · Powered by Claude Sonnet · AWS Bedrock</div>\n  </div>\n\n</div>\n\n<script>\nconst APPS = [\n  {\n    icon: 'radar', name: 'Mission Control', tag: 'live',\n    desc: 'Real-time system overview — agents, services, resources, activity.',\n    url: '/mission/',\n    bg: 'rgba(52,211,153,.08)', color: '#34d399'\n  },\n  {\n    icon: 'message-square', name: 'Council Chat', tag: 'live',\n    desc: 'Chat with 12 AI agents — Council, Roundtable, or Private mode.',\n    url: '/chat/',\n    bg: 'rgba(99,102,241,.08)', color: '#6366f1'\n  },\n  {\n    icon: 'vote', name: 'Roundtable', tag: 'live',\n    desc: 'Multi-agent discussion on any topic — parallel responses + AI synthesis.',\n    url: '/roundtable/',\n    bg: 'rgba(168,85,247,.08)', color: '#a78bfa'\n  },\n  {\n    icon: 'book-open', name: 'Vault', tag: 'live',\n    desc: 'Notes, knowledge base, graph view — your Obsidian in the browser.',\n    url: '/vault/',\n    bg: 'rgba(168,85,247,.08)', color: '#a78bfa'\n  },\n  {\n    icon: 'library', name: 'Knowledge Base', tag: 'live',\n    desc: 'Research archive — saved deep dives, intel briefs, auto-indexed.',\n    url: '/knowledge/',\n    bg: 'rgba(52,211,153,.08)', color: '#34d399'\n  },\n  {\n    icon: 'hard-drive', name: 'Files', tag: 'live',\n    desc: 'VPS file manager — browse, upload, download, edit files.',\n    url: '/files/',\n    bg: 'rgba(52,211,153,.08)', color: '#34d399'\n  },\n  {\n    icon: 'bar-chart-3', name: 'Analytics', tag: 'live',\n    desc: 'Agent usage, tokens, costs, system health — real-time dashboard.',\n    url: '/analytics/',\n    bg: 'rgba(245,158,11,.08)', color: '#f59e0b'\n  },\n  {\n    icon: 'activity', name: 'Agent Monitor', tag: 'live',\n    desc: 'Real-time agent status, channel routing, activity log.',\n    url: '/monitor/',\n    bg: 'rgba(34,211,238,.08)', color: '#22d3ee'\n  },\n  {\n    icon: 'kanban', name: 'Task Board', tag: 'live',\n    desc: 'Kanban board — track tasks, priorities, and progress.',\n    url: '/tasks/',\n    bg: 'rgba(168,85,247,.08)', color: '#a78bfa'\n  },\n  { sep: 'Coming Soon' },\n  {\n    icon: 'bot', name: 'ICat Little Helper', tag: 'live',\n    desc: 'Contact manager, message templates, auto-reply rules.',\n    url: '/icat/',\n    bg: 'rgba(52,211,153,.08)', color: '#34d399'\n  },\n  {\n    icon: 'map-pin', name: 'Maps & Leads', tag: 'live',\n    desc: 'Business intel — 158K leads, interactive map, filters, export.',\n    url: '/leads/',\n    bg: 'rgba(245,158,11,.08)', color: '#f59e0b'\n  },\n  {\n    icon: 'git-branch', name: 'Pipeline CRM', tag: 'live',\n    desc: 'Sales funnel — track deals from lead to close.',\n    url: '/pipeline/',\n    bg: 'rgba(249,115,22,.08)', color: '#f97316'\n  },\n  {\n    icon: 'send', name: 'Broadcast', tag: 'live',\n    desc: 'Bulk messaging with templates and rate limiting.',\n    url: '/broadcast/',\n    bg: 'rgba(37,211,102,.08)', color: '#25D366'\n  },\n  {\n    icon: 'bell', name: 'Notifications', tag: 'live',\n    desc: 'Central inbox for all system alerts and events.',\n    url: '/notifications/',\n    bg: 'rgba(248,113,113,.08)', color: '#f87171'\n  },\n  {\n    icon: 'file-bar-chart', name: 'Reports', tag: 'live',\n    desc: 'Weekly summaries, agent performance, cost breakdown.',\n    url: '/reports/',\n    bg: 'rgba(129,140,248,.08)', color: '#818cf8'\n  },\n  { sep: 'System' },\n  {\n    icon: 'log-in', name: 'Login', tag: 'live',\n    desc: 'User authentication and session management.',\n    url: '/login/',\n    bg: 'rgba(107,114,128,.06)', color: '#6b7185'\n  },\n  {\n    icon: 'sliders-horizontal', name: 'Settings', tag: 'live',\n    desc: 'Agent models, intensity, users, channels, cron jobs.',\n    url: '/settings/',\n    bg: 'rgba(107,114,128,.06)', color: '#6b7185'\n  },\n  {\n    icon: 'dice-5', name: 'Paul Simulator', tag: 'live',\n    desc: 'D&D 2024 companion — character sheets, dice, initiative, spells.',\n    url: '/dnd',\n    bg: 'rgba(212,167,58,.08)', color: '#d4a73a'\n  }\n]\n\nfunction render() {\n  const c = document.getElementById('apps')\n  let html = ''\n  for (const a of APPS) {\n    if (a.sep) {\n      html += `<div class=\"sep\"><span class=\"sep-line\"></span><span class=\"sep-text\">${a.sep}</span><span class=\"sep-line\"></span></div>`\n      continue\n    }\n    const tagCls = a.tag === 'live' ? 'tag-live' : a.tag === 'build' ? 'tag-build' : 'tag-soon'\n    const href = a.url ? `href=\"${a.url}\"` : ''\n    const dim = a.url ? '' : 'opacity:.5;cursor:default;'\n    const tagLabel = a.tag === 'live' ? 'Live' : a.tag === 'build' ? 'Building' : 'Soon'\n    html += `<a ${href} class=\"app\" style=\"${dim}\">\n      <div class=\"app-icon\" style=\"background:${a.bg}\"><i data-lucide=\"${a.icon}\" style=\"color:${a.color}\"></i></div>\n      <div class=\"app-body\">\n        <div class=\"app-name\">${a.name} <span class=\"tag ${tagCls}\">${tagLabel}</span></div>\n        <div class=\"app-desc\">${a.desc}</div>\n      </div>\n      ${a.url ? '<span class=\"app-arrow\"><i data-lucide=\"chevron-right\"></i></span>' : ''}\n    </a>`\n  }\n  c.innerHTML = html\n  lucide.createIcons()\n}\n\n;(async () => {\n  render()\n  try {\n    const r = await fetch('/api/agents')\n    const d = await r.json()\n    const n = Object.keys(d.agents || {}).length\n    document.getElementById('statusText').textContent = n + ' agents online'\n  } catch (e) {\n    document.getElementById('statusText').textContent = 'Offline'\n    document.querySelector('.hero-pill .dot').style.background = '#ef4444'\n  }\n})()\n</script>\n<script>if(\"serviceWorker\"in navigator)navigator.serviceWorker.register(\"/sw.js\")</script>\n</body>\n</html>\n"}],"isError":false,"timestamp":1775369320624}}
