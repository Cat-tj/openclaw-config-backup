{"type":"message","id":"70dd238c","parentId":"cb916868","timestamp":"2026-04-05T15:36:49.085Z","message":{"role":"assistant","content":[{"type":"text","text":"Playwright + Chromium installed! Let me write a full QA + screenshot test:"},{"type":"toolCall","id":"tooluse_IEM19NmSbTn6RnHUDlql2K","name":"write","arguments":{"content":"const { chromium } = require('playwright');\nconst fs = require('fs');\nconst path = require('path');\n\nconst BASE = 'http://127.0.0.1:3002';\nconst SCREENSHOTS_DIR = '/tmp/magi-qa';\nconst RESULTS = [];\n\n// All pages to test\nconst PAGES = [\n  { name: 'login', path: '/login/', needsAuth: false },\n  { name: 'dashboard', path: '/dashboard/', needsAuth: true },\n  { name: 'mission', path: '/mission/', needsAuth: true },\n  { name: 'chat', path: '/chat/', needsAuth: true },\n  { name: 'roundtable', path: '/roundtable/', needsAuth: true },\n  { name: 'vault', path: '/vault/', needsAuth: true },\n  { name: 'knowledge', path: '/knowledge/', needsAuth: true },\n  { name: 'monitor', path: '/monitor/', needsAuth: true },\n  { name: 'analytics', path: '/analytics/', needsAuth: true },\n  { name: 'tasks', path: '/tasks/', needsAuth: true },\n  { name: 'files', path: '/files/', needsAuth: true },\n  { name: 'leads', path: '/leads/', needsAuth: true },\n  { name: 'icat', path: '/icat/', needsAuth: true },\n  { name: 'pipeline', path: '/pipeline/', needsAuth: true },\n  { name: 'broadcast', path: '/broadcast/', needsAuth: true },\n  { name: 'reports', path: '/reports/', needsAuth: true },\n  { name: 'notifications', path: '/notifications/', needsAuth: true },\n  { name: 'users', path: '/users/', needsAuth: true },\n  { name: 'settings', path: '/settings/', needsAuth: true },\n];\n\nasync function run() {\n  fs.mkdirSync(SCREENSHOTS_DIR, { recursive: true });\n  \n  const browser = await chromium.launch({ headless: true });\n  const context = await browser.newContext({\n    viewport: { width: 1280, height: 800 },\n    ignoreHTTPSErrors: true\n  });\n\n  // Login first\n  const loginPage = await context.newPage();\n  await loginPage.goto(BASE + '/login/', { waitUntil: 'networkidle', timeout: 15000 });\n  await loginPage.fill('#user', 'lucy');\n  await loginPage.fill('#pass', 'magi2026');\n  await loginPage.click('button[type=\"submit\"]');\n  await loginPage.waitForTimeout(2000);\n  \n  // Get token from localStorage\n  const token = await loginPage.evaluate(() => localStorage.getItem('magi_token'));\n  console.log('Login:', token ? 'OK' : 'FAILED');\n  await loginPage.close();\n\n  // Test each page\n  for (const pg of PAGES) {\n    const page = await context.newPage();\n    const errors = [];\n    const consoleLogs = [];\n    \n    // Capture console errors\n    page.on('console', msg => {\n      if (msg.type() === 'error') consoleLogs.push(msg.text());\n    });\n    page.on('pageerror', err => errors.push(err.message));\n    \n    try {\n      // Set auth token\n      if (pg.needsAuth && token) {\n        await page.addInitScript((t) => {\n          localStorage.setItem('magi_token', t);\n        }, token);\n      }\n      \n      await page.goto(BASE + pg.path, { waitUntil: 'networkidle', timeout: 20000 });\n      await page.waitForTimeout(2000); // Let JS render\n      \n      // Take screenshot\n      await page.screenshot({ \n        path: path.join(SCREENSHOTS_DIR, `${pg.name}.jpg`),\n        type: 'jpeg',\n        quality: 80,\n        fullPage: false\n      });\n      \n      // Check for visible content\n      const bodyText = await page.evaluate(() => document.body?.innerText?.length || 0);\n      const hasNav = await page.evaluate(() => !!document.querySelector('.apex-nav'));\n      const hasError = errors.length > 0;\n      const jsErrors = consoleLogs.filter(l => l.includes('Error') || l.includes('error') || l.includes('Uncaught'));\n      \n      RESULTS.push({\n        page: pg.name,\n        status: hasError ? 'ERROR' : 'OK',\n        bodyLength: bodyText,\n        hasNav: pg.name === 'login' ? 'N/A' : hasNav,\n        jsErrors: jsErrors.length,\n        errorDetails: [...errors, ...jsErrors].slice(0, 3)\n      });\n      \n      console.log(`${hasError ? '❌' : '✅'} ${pg.name} — ${bodyText} chars, nav:${hasNav}, errors:${errors.length}, jsErr:${jsErrors.length}`);\n    } catch (e) {\n      RESULTS.push({ page: pg.name, status: 'CRASH', error: e.message });\n      console.log(`💥 ${pg.name} — CRASH: ${e.message.slice(0, 80)}`);\n    }\n    \n    await page.close();\n  }\n  \n  await browser.close();\n  \n  // Summary\n  console.log('\\n=== QA SUMMARY ===');\n  const ok = RESULTS.filter(r => r.status === 'OK').length;\n  const err = RESULTS.filter(r => r.status === 'ERROR').length;\n  const crash = RESULTS.filter(r => r.status === 'CRASH').length;\n  console.log(`Total: ${RESULTS.length} | ✅ OK: ${ok} | ❌ Error: ${err} | 💥 Crash: ${crash}`);\n  \n  if (err + crash > 0) {\n    console.log('\\nIssues:');\n    RESULTS.filter(r => r.status !== 'OK').forEach(r => {\n      console.log(`  ${r.page}: ${r.status} — ${(r.errorDetails || [r.error]).join('; ').slice(0, 150)}`);\n    });\n  }\n  \n  // Save results\n  fs.writeFileSync(path.join(SCREENSHOTS_DIR, 'results.json'), JSON.stringify(RESULTS, null, 2));\n  console.log(`\\nScreenshots saved to ${SCREENSHOTS_DIR}/`);\n}\n\nrun().catch(e => { console.error('Fatal:', e.message); process.exit(1); });\n","path":"/tmp/magi-qa-test.js"}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-opus-4-6-v1","usage":{"input":1,"output":1765,"cacheRead":321831,"cacheWrite":136,"totalTokens":323733,"cost":{"input":0.000005,"output":0.044125000000000004,"cacheRead":0.1609155,"cacheWrite":0.0008500000000000001,"total":0.20589549999999998}},"stopReason":"toolUse","timestamp":1775403381026}}
