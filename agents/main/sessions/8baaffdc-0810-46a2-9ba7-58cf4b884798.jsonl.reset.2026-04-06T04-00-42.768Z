{"type":"message","id":"1b9a5d20","parentId":"5a3b1c02","timestamp":"2026-04-05T05:34:04.692Z","message":{"role":"assistant","content":[{"type":"text","text":"Now replace the renderMd function and add the CodeBlock component:"},{"type":"toolCall","id":"tooluse_i3BL0FrSBhzPod8tR45OL8","name":"edit","arguments":{"file":"~/council-room/frontend/it-support.html","newText":"function renderMd(text){\n  // Code blocks → CodeBlock component\n  text = text.replace(/```(\\w*)\\n([\\s\\S]*?)```/g, (_, lang, code) => {\n    const id = 'cb-' + Math.random().toString(36).slice(2,8);\n    setTimeout(() => renderCodeBlock(id, code.trim(), lang || 'text'), 0);\n    return `<div id=\"${id}\" class=\"cb\" style=\"min-height:40px;opacity:.5\"><div class=\"cb-body\"><div class=\"cb-code\" style=\"padding:.6rem .85rem;font-size:.68rem;color:var(--dim)\">Loading...</div></div></div>`;\n  });\n  // Inline code\n  text = text.replace(/`([^`]+)`/g, '<code>$1</code>');\n  // Bold\n  text = text.replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>');\n  return text;\n}\n\n// ── Code Block Component ──\nfunction createCodeBlock(code, lang, opts={}){\n  const showLines = opts.lines !== false;\n  const filename = opts.filename || '';\n  const lines = code.split('\\n');\n  const lineNums = lines.map((_,i) => i+1).join('\\n');\n  const langLabel = lang || 'text';\n  const cbId = 'cb-' + Math.random().toString(36).slice(2,8);\n\n  let highlighted = escHtml(code);\n  if(window.sugarHighlight){\n    try{ highlighted = window.sugarHighlight(code); }catch(e){}\n  }\n\n  const rawB64 = btoa(unescape(encodeURIComponent(code)));\n\n  return `<div class=\"cb\" id=\"${cbId}\">\n    <div class=\"cb-header\">\n      <div class=\"cb-lang\">${filename ? `<span class=\"cb-filename\">${escHtml(filename)}</span>` : ''}<span class=\"cb-lang-pill\">${escHtml(langLabel)}</span></div>\n      <button class=\"cb-copy\" onclick=\"copyCode(this,'${cbId}')\" style=\"opacity:.6\">📋 Copy</button>\n    </div>\n    <div class=\"cb-body\">\n      ${showLines ? `<div class=\"cb-lines\">${lineNums}</div>` : ''}\n      <div class=\"cb-code\" data-raw=\"${rawB64}\">${highlighted}</div>\n    </div>\n  </div>`;\n}\n\nfunction renderCodeBlock(id, code, lang){\n  const el = document.getElementById(id);\n  if(!el) return;\n  el.outerHTML = createCodeBlock(code, lang);\n}\n\nfunction copyCode(btn, cbId){\n  const codeEl = document.querySelector('#'+cbId+' .cb-code');\n  if(!codeEl) return;\n  let raw;\n  try{ raw = decodeURIComponent(escape(atob(codeEl.dataset.raw))); }catch{ raw = codeEl.textContent; }\n  navigator.clipboard.writeText(raw).then(()=>{\n    btn.textContent = '✅ Copied!';\n    btn.classList.add('copied');\n    setTimeout(()=>{ btn.textContent = '📋 Copy'; btn.classList.remove('copied'); }, 2000);\n  });\n}\n\nfunction copyQcCmd(el, cmd){\n  navigator.clipboard.writeText(cmd).then(()=>{\n    el.classList.add('qc-copied');\n    el.querySelector('.qc-cp').textContent = '✅';\n    setTimeout(()=>{ el.classList.remove('qc-copied'); el.querySelector('.qc-cp').textContent = 'copy'; }, 1500);\n  });\n}\n\n// ── Quick Commands Data ──\nconst QC_COMMANDS = [\n  { title: '⚡ OpenClaw', cmds: [\n    'openclaw gateway restart',\n    'openclaw gateway status',\n    'openclaw doctor',\n    'openclaw status'\n  ]},\n  { title: '🔄 PM2', cmds: [\n    'pm2 restart council-room',\n    'pm2 logs council-room --lines 50',\n    'pm2 list',\n    'pm2 monit'\n  ]},\n  { title: '🖥️ System', cmds: [\n    'free -m',\n    'df -h',\n    'top -bn1 | head -20',\n    'journalctl -u pm2-openclaw --since \"1h ago\"'\n  ]},\n  { title: '🐳 Docker', cmds: [\n    'docker ps',\n    'docker stats --no-stream',\n    'docker logs couchdb --tail 50',\n    'docker system df'\n  ]}\n];\n\nfunction renderQuickCommands(){\n  const grid = document.getElementById('qcGrid');\n  if(!grid) return;\n  grid.innerHTML = QC_COMMANDS.map(cat => `\n    <div class=\"qc-card\">\n      <div class=\"qc-title\">${cat.title}</div>\n      ${cat.cmds.map(cmd => `\n        <div class=\"qc-cmd\" onclick=\"copyQcCmd(this,${JSON.stringify(cmd)})\">\n          <span class=\"qc-prompt\">$</span>\n          <span class=\"qc-text\">${escHtml(cmd)}</span>\n          <span class=\"qc-cp\">copy</span>\n        </div>\n      `).join('')}\n    </div>\n  `).join('');\n}\nrenderQuickCommands();","oldText":"function renderMd(text){\n  // Code blocks\n  text = text.replace(/```(\\w*)\\n([\\s\\S]*?)```/g, '<pre><code>$2</code></pre>');\n  // Inline code\n  text = text.replace(/`([^`]+)`/g, '<code>$1</code>');\n  // Bold\n  text = text.replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>');\n  // Escape html (but preserve our tags)\n  return text;\n}"}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-opus-4-6-v1","usage":{"input":1,"output":1652,"cacheRead":85299,"cacheWrite":206,"totalTokens":87158,"cost":{"input":0.000005,"output":0.0413,"cacheRead":0.0426495,"cacheWrite":0.0012875,"total":0.085242}},"stopReason":"toolUse","timestamp":1775367225193}}
