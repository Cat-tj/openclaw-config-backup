class=\"cb-header\">\n+717       <div class=\"cb-lang\">${filename ? `<span class=\"cb-filename\">${escHtml(filename)}</span>` : ''}<span class=\"cb-lang-pill\">${escHtml(langLabel)}</span></div>\n+718       <button class=\"cb-copy\" onclick=\"copyCode(this,'${cbId}')\" style=\"opacity:.6\">📋 Copy</button>\n+719     </div>\n+720     <div class=\"cb-body\">\n+721       ${showLines ? `<div class=\"cb-lines\">${lineNums}</div>` : ''}\n+722       <div class=\"cb-code\" data-raw=\"${rawB64}\">${highlighted}</div>\n+723     </div>\n+724   </div>`;\n+725 }\n+726 \n+727 function renderCodeBlock(id, code, lang){\n+728   const el = document.getElementById(id);\n+729   if(!el) return;\n+730   el.outerHTML = createCodeBlock(code, lang);\n+731 }\n+732 \n+733 function copyCode(btn, cbId){\n+734   const codeEl = document.querySelector('#'+cbId+' .cb-code');\n+735   if(!codeEl) return;\n+736   let raw;\n+737   try{ raw = decodeURIComponent(escape(atob(codeEl.dataset.raw))); }catch{ raw = codeEl.textContent; }\n+738   navigator.clipboard.writeText(raw).then(()=>{\n+739     btn.textContent = '✅ Copied!';\n+740     btn.classList.add('copied');\n+741     setTimeout(()=>{ btn.textContent = '📋 Copy'; btn.classList.remove('copied'); }, 2000);\n+742   });\n+743 }\n+744 \n+745 function copyQcCmd(el, cmd){\n+746   navigator.clipboard.writeText(cmd).then(()=>{\n+747     el.classList.add('qc-copied');\n+748     el.querySelector('.qc-cp').textContent = '✅';\n+749     setTimeout(()=>{ el.classList.remove('qc-copied'); el.querySelector('.qc-cp').textContent = 'copy'; }, 1500);\n+750   });\n+751 }\n+752 \n+753 // ── Quick Commands Data ──\n+754 const QC_COMMANDS = [\n+755   { title: '⚡ OpenClaw', cmds: [\n+756     'openclaw gateway restart',\n+757     'openclaw gateway status',\n+758     'openclaw doctor',\n+759     'openclaw status'\n+760   ]},\n+761   { title: '🔄 PM2', cmds: [\n+762     'pm2 restart council-room',\n+763     'pm2 logs council-room --lines 50',\n+764     'pm2 list',\n+765     'pm2 monit'\n+766   ]},\n+767   { title: '🖥️ System', cmds: [\n+768     'free -m',\n+769     'df -h',\n+770     'top -bn1 | head -20',\n+771     'journalctl -u pm2-openclaw --since \"1h ago\"'\n+772   ]},\n+773   { title: '🐳 Docker', cmds: [\n+774     'docker ps',\n+775     'docker stats --no-stream',\n+776     'docker logs couchdb --tail 50',\n+777     'docker system df'\n+778   ]}\n+779 ];\n+780 \n+781 function renderQuickCommands(){\n+782   const grid = document.getElementById('qcGrid');\n+783   if(!grid) return;\n+784   grid.innerHTML = QC_COMMANDS.map(cat => `\n+785     <div class=\"qc-card\">\n+786       <div class=\"qc-title\">${cat.title}</div>\n+787       ${cat.cmds.map(cmd => `\n+788         <div class=\"qc-cmd\" onclick=\"copyQcCmd(this,${JSON.stringify(cmd)})\">\n+789           <span class=\"qc-prompt\">$</span>\n+790           <span class=\"qc-text\">${escHtml(cmd)}</span>\n+791           <span class=\"qc-cp\">copy</span>\n+792         </div>\n+793       `).join('')}\n+794     </div>\n+795   `).join('');\n+796 }\n+797 renderQuickCommands();\n+798 \n 696 async function clearChat(){\n 697   try{\n 698     await fetch(API+'/it-support/clear',{method:'POST',headers:headers(),body:JSON.stringify({sessionId:chatSessionId})});\n 699   }catch{}\n     ...","firstChangedLine":686},"isError":false,"timestamp":1775367244743}}
