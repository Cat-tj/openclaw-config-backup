, 0.06);\n  --border-strong: rgba(255, 255, 255, 0.11);\n  \n  --text: #c9d1d9;\n  --text-primary: #c9d1d9;\n  --text-bright: #f3f4f6;\n  --text-secondary: #8b95a8;\n  --text-muted: #6e7681;\n  --text-tertiary: #6e7681;\n  --text-dim: #424854;\n  \n  --accent: #63ebff;\n  --accent-dim: rgba(99, 235, 255, 0.4);\n  --accent-bg: rgba(99, 235, 255, 0.08);\n  --color-primary: #63ebff;\n  --color-primary-dim: rgba(99, 235, 255, 0.10);\n  --color-accent: #63ebff;\n  --color-accent-dim: rgba(99, 235, 255, 0.12);\n  \n  --color-success: #86efac;\n  --color-warning: #fde047;\n  --color-danger: #fca5a5;\n  --color-info: #a5f3fc;\n  \n  --radius-sm: 6px;\n  --radius-md: 10px;\n  --radius-lg: 14px;\n  \n  --font-sans: 'JetBrains Mono', 'SF Mono', Consolas, monospace;\n  --font-mono: 'JetBrains Mono', 'SF Mono', Consolas, monospace;\n  \n  --ease-out: cubic-bezier(0.22, 1, 0.36, 1);\n  --duration-fast: 150ms;\n  --duration-normal: 200ms;\n  \n  --nav-width: 56px;\n  --nav-width-expanded: 220px;\n}\n\n*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\nhtml, body { height: 100%; overflow-x: hidden; }\nbody {\n  font-family: var(--font-sans);\n  font-size: 13px;\n  line-height: 1.6;\n  background: var(--bg);\n  color: var(--text);\n  -webkit-font-smoothing: antialiased;\n}\n\n/* Grid texture background (NOT orbs) */\nbody::before {\n  content: '';\n  position: fixed;\n  inset: 0;\n  pointer-events: none;\n  z-index: 0;\n  background-image:\n    linear-gradient(rgba(255, 255, 255, 0.024) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(255, 255, 255, 0.024) 1px, transparent 1px);\n  background-size: 48px 48px;\n}\nbody::after { display: none; }\n\n::selection { background: rgba(99, 235, 255, 0.25); color: #fff; }\n::-webkit-scrollbar { width: 5px; height: 5px; }\n::-webkit-scrollbar-track { background: transparent; }\n::-webkit-scrollbar-thumb { background: rgba(99, 235, 255, 0.10); border-radius: 999px; }\n::-webkit-scrollbar-thumb:hover { background: rgba(99, 235, 255, 0.18); }\n* { scrollbar-width: thin; scrollbar-color: rgba(99, 235, 255, 0.10) transparent; }\n\na { color: var(--accent); text-decoration: none; }\na:hover { text-decoration: underline; }\n:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }\n\n/* Animations */\n@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }\n@keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }\n@keyframes staggerIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }\n@keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.3; } }\n@keyframes spin { to { transform: rotate(360deg); } }\n@keyframes countUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }\n\n/* Stagger entry system - 50ms per item */\n.stagger-item { opacity: 0; transform: translateY(12px); animation: staggerIn 0.4s var(--ease-out) forwards; }\n.stagger-item:nth-child(1){animation-delay:0ms}.stagger-item:nth-child(2){animation-delay:50ms}\n.stagger-item:nth-child(3){animation-delay:100ms}.stagger-item:nth-child(4){animation-delay:150ms}\n.stagger-item:nth-child(5){animation-delay:200ms}.stagger-item:nth-child(6){animation-delay:250ms}\n.stagger-item:nth-child(7){animation-delay:300ms}.stagger-item:nth-child(8){animation-delay:350ms}\n.stagger-item:nth-child(9){animation-delay:400ms}.stagger-item:nth-child(10){animation-delay:450ms}\n.stagger-item:nth-child(11){animation-delay:500ms}.stagger-item:nth-child(12){animation-delay:550ms}\n\n/* Page transition overlay */\n#apex-transition{position:fixed;inset:0;z-index:9999;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none;opacity:0;transition:opacity .2s ease}\n#apex-transition.active{opacity:1;pointer-events:all}\n#apex-transition .t-icon{font-size:64px;opacity:0;transform:scale(.8);transition:all .4s var(--ease-out)}\n#apex-transition.show-icon .t-icon{opacity:1;transform:scale(1)}\n#apex-transition .t-label{font-size:13px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:3px;margin-top:16px;opacity:0;transition:opacity .3s ease}\n#apex-transition.show-label .t-label{opacity:1}\n\n/* Page content entrance */\n.page-enter{opacity:0;transform:translateY(20px)}\n.page-enter.visible{opacity:1;transform:translateY(0);transition:opacity .4s var(--ease-out),transform .4s var(--ease-out)}\n```\n\nAlso download JetBrains Mono woff2 files to /shared/fonts/:\n```bash\nmkdir -p ~/magi-v2/frontend/shared/fonts\ncurl -L \"https://github.com/JetBrains/JetBrainsMono/raw/master/fonts/webfonts/JetBrainsMono-Regular.woff2\" -o ~/magi-v2/frontend/shared/fonts/jetbrains-mono-400.woff2\ncurl -L \"https://github.com/JetBrains/JetBrainsMono/raw/master/fonts/webfonts/JetBrainsMono-Medium.woff2\" -o ~/magi-v2/frontend/shared/fonts/jetbrains-mono-500.woff2\ncurl -L \"https://github.com/JetBrains/JetBrainsMono/raw/master/fonts/webfonts/JetBrainsMono-SemiBold.woff2\" -o ~/magi-v2/frontend/shared/fonts/jetbrains-mono-600.woff2\ncurl -L \"https://github.com/JetBrains/JetBrainsMono/raw/master/fonts/webfonts/JetBrainsMono-Bold.woff2\" -o ~/magi-v2/frontend/shared/fonts/jetbrains-mono-700.woff2\n```\nIf the GitHub URLs fail, use Google Fonts CDN as fallback in the @font-face src.\n\n## DELIVERABLE 2: Replace `/shared/components.css`\n\nFull rewrite — Apex style components:\n\n- **Buttons:** Cyan gradient primary `.btn-primary { border: 1px solid var(--accent-dim); background: linear-gradient(180deg, rgba(99,235,255,0.14), rgba(99,235,255,0.08)); color: var(--accent); }` with hover glow. Secondary = subtle border. Danger = red tint. Ghost = transparent.\n- **Cards:** Minimal — `background: var(--bg-elevated); border: 1px solid var(--border); border-radius: var(--radius-md);` NO backdrop-filter blur.\n- **Inputs:** `background: rgba(0,0,0,0.3); border: 1px solid var(--border); color: var(--text);` Focus = `border-color: rgba(255,255,255,0.28)`\n- **Badges:** Small pills. Success = green bg, Warning = yellow, Danger = red, Info = cyan.\n- **Modals:** `background: var(--bg); border: 1px solid var(--border-strong);`\n- **Toast:** Slide up from bottom-right. Types: success (green border), error (red), warning (yellow), info (cyan).\n- **Tables:** Minimal. No zebra. Just `border-bottom: 1px solid var(--border)` per row.\n- **Spinner:** CSS-only, cyan border.\n- **Empty state:** centered icon + text + optional action button.\n- **Toggle switch:** Pill-shaped, cyan when on, smooth transition.\n- **Page layout:** `.page-layout { display: flex; height: 100dvh; }` with sidebar + main content area.\n\n## DELIVERABLE 3: Replace `/shared/nav.js`\n\nComplete rewrite — Apex sidebar navigation:\n\n**Desktop:** Left sidebar, fixed, 56px collapsed → 220px on hover.\n**Active item:** 3px cyan left border + brighter bg.\n**Font:** JetBrains Mono, 12px.\n**Grouped sections with small uppercase headers:**\n- CORE: Dashboard, Chat, Roundtable, Vault\n- OPERATIONS: Mission, Monitor, Analytics, Tasks, Files\n- BUSINESS: Leads, ICat, Pipeline, Broadcast\n- SYSTEM: Settings, Reports, Notifications\n\n**Each item:** Icon (emoji or Lucide) + label (visible when expanded).\n**Bottom:** Small MAGI logo + version text.\n**Mobile (<768px):** Hidden by default. Hamburger button fixed top-left. Slide-out overlay with dark backdrop.\n\n**CRITICAL: Integrate page transitions.** When a nav item is clicked, don't just `window.location.href` — call the transition system first:\n```javascript\nfunction handleNavClick(url, icon, label) {\n  // If transitions module loaded, use it\n  if (window.__apexNavTo) {\n    window.__apexNavTo(url, icon, label);\n  } else {\n    window.location.href = url;\n  }\n}\n```\n\n## DELIVERABLE 4: NEW `/shared/transitions.js`\n\nPage transition animation system:\n\n```javascript\nexport function initTransitions() {\n  // Create overlay DOM\n  // Fade in current page content on load (page-enter → visible)\n}\n\nexport function navTo(url, icon, label) {\n  // 1. Add .page-enter to main content (fade out current)\n  // 2. Show overlay (.active)\n  // 3. After 200ms: show icon (.show-icon) \n  // 4. After 500ms: show label (.show-label)\n  // 5. After 1200ms: navigate to url (window.location.href = url)\n}\n```\n\nRegister globally: `window.__apexNavTo = navTo;`\n\n## DELIVERABLE 5: NEW `/shared/countup.js`\n\nAnimated number counting for stat cards:\n\n```javascript\nexport function initCountUp() {\n  // Find all [data-countup] elements\n  // Use IntersectionObserver to trigger when visible\n  // Animate from 0 to target using requestAnimationFrame\n  // Duration: 800ms, ease-out\n  // Support: integers, decimals, percentages\n}\n```\n\nUsage: `<span data-countup=\"1234\">0</span>` → animates to 1234.\n\n## Rules\n- Overwrite the existing shared files completely\n- Download JetBrains Mono font files\n- Keep ALL export function signatures compatible (don't break existing page imports)\n- The nav must expose `renderNav(activePage)` as before\n- core.js should NOT be modified (keep auth, api, toast, etc as-is)\n- Test font downloads work\n- All CSS values must match the AlphaClaw Apex spec exactly"}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-opus-4-6-v1","usage":{"input":3,"output":4037,"cacheRead":0,"cacheWrite":182485,"totalTokens":186525,"cost":{"input":0.000015000000000000002,"output":0.100925,"cacheRead":0,"cacheWrite":1.14053125,"total":1.24147125}},"stopReason":"toolUse","timestamp":1775380527538}}
