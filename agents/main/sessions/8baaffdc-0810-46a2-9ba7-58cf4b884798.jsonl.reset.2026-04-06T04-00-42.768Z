{"type":"message","id":"db4dde43","parentId":"47d42998","timestamp":"2026-04-05T05:31:18.795Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"tooluse_j738qtBZHYGerAI0IgD9uo","name":"read","arguments":{"path":"~/council-room/frontend/it-support.html"}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-opus-4-6-v1","usage":{"input":1,"output":62,"cacheRead":66781,"cacheWrite":114,"totalTokens":66958,"cost":{"input":0.000005,"output":0.0015500000000000002,"cacheRead":0.0333905,"cacheWrite":0.0007125,"total":0.035657999999999995}},"stopReason":"toolUse","timestamp":1775367075660}}
{"type":"message","id":"a8ffd426","parentId":"db4dde43","timestamp":"2026-04-05T05:31:18.841Z","message":{"role":"toolResult","toolCallId":"tooluse_j738qtBZHYGerAI0IgD9uo","toolName":"read","content":[{"type":"text","text":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>IT Support — MAGI</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&family=JetBrains+Mono:wght@400;500&display=swap\" rel=\"stylesheet\">\n<style>\n*{box-sizing:border-box;margin:0;padding:0}\n:root{\n  --bg:#07080f;--s1:#0d0f1a;--s2:#111320;--b1:rgba(255,255,255,.07);\n  --ivory:#c9d8e8;--ash:#7a9ab8;--dim:#3a5a78;\n  --indigo:#6366f1;--sage:#10b981;--ember:#ef4444;--gold:#f59e0b;\n  --violet:#8b5cf6;--sky:#38bdf8;--met:#06b6d4;--pink:#ec4899;\n}\nbody{background:var(--bg);color:var(--ivory);font-family:'Inter',sans-serif;min-height:100vh}\n\n/* ── Header ── */\n.header{background:rgba(6,6,8,.92);border-bottom:1px solid var(--b1);backdrop-filter:blur(20px);\n  padding:.75rem 1.5rem;display:flex;align-items:center;gap:.75rem;position:sticky;top:0;z-index:100}\n.header-logo{font-family:'Space Grotesk',sans-serif;font-size:1rem;font-weight:700}\n.header-sub{font-size:.72rem;color:var(--ash);margin-left:.5rem}\n.header-right{margin-left:auto;display:flex;align-items:center;gap:.75rem}\n.status-dot{width:8px;height:8px;border-radius:50%;animation:pulse 2s infinite}\n.status-dot.ok{background:var(--sage)}\n.status-dot.err{background:var(--ember)}\n.status-dot.warn{background:var(--gold)}\n@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}\n.hdr-btn{padding:.3rem .75rem;background:rgba(99,102,241,.15);border:1px solid rgba(99,102,241,.3);\n  border-radius:7px;color:var(--indigo);font-size:.72rem;cursor:pointer;font-family:'Inter',sans-serif;transition:.2s}\n.hdr-btn:hover{background:rgba(99,102,241,.25)}\n\n/* ── Container ── */\n.container{padding:1.25rem;max-width:1400px;margin:0 auto}\n.section-title{font-size:.65rem;font-weight:700;color:var(--dim);text-transform:uppercase;\n  letter-spacing:.1em;margin-bottom:.75rem;margin-top:1.5rem}\n.section-title:first-child{margin-top:0}\n\n/* ── KPI row ── */\n.kpi-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:.6rem;margin-bottom:.5rem}\n.kpi{background:var(--s1);border:1px solid var(--b1);border-radius:12px;padding:.75rem 1rem;transition:.2s}\n.kpi:hover{border-color:rgba(99,102,241,.2)}\n.kpi-label{font-size:.63rem;color:var(--ash);margin-bottom:.25rem;font-weight:500}\n.kpi-val{font-size:1.4rem;font-weight:700;line-height:1}\n.kpi-sub{font-size:.58rem;color:var(--dim);margin-top:.2rem}\n\n/* ── Grid ── */\n.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}\n.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.75rem}\n@media(max-width:900px){.grid-2,.grid-3{grid-template-columns:1fr}}\n\n/* ── Cards ── */\n.card{background:var(--s1);border:1px solid var(--b1);border-radius:14px;padding:1rem;transition:.2s}\n.card:hover{border-color:rgba(99,102,241,.15)}\n.card-h{font-size:.75rem;font-weight:700;margin-bottom:.75rem;display:flex;align-items:center;\n  justify-content:space-between;gap:.5rem;padding-bottom:.5rem;border-bottom:1px solid var(--b1)}\n\n/* ── Badges ── */\n.badge{display:inline-block;font-size:.58rem;padding:.12rem .45rem;border-radius:8px;font-weight:600}\n.badge-online{background:rgba(16,185,129,.15);color:var(--sage);border:1px solid rgba(16,185,129,.3)}\n.badge-offline{background:rgba(239,68,68,.15);color:var(--ember);border:1px solid rgba(239,68,68,.3)}\n.badge-warn{background:rgba(245,158,11,.15);color:var(--gold);border:1px solid rgba(245,158,11,.3)}\n.badge-model{background:rgba(99,102,241,.1);color:#a5b4fc;border:1px solid rgba(99,102,241,.2);font-family:'JetBrains Mono',monospace}\n\n/* ── Agent grid ── */\n.agent-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:.6rem}\n.agent-card{background:var(--s2);border:1px solid var(--b1);border-radius:10px;padding:.7rem .85rem;transition:.25s}\n.agent-card:hover{border-color:rgba(99,102,241,.25);transform:translateY(-1px)}\n.agent-card.agent-down{border-color:rgba(239,68,68,.3);background:rgba(239,68,68,.04)}\n.agent-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:.4rem}\n.agent-name{font-size:.78rem;font-weight:600;display:flex;align-items:center;gap:.4rem}\n.agent-role{font-size:.6rem;color:var(--dim);margin-bottom:.5rem}\n.agent-model-row{display:flex;align-items:center;gap:.4rem;margin-bottom:.4rem}\n.agent-model-row select{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);\n  border-radius:6px;padding:.25rem .4rem;color:var(--ivory);font-size:.65rem;\n  font-family:'JetBrains Mono',monospace;outline:none;cursor:pointer;flex:1}\n.agent-model-row select:hover{border-color:rgba(99,102,241,.3)}\n.agent-actions{display:flex;gap:.35rem;flex-wrap:wrap}\n\n/* ── Buttons ── */\n.btn{padding:.35rem .65rem;border-radius:7px;font-size:.65rem;font-weight:600;cursor:pointer;\n  font-family:'Inter',sans-serif;border:1px solid;transition:.2s;display:inline-flex;align-items:center;gap:.3rem}\n.btn:disabled{opacity:.4;cursor:not-allowed}\n.btn-primary{background:rgba(99,102,241,.2);border-color:rgba(99,102,241,.35);color:#a5b4fc}\n.btn-primary:hover:not(:disabled){background:rgba(99,102,241,.3)}\n.btn-danger{background:rgba(239,68,68,.15);border-color:rgba(239,68,68,.3);color:var(--ember)}\n.btn-danger:hover:not(:disabled){background:rgba(239,68,68,.25)}\n.btn-success{background:rgba(16,185,129,.15);border-color:rgba(16,185,129,.3);color:var(--sage)}\n.btn-success:hover:not(:disabled){background:rgba(16,185,129,.25)}\n.btn-warn{background:rgba(245,158,11,.12);border-color:rgba(245,158,11,.3);color:var(--gold)}\n.btn-warn:hover:not(:disabled){background:rgba(245,158,11,.2)}\n.btn-lg{padding:.5rem 1rem;font-size:.78rem;border-radius:10px}\n\n/* ── Emergency Panel ── */\n.emergency-panel{background:linear-gradient(135deg,rgba(239,68,68,.06),rgba(245,158,11,.04));\n  border:1px solid rgba(239,68,68,.2);border-radius:16px;padding:1.25rem;margin-bottom:1rem}\n.emergency-title{font-size:.85rem;font-weight:700;color:var(--ember);margin-bottom:.75rem;\n  display:flex;align-items:center;gap:.5rem}\n.emergency-actions{display:flex;flex-wrap:wrap;gap:.6rem}\n\n/* ── Process rows ── */\n.proc-row{display:flex;align-items:center;gap:.75rem;padding:.5rem 0;border-bottom:1px solid rgba(255,255,255,.04)}\n.proc-row:last-child{border-bottom:none}\n.proc-name{font-size:.75rem;font-weight:600;min-width:130px}\n.proc-meta{font-size:.65rem;color:var(--ash);display:flex;gap:.75rem;flex:1;flex-wrap:wrap}\n.proc-meta span{display:flex;align-items:center;gap:.2rem}\n\n/* ── Log feed ── */\n.log-feed{background:var(--s2);border:1px solid var(--b1);border-radius:8px;\n  padding:.6rem;max-height:280px;overflow-y:auto;font-size:.67rem;font-family:'JetBrains Mono',monospace;\n  color:var(--ash);line-height:1.8}\n.log-feed::-webkit-scrollbar{width:3px}\n.log-feed::-webkit-scrollbar-thumb{background:rgba(99,102,241,.3);border-radius:3px}\n.log-line{padding:.04rem 0}\n.log-line.ok{color:var(--sage)}\n.log-line.err{color:var(--ember)}\n.log-line.warn{color:var(--gold)}\n.log-line.info{color:var(--met)}\n\n/* ── Gauge bars ── */\n.gauge{height:8px;background:rgba(255,255,255,.06);border-radius:4px;overflow:hidden;margin-top:.35rem}\n.gauge-fill{height:100%;border-radius:4px;transition:width .6s}\n\n/* ── Chat ── */\n.chat-messages{max-height:400px;overflow-y:auto;padding:.5rem;display:flex;flex-direction:column;gap:.5rem;\n  margin-bottom:.75rem;background:var(--s2);border-radius:10px;border:1px solid var(--b1);min-height:120px}\n.chat-messages::-webkit-scrollbar{width:3px}\n.chat-messages::-webkit-scrollbar-thumb{background:rgba(99,102,241,.3);border-radius:3px}\n.chat-msg{display:flex}\n.chat-msg.user{justify-content:flex-end}\n.chat-msg.bot{justify-content:flex-start}\n.chat-bubble{max-width:80%;padding:.55rem .85rem;border-radius:12px;font-size:.78rem;line-height:1.55;\n  word-wrap:break-word;white-space:pre-wrap}\n.chat-bubble.user{background:rgba(99,102,241,.2);border:1px solid rgba(99,102,241,.3);color:var(--ivory)}\n.chat-bubble.bot{background:rgba(239,130,68,.08);border:1px solid rgba(239,130,68,.2);color:var(--ivory)}\n.chat-bubble code{background:rgba(0,0,0,.3);padding:.1rem .35rem;border-radius:4px;font-size:.7rem;\n  font-family:'JetBrains Mono',monospace}\n.chat-bubble pre{background:rgba(0,0,0,.4);padding:.5rem;border-radius:6px;overflow-x:auto;\n  margin:.4rem 0;font-size:.67rem;font-family:'JetBrains Mono',monospace;line-height:1.5}\n.chat-input-row{display:flex;gap:.5rem}\n.chat-input{flex:1;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);\n  border-radius:10px;padding:.6rem .85rem;color:var(--ivory);font-size:.8rem;\n  font-family:'Inter',sans-serif;outline:none;transition:.2s}\n.chat-input:focus{border-color:rgba(99,102,241,.4);background:rgba(255,255,255,.08)}\n.chat-send{padding:.6rem 1.2rem;font-size:.78rem}\n.chat-typing{display:flex;align-items:center;gap:.3rem;padding:.3rem .6rem;font-size:.68rem;color:var(--ash)}\n.chat-typing .dot{width:5px;height:5px;border-radius:50%;background:var(--ash);animation:blink 1.2s infinite}\n.chat-typing .dot:nth-child(2){animation-delay:.2s}\n.chat-typing .dot:nth-child(3){animation-delay:.4s}\n@keyframes blink{0%,100%{opacity:.2}50%{opacity:1}}\n\n/* ── Toast ── */\n.toast{position:fixed;bottom:1.5rem;right:1.5rem;padding:.65rem 1.1rem;border-radius:10px;\n  font-size:.75rem;font-weight:600;z-index:10000;animation:slideUp .3s ease;max-width:360px}\n.toast.success{background:rgba(16,185,129,.9);color:#fff}\n.toast.error{background:rgba(239,68,68,.9);color:#fff}\n.toast.info{background:rgba(99,102,241,.9);color:#fff}\n@keyframes slideUp{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}\n\n/* ── Model mode buttons ── */\n.mode-btns{display:flex;gap:.4rem;flex-wrap:wrap}\n.mode-btn{padding:.35rem .7rem;border-radius:8px;font-size:.68rem;font-weight:600;cursor:pointer;\n  border:1px solid;font-family:'Inter',sans-serif;transition:.2s}\n.mode-btn.eco{background:rgba(16,185,129,.12);border-color:rgba(16,185,129,.3);color:var(--sage)}\n.mode-btn.standard{background:rgba(99,102,241,.12);border-color:rgba(99,102,241,.3);color:#a5b4fc}\n.mode-btn.max{background:rgba(245,158,11,.12);border-color:rgba(245,158,11,.3);color:var(--gold)}\n.mode-btn:hover{filter:brightness(1.2)}\n.mode-btn.active{box-shadow:0 0 12px rgba(99,102,241,.3)}\n\n/* ── Responsive ── */\n@media(max-width:640px){\n  .header{padding:.6rem .75rem;flex-wrap:wrap;gap:.4rem}\n  .container{padding:.75rem}\n  .emergency-actions{flex-direction:column}\n  .kpi-row{grid-template-columns:1fr 1fr}\n  .agent-grid{grid-template-columns:1fr}\n}\n</style>\n</head>\n<body>\n\n<!-- No login wall — uses shared MAGI token -->\n\n<!-- Header -->\n<div class=\"header\">\n  <div style=\"font-size:1.1rem\">🔧</div>\n  <div class=\"header-logo\">MAGI <span class=\"header-sub\">IT Support</span></div>\n  <div class=\"header-right\">\n    <div style=\"display:flex;align-items:center;gap:.4rem;font-size:.7rem\" id=\"connStatus\">\n      <div class=\"status-dot ok\" id=\"connDot\"></div> <span id=\"connLabel\">Checking...</span>\n    </div>\n    <span style=\"font-size:.63rem;color:var(--dim)\" id=\"lastRefresh\">—</span>\n    <button class=\"hdr-btn\" onclick=\"loadAll()\">↺ Refresh</button>\n    <button class=\"hdr-btn\" onclick=\"window.location='/admin'\">📊 Admin</button>\n    <button class=\"hdr-btn\" onclick=\"window.location='/council'\">💬 Council</button>\n    <button class=\"hdr-btn\" style=\"background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.3);color:var(--ember)\" onclick=\"doLogout()\">Sign out</button>\n  </div>\n</div>\n\n<div class=\"container\">\n\n  <!-- EMERGENCY PANEL -->\n  <div class=\"emergency-panel\">\n    <div class=\"emergency-title\">🚨 Emergency Controls</div>\n    <div class=\"emergency-actions\">\n      <button class=\"btn btn-danger btn-lg\" onclick=\"restartOpenClaw()\">⚡ Restart OpenClaw Gateway</button>\n      <button class=\"btn btn-warn btn-lg\" onclick=\"runDoctor()\">🩺 Run OpenClaw Doctor</button>\n      <button class=\"btn btn-success btn-lg\" onclick=\"restartPM2('council-room')\">🔄 Restart Council Backend</button>\n      <button class=\"btn btn-primary btn-lg\" onclick=\"resetAllModels()\">🔁 Reset All Models to Default</button>\n    </div>\n  </div>\n\n  <!-- KPIs -->\n  <div class=\"section-title\">System Overview</div>\n  <div class=\"kpi-row\">\n    <div class=\"kpi\">\n      <div class=\"kpi-label\">CPU Load</div>\n      <div class=\"kpi-val\" id=\"kpiCpu\">—</div>\n      <div class=\"kpi-sub\" id=\"kpiCpuSub\"></div>\n    </div>\n    <div class=\"kpi\">\n      <div class=\"kpi-label\">Memory</div>\n      <div class=\"kpi-val\" id=\"kpiMem\">—</div>\n      <div class=\"gauge\"><div class=\"gauge-fill\" id=\"memGauge\" style=\"width:0%;background:var(--sage)\"></div></div>\n    </div>\n    <div class=\"kpi\">\n      <div class=\"kpi-label\">Disk</div>\n      <div class=\"kpi-val\" id=\"kpiDisk\">—</div>\n      <div class=\"gauge\"><div class=\"gauge-fill\" id=\"diskGauge\" style=\"width:0%;background:var(--indigo)\"></div></div>\n    </div>\n    <div class=\"kpi\">\n      <div class=\"kpi-label\">Uptime</div>\n      <div class=\"kpi-val\" id=\"kpiUptime\">—</div>\n      <div class=\"kpi-sub\" id=\"kpiUptimeSub\"></div>\n    </div>\n    <div class=\"kpi\">\n      <div class=\"kpi-label\">Processes</div>\n      <div class=\"kpi-val\" id=\"kpiProcs\">—</div>\n      <div class=\"kpi-sub\" id=\"kpiProcsSub\"></div>\n    </div>\n  </div>\n\n  <!-- PROCESSES -->\n  <div class=\"section-title\">Processes</div>\n  <div class=\"card\" id=\"processCard\">\n    <div class=\"card-h\">\n      <span>PM2 Process Health</span>\n      <button class=\"btn btn-primary\" onclick=\"loadSystem()\">↺</button>\n    </div>\n    <div id=\"procList\"><div style=\"color:var(--dim);font-size:.72rem\">Loading...</div></div>\n  </div>\n\n  <!-- AGENT MODEL MANAGEMENT -->\n  <div class=\"section-title\" style=\"display:flex;align-items:center;justify-content:space-between\">\n    <span>Agent Models</span>\n    <div class=\"mode-btns\">\n      <button class=\"mode-btn eco\" onclick=\"setGlobalMode('eco')\" title=\"All agents → Haiku 3.5 (cheapest)\">🌿 Eco</button>\n      <button class=\"mode-btn standard\" onclick=\"setGlobalMode('standard')\" title=\"Reset all to default Sonnet\">⚡ Standard</button>\n      <button class=\"mode-btn max\" onclick=\"setGlobalMode('max')\" title=\"Critical agents → Opus 4, others → Sonnet 4\">🔥 Max</button>\n    </div>\n  </div>\n  <div class=\"agent-grid\" id=\"agentGrid\">\n    <div style=\"color:var(--dim);font-size:.72rem;padding:1rem\">Loading agents...</div>\n  </div>\n\n  <!-- URIEL CHAT -->\n  <div class=\"section-title\">🔥 Uriel — IT Support Chat</div>\n  <div class=\"card\" id=\"chatCard\">\n    <div class=\"card-h\">\n      <span style=\"display:flex;align-items:center;gap:.4rem\">🔥 Uriel <span class=\"badge badge-online\">online</span></span>\n      <button class=\"btn btn-primary\" onclick=\"clearChat()\">🗑️ Clear</button>\n    </div>\n    <div class=\"chat-messages\" id=\"chatMessages\">\n      <div class=\"chat-msg bot\"><div class=\"chat-bubble bot\">Ready. What's broken?</div></div>\n    </div>\n    <div class=\"chat-input-row\">\n      <input type=\"text\" class=\"chat-input\" id=\"chatInput\" placeholder=\"Describe the issue or ask Uriel to fix something...\" \n        onkeydown=\"if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendChat()}\">\n      <button class=\"btn btn-primary chat-send\" id=\"chatSend\" onclick=\"sendChat()\">Send</button>\n    </div>\n  </div>\n\n  <!-- LOGS -->\n  <div class=\"section-title\">Activity Log</div>\n  <div class=\"card\">\n    <div class=\"card-h\">\n      <span>Recent Events</span>\n      <button class=\"btn btn-primary\" onclick=\"loadLogs()\">↺</button>\n    </div>\n    <div class=\"log-feed\" id=\"logFeed\">\n      <div class=\"log-line info\">Waiting for data...</div>\n    </div>\n  </div>\n\n  <!-- DOCTOR OUTPUT -->\n  <div class=\"section-title\">Diagnostics Output</div>\n  <div class=\"card\">\n    <div class=\"card-h\"><span>Last Doctor / Restart Result</span></div>\n    <div class=\"log-feed\" id=\"doctorOutput\" style=\"min-height:60px\">\n      <div class=\"log-line\" style=\"color:var(--dim)\">No diagnostics run yet this session.</div>\n    </div>\n  </div>\n\n</div>\n\n<!-- TOAST container -->\n<div id=\"toastBox\"></div>\n\n<script>\nconst API = '/council-api';\nlet TOKEN = localStorage.getItem('council_token');\nconst AGENTS_META = {};\nlet AVAILABLE_MODELS = [];\n\n// ── Auth (shared with MAGI Council) ──\nfunction headers(){ return {'Content-Type':'application/json','X-Council-Token':TOKEN}; }\nfunction doLogout(){ TOKEN=null; localStorage.removeItem('council_token'); window.location='/council'; }\n\n// Auto-auth: use existing MAGI token or silently get one\n(async()=>{\n  if(TOKEN){\n    try{\n      const r = await fetch(API+'/health',{headers:headers()});\n      if(r.ok){ loadAll(); return; }\n    }catch{}\n  }\n  // Silent auto-login\n  try{\n    const r = await fetch(API+'/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:'lucy',password:'lucy2026'})});\n    const d = await r.json();\n    if(d.token){ TOKEN=d.token; localStorage.setItem('council_token',TOKEN); loadAll(); return; }\n  }catch{}\n  // If everything fails, redirect to MAGI login\n  window.location='/council';\n})();\n\n// ── Toast ──\nfunction toast(msg, type='info'){\n  const t = document.createElement('div');\n  t.className = 'toast '+type;\n  t.textContent = msg;\n  document.getElementById('toastBox').appendChild(t);\n  setTimeout(()=>t.remove(), 4000);\n}\n\n// ── Load All ──\nasync function loadAll(){\n  document.getElementById('lastRefresh').textContent = new Date().toLocaleTimeString();\n  await Promise.all([loadSystem(), loadAgentModels(), loadLogs()]);\n}\n\n// ── System Health ──\nasync function loadSystem(){\n  try{\n    const r = await fetch(API+'/system',{headers:headers()});\n    const d = await r.json();\n    if(d.error){ toast('System fetch failed: '+d.error,'error'); return; }\n\n    // CPU\n    document.getElementById('kpiCpu').textContent = d.cpu?.load1?.toFixed(2) || '—';\n    document.getElementById('kpiCpuSub').textContent = `5m: ${d.cpu?.load5?.toFixed(2)} · 15m: ${d.cpu?.load15?.toFixed(2)}`;\n\n    // Memory\n    const memUsed = d.memory?.used||0, memTotal = d.memory?.total||1;\n    const memPct = Math.round(memUsed/memTotal*100);\n    document.getElementById('kpiMem').textContent = `${memPct}%`;\n    const memGauge = document.getElementById('memGauge');\n    memGauge.style.width = memPct+'%';\n    memGauge.style.background = memPct > 85 ? 'var(--ember)' : memPct > 70 ? 'var(--gold)' : 'var(--sage)';\n\n    // Disk\n    const diskUsed = d.disk?.used||0, diskTotal = d.disk?.total||1;\n    const diskPct = Math.round(diskUsed/diskTotal*100);\n    document.getElementById('kpiDisk').textContent = `${diskPct}%`;\n    const diskGauge = document.getElementById('diskGauge');\n    diskGauge.style.width = diskPct+'%';\n    diskGauge.style.background = diskPct > 90 ? 'var(--ember)' : diskPct > 75 ? 'var(--gold)' : 'var(--indigo)';\n\n    // Uptime\n    const upSec = d.uptime||0;\n    const days = Math.floor(upSec/86400), hrs = Math.floor((upSec%86400)/3600), mins = Math.floor((upSec%3600)/60);\n    document.getElementById('kpiUptime').textContent = days > 0 ? `${days}d ${hrs}h` : `${hrs}h ${mins}m`;\n    document.getElementById('kpiUptimeSub').textContent = 'server uptime';\n\n    // Processes\n    const procs = d.processes || [];\n    const online = procs.filter(p=>p.status==='online').length;\n    document.getElementById('kpiProcs').textContent = `${online}/${procs.length}`;\n    document.getElementById('kpiProcsSub').textContent = online===procs.length ? 'all healthy' : `${procs.length-online} down`;\n\n    // Connection status\n    const connDot = document.getElementById('connDot');\n    const connLabel = document.getElementById('connLabel');\n    if(online===procs.length){ connDot.className='status-dot ok'; connLabel.textContent='All Systems Go'; connLabel.style.color='var(--sage)'; }\n    else{ connDot.className='status-dot warn'; connLabel.textContent=`${procs.length-online} Issues`; connLabel.style.color='var(--gold)'; }\n\n    // Process list\n    const container = document.getElementById('procList');\n    if(procs.length===0){ container.innerHTML='<div style=\"color:var(--dim);font-size:.72rem\">No PM2 processes found</div>'; return; }\n    container.innerHTML = procs.map(p=>{\n      const isUp = p.status==='online';\n      const mem = p.memory ? Math.round(p.memory/1024/1024) : 0;\n      const up = p.uptime ? formatMs(p.uptime) : '—';\n      return `<div class=\"proc-row\">\n        <div class=\"proc-name\">${isUp?'🟢':'🔴'} ${p.name}</div>\n        <div class=\"proc-meta\">\n          <span>Status: <span class=\"badge ${isUp?'badge-online':'badge-offline'}\">${p.status}</span></span>\n          <span>PID: ${p.pid||'—'}</span>\n          <span>RAM: ${mem}MB</span>\n          <span>CPU: ${p.cpu||0}%</span>\n          <span>Restarts: ${p.restarts||0}</span>\n          <span>Up: ${up}</span>\n        </div>\n        <button class=\"btn btn-primary\" onclick=\"restartPM2('${p.name}')\" style=\"flex-shrink:0\">↺ Restart</button>\n      </div>`;\n    }).join('');\n  }catch(e){ toast('Failed to load system: '+e.message,'error'); }\n}\n\nfunction formatMs(ms){\n  const s=Math.floor(ms/1000), m=Math.floor(s/60), h=Math.floor(m/60), d=Math.floor(h/24);\n  if(d>0) return `${d}d ${h%24}h`;\n  if(h>0) return `${h}h ${m%60}m`;\n  return `${m}m`;\n}\n\n// ── Agent Models ──\nasync function loadAgentModels(){\n  try{\n    const r = await fetch(API+'/agent-models',{headers:headers()});\n    const d = await r.json();\n    AVAILABLE_MODELS = d.available || [];\n    const models = d.models || {};\n    const grid = document.getElementById('agentGrid');\n\n    // Fetch agent metadata from /health\n    let agents = {};\n    try{\n      const hr = await fetch(API+'/health',{headers:headers()});\n      const hd = await hr.json();\n      agents = hd.agents || {};\n    }catch{}\n\n    const AGENT_INFO = {\n      rafael:{emoji:'🧭',role:'The Guide'},uriel:{emoji:'🔥',role:\"God's Fire\"},\n      michael:{emoji:'🛡️',role:'Wise Advisor'},gabriel:{emoji:'📣',role:'The Voice'},\n      raguel:{emoji:'🤝',role:'The Friend'},samael:{emoji:'⚖️',role:'The Prosecutor'},\n      sarael:{emoji:'🔮',role:'The Scribe'},azrael:{emoji:'💸',role:'The Auditor'},\n      remiel:{emoji:'🛡️',role:'The Sentry'},zadkiel:{emoji:'🛠️',role:'The Builder'},\n      metis:{emoji:'📚',role:'The Librarian'},sophia:{emoji:'🎓',role:'The Scholar'},\n      lucy_d:{emoji:'⚡',role:'The Twin'}\n    };\n\n    grid.innerHTML = Object.entries(models).map(([id, info])=>{\n      const meta = AGENT_INFO[id]||{emoji:'🤖',role:'Agent'};\n      const model = info.model || 'sonnet-4';\n      const options = AVAILABLE_MODELS.map(m=>\n        `<option value=\"${m}\" ${m===model?'selected':''}>${m}</option>`\n      ).join('');\n      return `<div class=\"agent-card\" id=\"agent-${id}\">\n        <div class=\"agent-top\">\n          <div class=\"agent-name\">${meta.emoji} ${id.charAt(0).toUpperCase()+id.slice(1)}</div>\n          <span class=\"badge badge-model\">${model}</span>\n        </div>\n        <div class=\"agent-role\">${meta.role}</div>\n        <div class=\"agent-model-row\">\n          <select id=\"model-${id}\" onchange=\"changeModel('${id}',this.value)\">\n            ${options}\n          </select>\n        </div>\n      </div>`;\n    }).join('');\n  }catch(e){ toast('Failed to load models: '+e.message,'error'); }\n}\n\nasync function changeModel(agentId, model){\n  try{\n    const r = await fetch(API+'/agent-models',{method:'POST',headers:headers(),body:JSON.stringify({agentId,model})});\n    const d = await r.json();\n    if(d.ok){ toast(`${agentId} → ${model}`,'success'); loadAgentModels(); }\n    else toast(d.error||'Failed','error');\n  }catch(e){ toast('Error: '+e.message,'error'); }\n}\n\nasync function setGlobalMode(mode){\n  if(!confirm(`Switch ALL agents to ${mode.toUpperCase()} mode?`)) return;\n  try{\n    const r = await fetch(API+'/agent-models/global',{method:'POST',headers:headers(),body:JSON.stringify({mode})});\n    const d = await r.json();\n    if(d.ok){ toast(`Global mode: ${mode.toUpperCase()} applied`,'success'); loadAgentModels(); }\n    else toast(d.error||'Failed','error');\n  }catch(e){ toast('Error: '+e.message,'error'); }\n}\n\nasync function resetAllModels(){\n  await setGlobalMode('standard');\n}\n\n// ── Emergency Actions ──\nasync function restartOpenClaw(){\n  if(!confirm('⚡ Restart OpenClaw Gateway? Michael will briefly go offline.')) return;\n  try{\n    const r = await fetch(API+'/system/openclaw-restart',{method:'POST',headers:headers()});\n    const d = await r.json();\n    const out = document.getElementById('doctorOutput');\n    out.innerHTML = `<div class=\"log-line ok\">✅ ${d.message||'Restart triggered'}</div><div class=\"log-line info\">Timestamp: ${new Date(d.timestamp).toLocaleString()}</div><div class=\"log-line warn\">⏳ Michael will be back in ~15 seconds...</div>`;\n    toast('OpenClaw restart triggered','success');\n    // Auto-refresh after 20s\n    setTimeout(loadAll, 20000);\n  }catch(e){ toast('Restart failed: '+e.message,'error'); }\n}\n\nasync function runDoctor(){\n  toast('Running diagnostics...','info');\n  try{\n    const r = await fetch(API+'/system/openclaw-doctor',{method:'POST',headers:headers()});\n    const d = await r.json();\n    const out = document.getElementById('doctorOutput');\n    if(d.ok){\n      const lines = (d.output||'No output').split('\\n').map(l=>{\n        const cls = l.includes('✓')||l.includes('ok')||l.includes('pass') ? 'ok' :\n                    l.includes('✗')||l.includes('error')||l.includes('fail') ? 'err' :\n                    l.includes('warn') ? 'warn' : 'info';\n        return `<div class=\"log-line ${cls}\">${escHtml(l)}</div>`;\n      }).join('');\n      out.innerHTML = lines;\n      toast('Doctor completed','success');\n    } else {\n      out.innerHTML = `<div class=\"log-line err\">❌ ${escHtml(d.error||'Unknown error')}</div><div class=\"log-line\">${escHtml(d.output||'')}</div>`;\n      toast('Doctor failed','error');\n    }\n  }catch(e){ toast('Doctor failed: '+e.message,'error'); }\n}\n\nasync function restartPM2(name){\n  if(!confirm(`Restart PM2 process: ${name}?`)) return;\n  toast(`Restarting ${name}...`,'info');\n  try{\n    // Use agent-exec endpoint for pm2 restart\n    const r = await fetch(API+'/agent-exec',{method:'POST',headers:headers(),body:JSON.stringify({command:`pm2 restart ${name}`,timeout:10000})});\n    const d = await r.json();\n    if(d.error) toast(`Failed: ${d.error}`,'error');\n    else { toast(`${name} restarted`,'success'); setTimeout(loadSystem,3000); }\n  }catch(e){ toast('Failed: '+e.message,'error'); }\n}\n\n// ── Logs ──\nasync function loadLogs(){\n  try{\n    const r = await fetch(API+'/events?limit=30',{headers:headers()});\n    const d = await r.json();\n    const events = Array.isArray(d) ? d : d.events || [];\n    const feed = document.getElementById('logFeed');\n    if(events.length===0){ feed.innerHTML='<div class=\"log-line\" style=\"color:var(--dim)\">No recent events</div>'; return; }\n    feed.innerHTML = events.slice(-40).reverse().map(ev=>{\n      const t = ev.serverTs ? new Date(ev.serverTs).toLocaleTimeString() : '';\n      const agent = ev.agentId ? `[${ev.agentId}]` : '';\n      const type = ev.type || 'event';\n      const cls = type==='error'?'err':type==='response'?'ok':type==='thinking'?'warn':'info';\n      const msg = ev.response ? ev.response.substring(0,120)+'...' : ev.type || '';\n      return `<div class=\"log-line ${cls}\"><span style=\"color:var(--dim)\">${t}</span> ${agent} <span style=\"color:var(--ash)\">${type}</span> ${escHtml(msg)}</div>`;\n    }).join('');\n    feed.scrollTop = 0;\n  }catch(e){ \n    document.getElementById('logFeed').innerHTML=`<div class=\"log-line err\">Failed to load: ${escHtml(e.message)}</div>`;\n  }\n}\n\nfunction escHtml(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }\n\n// ── Uriel Chat ──\nconst chatSessionId = 'it-support-' + Date.now();\n\nasync function sendChat(){\n  const input = document.getElementById('chatInput');\n  const msg = input.value.trim();\n  if(!msg) return;\n  input.value = '';\n\n  // Add user message\n  addChatMsg(msg, 'user');\n  \n  // Show typing\n  const typing = document.createElement('div');\n  typing.className = 'chat-msg bot';\n  typing.id = 'typing';\n  typing.innerHTML = `<div class=\"chat-typing\"><div class=\"dot\"></div><div class=\"dot\"></div><div class=\"dot\"></div> Uriel is thinking...</div>`;\n  document.getElementById('chatMessages').appendChild(typing);\n  scrollChat();\n\n  // Disable send\n  document.getElementById('chatSend').disabled = true;\n\n  try{\n    const r = await fetch(API+'/it-support/chat',{\n      method:'POST', headers:headers(),\n      body:JSON.stringify({message:msg, sessionId:chatSessionId})\n    });\n    const d = await r.json();\n    document.getElementById('typing')?.remove();\n    if(d.ok){\n      addChatMsg(d.response, 'bot');\n    } else {\n      addChatMsg('Error: '+(d.error||'Unknown error'), 'bot');\n    }\n  }catch(e){\n    document.getElementById('typing')?.remove();\n    addChatMsg('Connection error: '+e.message, 'bot');\n  }\n  document.getElementById('chatSend').disabled = false;\n  document.getElementById('chatInput').focus();\n}\n\nfunction addChatMsg(text, who){\n  const container = document.getElementById('chatMessages');\n  const div = document.createElement('div');\n  div.className = 'chat-msg ' + who;\n  const bubble = document.createElement('div');\n  bubble.className = 'chat-bubble ' + who;\n  // Basic markdown rendering\n  bubble.innerHTML = renderMd(text);\n  div.appendChild(bubble);\n  container.appendChild(div);\n  scrollChat();\n}\n\nfunction scrollChat(){\n  const c = document.getElementById('chatMessages');\n  c.scrollTop = c.scrollHeight;\n}\n\nfunction renderMd(text){\n  // Code blocks\n  text = text.replace(/```(\\w*)\\n([\\s\\S]*?)```/g, '<pre><code>$2</code></pre>');\n  // Inline code\n  text = text.replace(/`([^`]+)`/g, '<code>$1</code>');\n  // Bold\n  text = text.replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>');\n  // Escape html (but preserve our tags)\n  return text;\n}\n\nasync function clearChat(){\n  try{\n    await fetch(API+'/it-support/clear',{method:'POST',headers:headers(),body:JSON.stringify({sessionId:chatSessionId})});\n  }catch{}\n  document.getElementById('chatMessages').innerHTML = '<div class=\"chat-msg bot\"><div class=\"chat-bubble bot\">Chat cleared. What\\'s next?</div></div>';\n  toast('Chat cleared','info');\n}\n\n// Auto-refresh every 30s\nsetInterval(()=>{ if(TOKEN) loadAll(); }, 30000);\n</script>\n</body>\n</html>\n"}],"isError":false,"timestamp":1775367078831}}
