{"type":"message","id":"a33c04b8","parentId":"7458a6ea","timestamp":"2026-04-05T09:30:22.105Z","message":{"role":"toolResult","toolCallId":"tooluse_y5BZDHNJE13SFdkgb4frmX","toolName":"read","content":[{"type":"text","text":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<link rel=\"manifest\" href=\"/manifest.json\"><meta name=\"theme-color\" content=\"#060a14\">\n<title>MAGI — Login</title>\n<link rel=\"stylesheet\" href=\"/shared/core.css\">\n<link rel=\"stylesheet\" href=\"/shared/components.css\">\n<style>\nbody { display: flex; align-items: center; justify-content: center; }\n.login-box {\n  width: 360px; background: var(--bg-surface); border: 1px solid var(--glass-border);\n  border-radius: 20px; padding: 40px 32px; backdrop-filter: blur(16px);\n  -webkit-backdrop-filter: blur(16px); position: relative; z-index: 1;\n  box-shadow: 0 4px 40px rgba(0,0,0,0.3);\n}\n.logo { text-align: center; margin-bottom: 28px; }\n.logo span {\n  font-size: 28px; font-weight: 700;\n  background: linear-gradient(135deg, var(--color-accent), #22d3ee);\n  -webkit-background-clip: text; -webkit-text-fill-color: transparent;\n}\n.logo p { font-size: 12px; color: var(--text-tertiary); margin-top: 4px; letter-spacing: 1px; text-transform: uppercase; }\n.field { margin-bottom: 16px; }\n.field label { display: block; font-size: 10px; text-transform: uppercase; letter-spacing: .5px; color: var(--text-tertiary); margin-bottom: 6px; font-weight: 500; }\n.field .input-wrap { position: relative; }\n.field .input-wrap input { width: 100%; padding-right: 40px; }\n.pwd-toggle {\n  position: absolute; right: 10px; top: 50%; transform: translateY(-50%);\n  background: none; border: none; color: var(--text-tertiary); cursor: pointer;\n  font-size: 14px; padding: 4px; line-height: 1;\n}\n.pwd-toggle:hover { color: var(--text-secondary); }\n.login-btn {\n  width: 100%; padding: 11px; border: none; border-radius: var(--radius-md);\n  background: linear-gradient(135deg, rgba(52,211,153,0.2), rgba(34,211,238,0.15));\n  color: var(--color-accent); font-size: 14px; font-weight: 600;\n  cursor: pointer; font-family: var(--font-sans); transition: all 0.2s; margin-top: 8px;\n  display: flex; align-items: center; justify-content: center; gap: 8px;\n}\n.login-btn:hover { background: linear-gradient(135deg, rgba(52,211,153,0.3), rgba(34,211,238,0.25)); }\n.login-btn:disabled { opacity: 0.4; cursor: not-allowed; }\n.error-msg { color: var(--color-danger); font-size: 12px; text-align: center; margin-top: 12px; min-height: 18px; }\n.version { text-align: center; font-size: 10px; color: var(--text-tertiary); margin-top: 20px; font-family: var(--font-mono); }\n@media (max-width: 400px) { .login-box { width: 92vw; padding: 32px 20px; } }\n</style>\n</head>\n<body>\n<div class=\"login-box\">\n  <div class=\"logo\"><span>✦ MAGI</span><p>Command Center</p></div>\n  <form id=\"loginForm\">\n    <div class=\"field\">\n      <label>Username</label>\n      <input class=\"input\" id=\"user\" autocomplete=\"username\" autofocus>\n    </div>\n    <div class=\"field\">\n      <label>Password</label>\n      <div class=\"input-wrap\">\n        <input class=\"input\" id=\"pass\" type=\"password\" autocomplete=\"current-password\">\n        <button type=\"button\" class=\"pwd-toggle\" id=\"pwdToggle\" aria-label=\"Toggle password visibility\">👁</button>\n      </div>\n    </div>\n    <button class=\"login-btn\" type=\"submit\" id=\"loginBtn\">Sign In</button>\n    <div class=\"error-msg\" id=\"err\"></div>\n  </form>\n  <div class=\"version\">v2.0 · Multi-Agent Intelligence</div>\n</div>\n\n<script type=\"module\">\nimport { api, toast } from '/shared/core.js';\n\n// If already logged in, redirect\nconst token = localStorage.getItem('magi_token');\nif (token) {\n  try {\n    const res = await fetch('/api/auth/me', { headers: { Authorization: 'Bearer ' + token } });\n    const d = await res.json();\n    if (d.ok) window.location.href = '/dashboard/';\n  } catch { /* ignore */ }\n}\n\n// Password visibility toggle\nconst passInput = document.getElementById('pass');\nconst pwdToggle = document.getElementById('pwdToggle');\npwdToggle.addEventListener('click', () => {\n  const isPassword = passInput.type === 'password';\n  passInput.type = isPassword ? 'text' : 'password';\n  pwdToggle.textContent = isPassword ? '🙈' : '👁';\n});\n\n// Login handler\nconst form = document.getElementById('loginForm');\nconst loginBtn = document.getElementById('loginBtn');\nconst errEl = document.getElementById('err');\n\nform.addEventListener('submit', async (e) => {\n  e.preventDefault();\n  errEl.textContent = '';\n  loginBtn.disabled = true;\n  loginBtn.innerHTML = '<span class=\"spinner spinner-sm\"></span> Signing in...';\n\n  try {\n    const res = await fetch('/api/auth/login', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({\n        username: document.getElementById('user').value,\n        password: document.getElementById('pass').value\n      })\n    });\n    const d = await res.json();\n    if (d.ok) {\n      localStorage.setItem('magi_token', d.token);\n      localStorage.setItem('magi_user', JSON.stringify(d.user));\n      window.location.href = '/dashboard/';\n    } else {\n      errEl.textContent = d.error || 'Invalid credentials';\n    }\n  } catch {\n    errEl.textContent = 'Connection error — check your network';\n  }\n\n  loginBtn.disabled = false;\n  loginBtn.innerHTML = 'Sign In';\n});\n</script>\n</body>\n</html>\n"}],"isError":false,"timestamp":1775381422085}}
