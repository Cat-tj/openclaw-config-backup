{"type":"message","id":"f932af29","parentId":"24e3bccd","timestamp":"2026-04-05T05:32:16.403Z","message":{"role":"toolResult","toolCallId":"tooluse_ZiM2t1EQt2DGgBCIxsQ8dF","toolName":"read","content":[{"type":"text","text":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>IT Support — MAGI</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&family=JetBrains+Mono:wght@400;500&display=swap\" rel=\"stylesheet\">\n<style>\n*{box-sizing:border-box;margin:0;padding:0}\n:root{\n  --bg:#07080f;--s1:#0d0f1a;--s2:#111320;--b1:rgba(255,255,255,.07);\n  --ivory:#c9d8e8;--ash:#7a9ab8;--dim:#3a5a78;\n  --indigo:#6366f1;--sage:#10b981;--ember:#ef4444;--gold:#f59e0b;\n  --violet:#8b5cf6;--sky:#38bdf8;--met:#06b6d4;--pink:#ec4899;\n}\nbody{background:var(--bg);color:var(--ivory);font-family:'Inter',sans-serif;min-height:100vh}\n\n/* ── Header ── */\n.header{background:rgba(6,6,8,.92);border-bottom:1px solid var(--b1);backdrop-filter:blur(20px);\n  padding:.75rem 1.5rem;display:flex;align-items:center;gap:.75rem;position:sticky;top:0;z-index:100}\n\n[636 more lines in file. Use offset=21 to continue.]"}],"isError":false,"timestamp":1775367136392}}
{"type":"message","id":"7dfeda02","parentId":"f932af29","timestamp":"2026-04-05T05:33:16.828Z","message":{"role":"assistant","content":[{"type":"text","text":"I have the full file already from earlier. Let me build the code-blocks integration directly."},{"type":"toolCall","id":"tooluse_bjaiE5v6zdqRwgoZdmNQsO","name":"edit","arguments":{"file":"~/council-room/frontend/it-support.html","edits":[{"oldText":"<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&family=JetBrains+Mono:wght@400;500&display=swap\" rel=\"stylesheet\">","newText":"<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&family=JetBrains+Mono:wght@400;500&display=swap\" rel=\"stylesheet\">\n<script type=\"module\">\nimport { highlight } from 'https://cdn.jsdelivr.net/npm/sugar-high@0.7.2/+esm';\nwindow.sugarHighlight = highlight;\n</script>"},{"oldText":"/* ── Responsive ── */\n@media(max-width:640px){\n  .header{padding:.6rem .75rem;flex-wrap:wrap;gap:.4rem}\n  .container{padding:.75rem}\n  .emergency-actions{flex-direction:column}\n  .kpi-row{grid-template-columns:1fr 1fr}\n  .agent-grid{grid-template-columns:1fr}\n}\n</style>","newText":"/* ── Code Blocks ── */\n.cb{position:relative;background:#080a14;border:1px solid var(--b1);border-radius:12px;\n  margin:.5rem 0;overflow:hidden;transition:border-color .2s,box-shadow .2s}\n.cb:hover{border-color:rgba(99,102,241,.25);box-shadow:0 0 20px rgba(99,102,241,.06)}\n.cb-header{display:flex;align-items:center;justify-content:space-between;padding:.4rem .75rem;\n  background:rgba(255,255,255,.03);border-bottom:1px solid rgba(255,255,255,.05);\n  font-size:.65rem;font-family:'JetBrains Mono',monospace}\n.cb-lang{color:var(--ash);font-weight:500;display:flex;align-items:center;gap:.35rem}\n.cb-lang-pill{background:rgba(99,102,241,.15);color:#a5b4fc;padding:.1rem .45rem;border-radius:6px;\n  font-size:.58rem;font-weight:600;border:1px solid rgba(99,102,241,.2)}\n.cb-filename{color:var(--ivory);font-weight:600;font-size:.68rem}\n.cb-copy{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:6px;\n  color:var(--ash);padding:.2rem .5rem;font-size:.6rem;cursor:pointer;font-family:'Inter',sans-serif;\n  transition:.2s;display:flex;align-items:center;gap:.25rem;opacity:0}\n.cb:hover .cb-copy{opacity:1}\n.cb-copy:hover{background:rgba(99,102,241,.2);border-color:rgba(99,102,241,.3);color:#a5b4fc}\n.cb-copy.copied{background:rgba(16,185,129,.15);border-color:rgba(16,185,129,.3);color:var(--sage)}\n.cb-body{display:flex;overflow:hidden}\n.cb-lines{padding:.6rem .5rem;text-align:right;color:var(--dim);font-size:.65rem;line-height:1.7;\n  font-family:'JetBrains Mono',monospace;user-select:none;border-right:1px solid rgba(255,255,255,.05);\n  min-width:2.5rem;flex-shrink:0}\n.cb-code{flex:1;overflow-x:auto;padding:.6rem .85rem;font-size:.7rem;line-height:1.7;\n  font-family:'JetBrains Mono',monospace;color:var(--ivory);white-space:pre;tab-size:2}\n.cb-code::-webkit-scrollbar{height:4px}\n.cb-code::-webkit-scrollbar-thumb{background:rgba(99,102,241,.25);border-radius:3px}\n/* Sugar-High token colors */\n.cb-code .sh__line{display:block}\n.cb-code [class*=\"sh__\"],.cb-code span{}\n\n/* ── Quick Commands ── */\n.qc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:.6rem}\n.qc-card{background:var(--s1);border:1px solid var(--b1);border-radius:12px;padding:.85rem;transition:.2s}\n.qc-card:hover{border-color:rgba(99,102,241,.2)}\n.qc-title{font-size:.72rem;font-weight:700;margin-bottom:.6rem;display:flex;align-items:center;gap:.4rem}\n.qc-cmd{position:relative;display:flex;align-items:center;background:#080a14;border:1px solid var(--b1);\n  border-radius:8px;padding:.35rem .65rem;margin-bottom:.4rem;font-family:'JetBrains Mono',monospace;\n  font-size:.68rem;color:var(--ivory);cursor:pointer;transition:.2s;gap:.5rem}\n.qc-cmd:last-child{margin-bottom:0}\n.qc-cmd:hover{border-color:rgba(99,102,241,.3);background:rgba(99,102,241,.06)}\n.qc-cmd .qc-prompt{color:var(--dim);user-select:none;flex-shrink:0}\n.qc-cmd .qc-text{flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}\n.qc-cmd .qc-cp{position:absolute;right:.5rem;opacity:0;transition:.15s;font-size:.58rem;\n  color:var(--ash);background:rgba(255,255,255,.08);padding:.15rem .4rem;border-radius:5px}\n.qc-cmd:hover .qc-cp{opacity:1}\n.qc-cmd.qc-copied{border-color:rgba(16,185,129,.4)}\n.qc-cmd.qc-copied .qc-cp{opacity:1;color:var(--sage);background:rgba(16,185,129,.15)}\n\n/* ── Responsive ── */\n@media(max-width:640px){\n  .header{padding:.6rem .75rem;flex-wrap:wrap;gap:.4rem}\n  .container{padding:.75rem}\n  .emergency-actions{flex-direction:column}\n  .kpi-row{grid-template-columns:1fr 1fr}\n  .agent-grid{grid-template-columns:1fr}\n  .qc-grid{grid-template-columns:1fr}\n}\n</style>"},{"oldText":"  <!-- KPIs -->\n  <div class=\"section-title\">System Overview</div>","newText":"  <!-- QUICK COMMANDS -->\n  <div class=\"section-title\">Quick Commands</div>\n  <div class=\"qc-grid\" id=\"qcGrid\"></div>\n\n  <!-- KPIs -->\n  <div class=\"section-title\">System Overview</div>"},{"oldText":"function renderMd(text){\n  // Code blocks\n  text = text.replace(/```(\\w*)\\n([\\s\\S]*?)```/g, '<pre><code>$2</code></pre>');\n  // Inline code\n  text = text.replace(/`([^`]+)`/g, '<code>$1</code>');\n  // Bold\n  text = text.replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>');\n  // Escape html (but preserve our tags)\n  return text;\n}","newText":"function renderMd(text){\n  // Code blocks → CodeBlock component\n  text = text.replace(/```(\\w*)\\n([\\s\\S]*?)```/g, (_, lang, code) => {\n    const id = 'cb-' + Math.random().toString(36).slice(2,8);\n    setTimeout(() => renderCodeBlock(id, code.trim(), lang || 'text'), 0);\n    return `<div id=\"${id}\" class=\"cb-placeholder\" style=\"min-height:40px\"></div>`;\n  });\n  // Inline code\n  text = text.replace(/`([^`]+)`/g, '<code>$1</code>');\n  // Bold\n  text = text.replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>');\n  return text;\n}\n\n// ── Code Block Component ──\nfunction createCodeBlock(code, lang, opts={}){\n  const showLines = opts.lines !== false;\n  const filename = opts.filename || '';\n  const lines = code.split('\\n');\n  const lineNums = lines.map((_,i) => i+1).join('\\n');\n  const langLabel = lang || 'text';\n  const cbId = 'cb-' + Math.random().toString(36).slice(2,8);\n\n  let highlighted = escHtml(code);\n  if(window.sugarHighlight){\n    try{ highlighted = window.sugarHighlight(code); }catch(e){}\n  }\n\n  return `<div class=\"cb\" id=\"${cbId}\">\n    <div class=\"cb-header\">\n      <div class=\"cb-lang\">${filename ? `<span class=\"cb-filename\">${escHtml(filename)}</span>` : ''}<span class=\"cb-lang-pill\">${escHtml(langLabel)}</span></div>\n      <button class=\"cb-copy\" onclick=\"copyCode(this,'${cbId}')\" style=\"opacity:.6\">📋 Copy</button>\n    </div>\n    <div class=\"cb-body\">\n      ${showLines ? `<div class=\"cb-lines\">${lineNums}</div>` : ''}\n      <div class=\"cb-code\" data-raw=\"${btoa(unescape(encodeURIComponent(code)))}\">${highlighted}</div>\n    </div>\n  </div>`;\n}\n\nfunction renderCodeBlock(id, code, lang){\n  const el = document.getElementById(id);\n  if(!el) return;\n  el.outerHTML = createCodeBlock(code, lang);\n}\n\nfunction copyCode(btn, cbId){\n  const codeEl = document.querySelector(`#${cbId} .cb-code`);\n  if(!codeEl) return;\n  let raw;\n  try{ raw = decodeURIComponent(escape(atob(codeEl.dataset.raw))); }catch{ raw = codeEl.textContent; }\n  navigator.clipboard.writeText(raw).then(()=>{\n    btn.textContent = '✅ Copied!';\n    btn.classList.add('copied');\n    setTimeout(()=>{ btn.textContent = '📋 Copy'; btn.classList.remove('copied'); }, 2000);\n  });\n}\n\nfunction copyQcCmd(el, cmd){\n  navigator.clipboard.writeText(cmd).then(()=>{\n    el.classList.add('qc-copied');\n    el.querySelector('.qc-cp').textContent = '✅';\n    setTimeout(()=>{ el.classList.remove('qc-copied'); el.querySelector('.qc-cp').textContent = 'copy'; }, 1500);\n  });\n}\n\n// ── Quick Commands Data ──\nconst QC_COMMANDS = [\n  { title: '⚡ OpenClaw', icon: '', cmds: [\n    'openclaw gateway restart',\n    'openclaw gateway status',\n    'openclaw doctor',\n    'openclaw status'\n  ]},\n  { title: '🔄 PM2', icon: '', cmds: [\n    'pm2 restart council-room',\n    'pm2 logs council-room --lines 50',\n    'pm2 list',\n    'pm2 monit'\n  ]},\n  { title: '🖥️ System', icon: '', cmds: [\n    'free -m',\n    'df -h',\n    'top -bn1 | head -20',\n    'journalctl -u pm2-openclaw --since \"1h ago\"'\n  ]},\n  { title: '🐳 Docker', icon: '', cmds: [\n    'docker ps',\n    'docker stats --no-stream',\n    'docker logs couchdb --tail 50',\n    'docker system df'\n  ]}\n];\n\nfunction renderQuickCommands(){\n  const grid = document.getElementById('qcGrid');\n  grid.innerHTML = QC_COMMANDS.map(cat => `\n    <div class=\"qc-card\">\n      <div class=\"qc-title\">${cat.title}</div>\n      ${cat.cmds.map(cmd => `\n        <div class=\"qc-cmd\" onclick=\"copyQcCmd(this,'${escHtml(cmd)}')\">\n          <span class=\"qc-prompt\">$</span>\n          <span class=\"qc-text\">${escHtml(cmd)}</span>\n          <span class=\"qc-cp\">copy</span>\n        </div>\n      `).join('')}\n    </div>\n  `).join('');\n}\nrenderQuickCommands();"},{"oldText":"    const out = document.getElementById('doctorOutput');\n    if(d.ok){\n      const lines = (d.output||'No output').split('\\n').map(l=>{\n        const cls = l.includes('✓')||l.includes('ok')||l.includes('pass') ? 'ok' :\n                    l.includes('✗')||l.includes('error')||l.includes('fail') ? 'err' :\n                    l.includes('warn') ? 'warn' : 'info';\n        return `<div class=\"log-line ${cls}\">${escHtml(l)}</div>`;\n      }).join('');\n      out.innerHTML = lines;\n      toast('Doctor completed','success');\n    } else {\n      out.innerHTML = `<div class=\"log-line err\">❌ ${escHtml(d.error||'Unknown error')}</div><div class=\"log-line\">${escHtml(d.output||'')}</div>`;\n      toast('Doctor failed','error');\n    }","newText":"    const out = document.getElementById('doctorOutput');\n    if(d.ok){\n      const rawOutput = d.output || 'No output';\n      out.innerHTML = createCodeBlock(rawOutput, 'bash', {filename:'openclaw doctor', lines:true});\n      toast('Doctor completed','success');\n    } else {\n      const errOut = `❌ Error: ${d.error||'Unknown error'}\\n${d.output||''}`;\n      out.innerHTML = createCodeBlock(errOut.trim(), 'bash', {filename:'doctor — failed', lines:false});\n      toast('Doctor failed','error');\n    }"},{"oldText":"    if(d.error){ toast('System fetch failed: '+d.error,'error'); return; }","newText":"    if(d.error){ toast('System fetch failed: '+d.error,'error'); return; }\n    // Wrap restart output in code blocks\n    window._lastSystemData = d;"}]}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-opus-4-6-v1","usage":{"input":1,"output":4150,"cacheRead":78427,"cacheWrite":569,"totalTokens":83147,"cost":{"input":0.000005,"output":0.10375000000000001,"cacheRead":0.0392135,"cacheWrite":0.0035562500000000004,"total":0.14652475}},"stopReason":"toolUse","timestamp":1775367136408}}
