{"type":"message","id":"0af1274c","parentId":"34f70bae","timestamp":"2026-04-05T09:49:02.469Z","message":{"role":"toolResult","toolCallId":"tooluse_OBu841kHlh0i02e9EzxssT","toolName":"read","content":[{"type":"text","text":"  saveSession(sess)\n  return { ok: true }\n})\n\napp.post('/api/sessions/:id/fork', async (req) => {\n  const src = loadSession(req.params.id)\n  if (!src) return { ok: false, error: 'Not found' }\n  const id = 'sess_' + Date.now() + '_' + Math.random().toString(36).slice(2, 6)\n  const forked = { ...src, id, title: '🌀 Fork: ' + src.title, messages: [...src.messages], createdAt: Date.now(), updatedAt: Date.now() }\n  saveSession(forked)\n  return { ok: true, session: { id: forked.id, title: forked.title, mode: forked.mode, agentId: forked.agentId, createdAt: forked.createdAt, updatedAt: forked.updatedAt, messageCount: forked.messages.length } }\n})\n\n// ── REST: save to Obsidian ──────────────────────────────\nconst OBSIDIAN_VAULT = join('/home/openclaw/livesync-bridge/vault')\nconst OBSIDIAN_SAVED = join(OBSIDIAN_VAULT, '03_Council_Records', 'Saved_Chats')\nif (!existsSync(OBSIDIAN_SAVED)) mkdirSync(OBSIDIAN_SAVED, { recursive: true })\n\napp.post('/api/obsidian/save', async (req) => {\n  const { title, agent, text, tags } = req.body || {}\n  if (!text) return { ok: false, error: 'No text to save' }\n  const now = new Date()\n  const dateStr = now.toISOString().slice(0, 10)\n  const timeStr = now.toTimeString().slice(0, 5)\n  const slug = (title || 'untitled').replace(/[^a-zA-Z0-9\\s-]/g, '').replace(/\\s+/g, '-').slice(0, 60)\n  const filename = dateStr + '_' + slug + '.md'\n  const tagLine = tags?.length ? '\\ntags: [' + tags.map(t => '\"' + t + '\"').join(', ') + ']' : ''\n  const content = `---\ntitle: \"${(title || 'Saved Chat').replace(/\"/g, '\\\\\"')}\"\nagent: \"${agent || 'unknown'}\"\n\n[1750 more lines in file. Use offset=616 to continue.]"}],"isError":false,"timestamp":1775382542441}}
