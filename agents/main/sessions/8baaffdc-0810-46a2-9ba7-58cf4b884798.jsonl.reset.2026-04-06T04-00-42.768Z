{"type":"message","id":"7d9a2fda","parentId":"c550cbc3","timestamp":"2026-04-05T16:25:45.302Z","message":{"role":"toolResult","toolCallId":"tooluse_K7IaKEtepYO7kYgHTPlAox","toolName":"exec","content":[{"type":"text","text":"function switchTab2(tabId) {\n    // Hide all tab-panes\n    document.querySelectorAll('.tab-pane').forEach(function(p) { p.classList.remove('active'); });\n    // Hide all legacy tab-content\n    document.querySelectorAll('.tab-content').forEach(function(t) { t.style.display = 'none'; });\n    // Update button states\n    document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });\n    var btn = document.querySelector('.tab-btn[data-tab=\"' + tabId + '\"]');\n    if (btn) btn.classList.add('active');\n    \n    // Show the mapped legacy tab OR the pane\n    var legacyId = TAB_MAP[tabId];\n    if (legacyId) {\n      var legacyTab = document.getElementById(legacyId);\n      if (legacyTab) { legacyTab.style.display = 'block'; }\n    } else {\n      var pane = document.getElementById('tab-' + tabId + '-pane');\n      if (pane) pane.classList.add('active');\n    }\n  }\n\n  // For More tab's feature buttons — show a specific legacy tab\n  window.showTab = function(tabId) {\n    // Hide all tab-panes and legacy tabs\n    document.querySelectorAll('.tab-pane').forEach(function(p) { p.classList.remove('active'); });\n    document.querySelectorAll('.tab-content').forEach(function(t) { t.style.display = 'none'; });\n    // Show the requested legacy tab\n    var tab = document.getElementById(tabId);\n    if (tab) tab.style.display = 'block';\n  };"}],"details":{"status":"completed","exitCode":0,"durationMs":38,"aggregated":"function switchTab2(tabId) {\n    // Hide all tab-panes\n    document.querySelectorAll('.tab-pane').forEach(function(p) { p.classList.remove('active'); });\n    // Hide all legacy tab-content\n    document.querySelectorAll('.tab-content').forEach(function(t) { t.style.display = 'none'; });\n    // Update button states\n    document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });\n    var btn = document.querySelector('.tab-btn[data-tab=\"' + tabId + '\"]');\n    if (btn) btn.classList.add('active');\n    \n    // Show the mapped legacy tab OR the pane\n    var legacyId = TAB_MAP[tabId];\n    if (legacyId) {\n      var legacyTab = document.getElementById(legacyId);\n      if (legacyTab) { legacyTab.style.display = 'block'; }\n    } else {\n      var pane = document.getElementById('tab-' + tabId + '-pane');\n      if (pane) pane.classList.add('active');\n    }\n  }\n\n  // For More tab's feature buttons — show a specific legacy tab\n  window.showTab = function(tabId) {\n    // Hide all tab-panes and legacy tabs\n    document.querySelectorAll('.tab-pane').forEach(function(p) { p.classList.remove('active'); });\n    document.querySelectorAll('.tab-content').forEach(function(t) { t.style.display = 'none'; });\n    // Show the requested legacy tab\n    var tab = document.getElementById(tabId);\n    if (tab) tab.style.display = 'block';\n  };","cwd":"/home/openclaw/.openclaw/workspace"},"isError":false,"timestamp":1775406345272}}
