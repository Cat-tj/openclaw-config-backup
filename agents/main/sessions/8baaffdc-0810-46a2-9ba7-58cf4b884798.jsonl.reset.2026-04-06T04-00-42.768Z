ch('/api/auth/register', {\n+196       method: 'POST',\n+197       headers: { 'Content-Type': 'application/json' },\n+198       body: JSON.stringify({\n+199         username: document.getElementById('regUser').value.trim(),\n+200         password: document.getElementById('regPass').value\n+201       })\n+202     });\n+203     const d = await res.json();\n+204     if (d.ok) {\n+205       regOk.textContent = '✅ ' + (d.message || 'Request submitted — awaiting admin approval');\n+206       regOk.style.display = 'block';\n+207       regForm.querySelector('button[type=submit]').style.display = 'none';\n+208     } else {\n+209       regErr.textContent = d.error || 'Registration failed';\n+210     }\n+211   } catch {\n+212     regErr.textContent = 'Connection error';\n+213   }\n+214 \n+215   regBtn.disabled = false;\n+216   regBtn.innerHTML = 'Request Access';\n+217 });\n 157 </script>\n 158 </body>\n 159 </html>","firstChangedLine":157},"isError":false,"timestamp":1775381625803}}
{"type":"message","id":"82187858","parentId":"141683f7","timestamp":"2026-04-05T09:34:35.206Z","message":{"role":"assistant","content":[{"type":"text","text":"Now create the User Management page:"},{"type":"toolCall","id":"tooluse_aVYzEPEMTXQWsf9gfTQ7Tj","name":"write","arguments":{"path":"~/magi-v2/frontend/users/index.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<link rel=\"manifest\" href=\"/manifest.json\"><meta name=\"theme-color\" content=\"#0d121b\">\n<title>MAGI — User Management</title>\n<link rel=\"stylesheet\" href=\"/shared/core.css\">\n<link rel=\"stylesheet\" href=\"/shared/components.css\">\n<style>\n.content { max-width: 900px; margin: 0 auto; padding: 32px 24px; position: relative; z-index: 1; }\n.page-title { font-size: 20px; font-weight: 700; color: var(--text-bright); margin-bottom: 8px; }\n.page-sub { font-size: 12px; color: var(--text-muted); margin-bottom: 32px; }\n\n.section { margin-bottom: 32px; }\n.section-title { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-muted); margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }\n.section-title .count { background: var(--accent-bg, rgba(99,235,255,0.08)); color: var(--accent); padding: 2px 8px; border-radius: 99px; font-size: 10px; }\n\n.user-table { width: 100%; border-collapse: collapse; }\n.user-table th { text-align: left; font-size: 10px; text-transform: uppercase; letter-spacing: .8px; color: var(--text-dim); padding: 8px 12px; border-bottom: 1px solid var(--border-strong, rgba(255,255,255,0.11)); font-weight: 600; }\n.user-table td { padding: 12px; border-bottom: 1px solid var(--border, rgba(255,255,255,0.06)); font-size: 13px; vertical-align: middle; }\n.user-table tr:last-child td { border-bottom: none; }\n.user-table tr:hover td { background: var(--bg-hover, rgba(99,235,255,0.05)); }\n\n.role-select { background: rgba(0,0,0,0.3); border: 1px solid var(--border); color: var(--text); padding: 4px 8px; border-radius: 6px; font-family: var(--font-mono); font-size: 12px; cursor: pointer; }\n.role-select:focus { border-color: rgba(255,255,255,0.28); outline: none; }\n\n.role-badge { font-size: 10px; font-weight: 600; padding: 3px 10px; border-radius: 99px; text-transform: uppercase; letter-spacing: .5px; }\n.role-admin { background: rgba(99,235,255,0.12); color: var(--accent); border: 1px solid rgba(99,235,255,0.25); }\n.role-editor { background: rgba(134,239,172,0.12); color: var(--color-success); border: 1px solid rgba(134,239,172,0.25); }\n.role-viewer { background: rgba(255,255,255,0.06); color: var(--text-muted); border: 1px solid var(--border); }\n\n.action-btn { padding: 5px 12px; border-radius: 6px; font-size: 11px; font-weight: 600; cursor: pointer; font-family: var(--font-mono); border: 1px solid; transition: all .15s; }\n.btn-approve { background: rgba(134,239,172,0.1); border-color: rgba(134,239,172,0.3); color: var(--color-success); }\n.btn-approve:hover { background: rgba(134,239,172,0.2); }\n.btn-reject { background: rgba(252,165,165,0.1); border-color: rgba(252,165,165,0.3); color: var(--color-danger); }\n.btn-reject:hover { background: rgba(252,165,165,0.2); }\n.btn-delete { background: rgba(252,165,165,0.06); border-color: rgba(252,165,165,0.2); color: var(--color-danger); font-size: 10px; padding: 4px 10px; }\n.btn-delete:hover { background: rgba(252,165,165,0.15); }\n\n.actions-cell { display: flex; gap: 6px; align-items: center; }\n\n.pending-card { background: var(--bg-elevated, #131a27); border: 1px solid rgba(253,224,71,0.15); border-radius: var(--radius-md); padding: 16px; margin-bottom: 8px; display: flex; align-items: center; justify-content: space-between; }\n.pending-info { display: flex; flex-direction: column; gap: 2px; }\n.pending-name { font-weight: 600; color: var(--text-bright); font-size: 14px; }\n.pending-time { font-size: 11px; color: var(--text-dim); }\n\n.role-picker { display: flex; gap: 4px; align-items: center; }\n.role-picker label { font-size: 10px; color: var(--text-muted); margin-right: 4px; }\n\n.empty { text-align: center; padding: 32px; color: var(--text-dim); font-size: 12px; }\n\n@media (max-width: 640px) {\n  .content { padding: 20px 12px; }\n  .user-table { font-size: 12px; }\n  .pending-card { flex-direction: column; gap: 12px; align-items: flex-start; }\n}\n</style>\n</head>\n<body>\n<div id=\"nav\"></div>\n<div class=\"content page-enter\">\n  <div class=\"page-title\">👥 User Management</div>\n  <div class=\"page-sub\">Approve registrations, manage roles, control access</div>\n\n  <!-- Pending Approvals -->\n  <div class=\"section\" id=\"pendingSection\" style=\"display:none\">\n    <div class=\"section-title\">⏳ Pending Approvals <span class=\"count\" id=\"pendingCount\">0</span></div>\n    <div id=\"pendingList\"></div>\n  </div>\n\n  <!-- Active Users -->\n  <div class=\"section\">\n    <div class=\"section-title\">Active Users <span class=\"count\" id=\"userCount\">0</span></div>\n    <div style=\"overflow-x:auto;\">\n      <table class=\"user-table\">\n        <thead>\n          <tr><th>Username</th><th>Name</th><th>Role</th><th>Actions</th></tr>\n        </thead>\n        <tbody id=\"userBody\">\n          <tr><td colspan=\"4\" class=\"empty\">Loading...</td></tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n</div>\n\n<script type=\"module\">\nimport { initPage, api, toast, escHtml, timeAgo } from '/shared/core.js';\nimport { renderNav } from '/shared/nav.js';\nimport { initTransitions } from '/shared/transitions.js';\n\nawait initPage();\nrenderNav('users');\ninitTransitions();\n\nconst CORE_ACCOUNTS = ['lucy', 'richard'];\n\nasync function loadUsers() {\n  const { data, error } = await api('/admin/users');\n  if (error) { toast(error, 'error'); return; }\n\n  // Render pending\n  const pending = data.pending || [];\n  const pendingSection = document.getElementById('pendingSection');\n  const pendingList = document.getElementById('pendingList');\n  document.getElementById('pendingCount').textContent = pending.length;\n\n  if (pending.length > 0) {\n    pendingSection.style.display = 'block';\n    pendingList.innerHTML = pending.map(p => `\n      <div class=\"pending-card stagger-item\">\n        <div class=\"pending-info\">\n          <div class=\"pending-name\">${escHtml(p.username)}</div>\n          <div class=\"pending-time\">Requested ${timeAgo(new Date(p.requestedAt))}</div>\n        </div>\n        <div class=\"actions-cell\">\n          <div class=\"role-picker\">\n            <label>Role:</label>\n            <select class=\"role-select\" id=\"role-${escHtml(p.username)}\">\n              <option value=\"viewer\">Viewer</option>\n              <option value=\"editor\">Editor</option>\n              <option value=\"admin\">Admin</option>\n            </select>\n          </div>\n          <button class=\"action-btn btn-approve\" onclick=\"approveUser('${escHtml(p.username)}')\">✓ Approve</button>\n          <button class=\"action-btn btn-reject\" onclick=\"rejectUser('${escHtml(p.username)}')\">✕ Reject</button>\n        </div>\n      </div>\n    `).join('');\n  } else {\n    pendingSection.style.display = 'none';\n  }\n\n  // Render users\n  const users = data.users || [];\n  document.getElementById('userCount').textContent = users.length;\n  const tbody = document.getElementById('userBody');\n\n  if (users.length === 0) {\n    tbody.innerHTML = '<tr><td colspan=\"4\" class=\"empty\">No users found</td></tr>';\n    return;\n  }\n\n  tbody.innerHTML = users.map(u => {\n    const isCore = CORE_ACCOUNTS.includes(u.username);\n    const roleCls = u.role === 'admin' ? 'role-admin' : u.role === 'editor' ? 'role-editor' : 'role-viewer';\n    return `<tr class=\"stagger-item\">\n      <td><strong>${escHtml(u.username)}</strong>${isCore ? ' 🔒' : ''}</td>\n      <td style=\"color:var(--text-secondary)\">${escHtml(u.name || u.username)}</td>\n      <td>\n        ${isCore\n          ? `<span class=\"role-badge ${roleCls}\">${u.role}</span>`\n          : `<select class=\"role-select\" onchange=\"changeRole('${escHtml(u.username)}', this.value)\">\n              <option value=\"viewer\" ${u.role==='viewer'?'selected':''}>viewer</option>\n              <option value=\"editor\" ${u.role==='editor'?'selected':''}>editor</option>\n              <option value=\"admin\" ${u.role==='admin'?'selected':''}>admin</option>\n            </select>`\n        }\n      </td>\n      <td>\n        ${isCore\n          ? '<span style=\"color:var(--text-dim);font-size:11px\">Protected</span>'\n          : `<button class=\"action-btn btn-delete\" onclick=\"deleteUser('${escHtml(u.username)}')\">Delete</button>`\n        }\n      </td>\n    </tr>`;\n  }).join('');\n}\n\nwindow.approveUser = async function(username) {\n  const roleEl = document.getElementById('role-' + username);\n  const role = roleEl ? roleEl.value : 'viewer';\n  const { error } = await api('/admin/users/approve', { method: 'POST', body: JSON.stringify({ username, role }) });\n  if (error) { toast(error, 'error'); return; }\n  toast(`${username} approved as ${role}`, 'success');\n  loadUsers();\n};\n\nwindow.rejectUser = async function(username) {\n  if (!confirm(`Reject registration for \"${username}\"?`)) return;\n  const { error } = await api('/admin/users/reject', { method: 'POST', body: JSON.stringify({ username }) });\n  if (error) { toast(error, 'error'); return; }\n  toast(`${username} rejected`, 'info');\n  loadUsers();\n};\n\nwindow.changeRole = async function(username, role) {\n  const { error } = await api(`/admin/users/${username}/role`, { method: 'PUT', body: JSON.stringify({ role }) });\n  if (error) { toast(error, 'error'); loadUsers(); return; }\n  toast(`${username} → ${role}`, 'success');\n};\n\nwindow.deleteUser = async function(username) {\n  if (!confirm(`Delete user \"${username}\"? This cannot be undone.`)) return;\n  const { error } = await api(`/admin/users/${username}`, { method: 'DELETE' });\n  if (error) { toast(error, 'error'); return; }\n  toast(`${username} deleted`, 'success');\n  loadUsers();\n};\n\nloadUsers();\n</script>\n</body>\n</html>\n"}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-opus-4-6-v1","usage":{"input":1,"output":3378,"cacheRead":205220,"cacheWrite":802,"totalTokens":209401,"cost":{"input":0.000005,"output":0.08445,"cacheRead":0.10260999999999999,"cacheWrite":0.0050125000000000005,"total":0.19207749999999998}},"stopReason":"toolUse","timestamp":1775381625827}}
