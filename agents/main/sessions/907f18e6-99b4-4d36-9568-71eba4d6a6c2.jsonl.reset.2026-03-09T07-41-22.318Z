{"type":"message","id":"82b76ca6","parentId":"c7f5d66a","timestamp":"2026-03-08T15:56:06.387Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"tooluse_aDuSx6MvZZiWTAULC79yZ4","name":"exec","arguments":{"command":"mkdir -p ~/council-room/uploads ~/council-room/data\ncat > ~/council-room/backend/server.js << 'EOF'\nimport Fastify from 'fastify';\nimport cors from '@fastify/cors';\nimport websocket from '@fastify/websocket';\nimport multipart from '@fastify/multipart';\nimport { spawn, execSync } from 'child_process';\nimport { readFileSync, writeFileSync, existsSync, mkdirSync, readdirSync, statSync, unlinkSync } from 'fs';\nimport { join, extname, relative, dirname, basename } from 'path';\nimport { pipeline } from 'stream/promises';\nimport { createWriteStream } from 'fs';\n\nconst fastify = Fastify({ logger: false });\nawait fastify.register(cors, { origin: true });\nawait fastify.register(websocket);\nawait fastify.register(multipart, { limits: { fileSize: 50*1024*1024 } });\n\nconst TOKEN        = process.env.COUNCIL_TOKEN || 'council-88d2f8242c07fcef';\nconst MEMORY_FILE  = '/home/openclaw/council-room/memory.json';\nconst EVENTS_FILE  = '/home/openclaw/council-room/events.json';\nconst TOKENS_FILE  = '/home/openclaw/council-room/data/tokens.json';\nconst PINS_FILE    = '/home/openclaw/council-room/data/pins.json';\nconst DOCS_DIR     = '/home/openclaw/council-room/uploads';\nconst OC_CONFIG    = '/home/openclaw/.openclaw/openclaw.json';\nconst WORKSPACES   = {\n  michael: '/home/openclaw/.openclaw/workspace',\n  rafael:  '/home/openclaw/.openclaw/workspace-rafael',\n  uriel:   '/home/openclaw/.openclaw/workspace-uriel',\n  gabriel: '/home/openclaw/.openclaw/workspace-gabriel',\n  raguel:  '/home/openclaw/.openclaw/workspace-raguel',\n};\n\nconst AGENTS = {\n  rafael:  { name:'Rafael',  emoji:'🧭', role:'The Guide'        },\n  uriel:   { name:'Uriel',   emoji:'🔥', role:\"God's Fire\"       },\n  michael: { name:'Michael', emoji:'🛡️', role:'Wise Advisor'     },\n  gabriel: { name:'Gabriel', emoji:'📣', role:'The Voice'        },\n  raguel:  { name:'Raguel',  emoji:'🤝', role:'The Friend'       },\n};\n\n// ── helpers ──\nconst jread  = (f,d={}) => { try { return JSON.parse(readFileSync(f,'utf8')); } catch { return d; } };\nconst jwrite = (f,d)    => writeFileSync(f, JSON.stringify(d,null,2));\nfunction auth(req,rep)  { const t=req.headers['x-council-token']||req.query?.token; if(t!==TOKEN){rep.code(401).send({error:'Unauthorized'});return false;} return true; }\n\n// ── token tracking ──\nfunction recordTokens(agentId, text) {\n  const est = Math.ceil(text.length/4);\n  const d   = jread(TOKENS_FILE, { agents:{}, hourly:[] });\n  if(!d.agents[agentId]) d.agents[agentId] = { total:0, sessions:0 };\n  d.agents[agentId].total += est;\n  d.agents[agentId].sessions++;\n  d.agents[agentId].lastSeen = Date.now();\n  // hourly bucket\n  const hKey = new Date().toISOString().slice(0,13);\n  let hb = d.hourly.find(h=>h.hour===hKey);\n  if(!hb){ hb={hour:hKey,tokens:0,byAgent:{}}; d.hourly.push(hb); if(d.hourly.length>168) d.hourly.shift(); }\n  hb.tokens += est;\n  hb.byAgent[agentId] = (hb.byAgent[agentId]||0)+est;\n  jwrite(TOKENS_FILE, d);\n  return est;\n}\n\n// ── events ──\nconst clients = new Set();\nfunction loadEvents()   { return jread(EVENTS_FILE, []); }\nfunction appendEvent(ev){ const evs=loadEvents(); evs.push({...ev,serverTs:Date.now()}); if(evs.length>500)evs.splice(0,evs.length-500); jwrite(EVENTS_FILE,evs); }\nfunction getEventsSince(ts){ return loadEvents().filter(e=>e.serverTs>ts); }\nfunction broadcast(ev)  { appendEvent(ev); clients.forEach(s=>{ try{ if(s.readyState===1)s.send(JSON.stringify(ev)); }catch{} }); }\n\n// ── agent runner ──\nfunction runAgent(id, msg) {\n  return new Promise(resolve=>{\n    const aid = id==='michael'?'main':id;\n    const proc = spawn('openclaw',['agent','--agent',aid,'--message',msg,'--json'],{env:{...process.env,HOME:'/home/openclaw'}});\n    let buf='';\n    proc.stdout.on('data',c=>buf+=c.toString());\n    proc.on('close',()=>{\n      try{ const j=JSON.parse(buf); const text=j?.result?.payloads?.[0]?.text||j?.reply||j?.text||buf.trim(); recordTokens(id,text); resolve(text); }\n      catch{ resolve(buf.trim()); }\n    });\n    proc.on('error',e=>resolve(`Error: ${e.message}`));\n  });\n}\n\n// ── roundtable ──\nconst activeRT = new Map();\nasync function runRoundtable(id, topic, sessionId) {\n  let stopped = false;\n  activeRT.set(id, { stop:()=>{stopped=true;} });\n  const mem = jread(MEMORY_FILE,{facts:[]});\n  const memCtx = mem.facts.length ? `\\n\\n[Memory: ${mem.facts.map(f=>f.fact).join('; ')}]`:'';\n  const order = ['rafael','uriel','gabriel','raguel'];\n  let transcript = '';\n  for(const aid of order){\n    if(stopped) break;\n    broadcast({type:'thinking',agentId:aid,agent:AGENTS[aid],pane:'council',sessionId,roundtableId:id});\n    const prompt=`Council roundtable on: \"${topic}\"\\n\\n${transcript?'So far:\\n'+transcript+'\\n':''}You are ${AGENTS[aid].name} (${AGENTS[aid].role}). 2-4 sentences, direct, add your unique angle.${memCtx}`;\n    const res = await runAgent(aid,prompt);\n    broadcast({type:'response',agentId:aid,agent:AGENTS[aid],response:res,pane:'council',sessionId,roundtableId:id});\n    transcript += `${AGENTS[aid].name}: ${res}\\n\\n`;\n  }\n  // Michael summarizes\n  broadcast({type:'thinking',agentId:'michael',agent:AGENTS['michael'],pane:'council',sessionId});\n  const sum = await runAgent('michael',`Roundtable on \"${topic}\":\\n${transcript}\\nSummarize in 3-5 sentences: key points, consensus, ONE next action for Lucy. Start with \"📋 Roundtable Summary:\"${memCtx}`);\n  broadcast({type:'response',agentId:'michael',agent:AGENTS['michael'],response:sum,pane:'council',sessionId});\n  broadcast({type:'council_done',pane:'council',sessionId});\n  activeRT.delete(id);\n}\n\n// ══════════════════════════════════════\n//  REST ENDPOINTS\n// ══════════════════════════════════════\n\nfastify.get('/health', async(req,rep)=>{ if(!auth(req,rep))return; return {status:'ok',agents:Object.keys(AGENTS),activeRoundtables:[...activeRT.keys()]}; });\n\n// ── system health ──\nfastify.get('/system', async(req,rep)=>{\n  if(!auth(req,rep))return;\n  try{\n    const mem   = readFileSync('/proc/meminfo','utf8');\n    const total = parseInt(mem.match(/MemTotal:\\s+(\\d+)/)[1])*1024;\n    const avail = parseInt(mem.match(/MemAvailable:\\s+(\\d+)/)[1])*1024;\n    const load  = readFileSync('/proc/loadavg','utf8').split(' ');\n    const disk  = execSync('df -B1 /home/openclaw 2>/dev/null').toString().split('\\n')[1].split(/\\s+/);\n    const up    = parseFloat(readFileSync('/proc/uptime','utf8').split(' ')[0]);\n    return { memory:{total,used:total-avail,free:avail}, cpu:{load1:parseFloat(load[0]),load5:parseFloat(load[1]),load15:parseFloat(load[2])}, disk:{total:parseInt(disk[1]),used:parseInt(disk[2]),free:parseInt(disk[3])}, uptime:up };\n  }catch(e){return {error:e.message};}\n});\n\n// ── tokens ──\nfastify.get('/tokens', async(req,rep)=>{ if(!auth(req,rep))return; return jread(TOKENS_FILE,{agents:{},hourly:[]}); });\n\n// ── memory ──\nfastify.get('/memory',       async(req,rep)=>{ if(!auth(req,rep))return; return jread(MEMORY_FILE,{facts:[]}); });\nfastify.post('/memory',      async(req,rep)=>{ if(!auth(req,rep))return; const {fact}=req.body; if(!fact)return rep.code(400).send({error:'fact required'}); const m=jread(MEMORY_FILE,{facts:[]}); m.facts.push({fact,ts:Date.now(),date:new Date().toISOString()}); jwrite(MEMORY_FILE,m); return {ok:true}; });\nfastify.delete('/memory/:i', async(req,rep)=>{ if(!auth(req,rep))return; const m=jread(MEMORY_FILE,{facts:[]}); m.facts.splice(parseInt(req.params.i),1); jwrite(MEMORY_FILE,m); return {ok:true}; });\n\n// ── pins ──\nfastify.get('/pins',         async(req,rep)=>{ if(!auth(req,rep))return; return jread(PINS_FILE,{pins:[]}); });\nfastify.post('/pins',        async(req,rep)=>{ if(!auth(req,rep))return; const {text,agentId,ts}=req.body; const p=jread(PINS_FILE,{pins:[]}); p.pins.push({text,agentId,ts,pinned:Date.now()}); jwrite(PINS_FILE,p); return {ok:true}; });\nfastify.delete('/pins/:i',   async(req,rep)=>{ if(!auth(req,rep))return; const p=jread(PINS_FILE,{pins:[]}); p.pins.splice(parseInt(req.params.i),1); jwrite(PINS_FILE,p); return {ok:true}; });\n\n// ── openclaw config ──\nfastify.get('/oc/config',  async(req,rep)=>{ if(!auth(req,rep))return; return jread(OC_CONFIG,{}); });\nfastify.post('/oc/config', async(req,rep)=>{ if(!auth(req,rep))return; try{ jwrite(OC_CONFIG,req.body); return {ok:true}; }catch(e){return rep.code(500).send({error:e.message});} });\n\n// ── openclaw agents list ──\nfastify.get('/oc/agents', async(req,rep)=>{\n  if(!auth(req,rep))return;\n  try{ const r=execSync('openclaw agents list --json 2>/dev/null').toString(); return {agents:JSON.parse(r)}; }\n  catch{ return {agents:Object.keys(AGENTS).map(id=>({id,name:AGENTS[id].name}))}; }\n});\n\n// ── file explorer ──\nfunction safeList(dir){\n  if(!existsSync(dir))return [];\n  return readdirSync(dir).map(f=>{ const fp=join(dir,f); const s=statSync(fp); return {name:f,path:fp,isDir:s.isDirectory(),size:s.size,mtime:s.mtimeMs}; }).sort((a,b)=>b.isDir-a.isDir||a.name.localeCompare(b.name));\n}\nfastify.get('/files', async(req,rep)=>{\n  if(!auth(req,rep))return;\n  const agent  = req.query.agent||'michael';\n  const relPath= req.query.path||'';\n  const base   = WORKSPACES[agent]||WORKSPACES.michael;\n  const target = relPath ? join(base,relPath) : base;\n  if(!target.startsWith(base))return rep.code(403).send({error:'forbidden'});\n  return {items:safeList(target),base,current:target};\n});\nfastify.get('/file', async(req,rep)=>{\n  if(!auth(req,rep))return;\n  const {agent='michael',path:p=''} = req.query;\n  const base=WORKSPACES[agent]||WORKSPACES.michael;\n  const fp=join(base,p);\n  if(!fp.startsWith(base))return rep.code(403).send({error:'forbidden'});\n  try{ return {content:readFileSync(fp,'utf8'),path:fp}; }catch(e){return rep.code(404).send({error:'not found'});}\n});\nfastify.post('/file', async(req,rep)=>{\n  if(!auth(req,rep))return;\n  const {agent='michael',path:p='',content=''} = req.body;\n  const base=WORKSPACES[agent]||WORKSPACES.michael;\n  const fp=join(base,p);\n  if(!fp.startsWith(base))return rep.code(403).send({error:'forbidden'});\n  try{ mkdirSync(dirname(fp),{recursive:true}); writeFileSync(fp,content,'utf8'); return {ok:true}; }catch(e){return rep.code(500).send({error:e.message});}\n});\n\n// ── document vault ──\nfastify.get('/docs', async(req,rep)=>{\n  if(!auth(req,rep))return;\n  if(!existsSync(DOCS_DIR))return {docs:[]};\n  const docs=readdirSync(DOCS_DIR).map(f=>{ const s=statSync(join(DOCS_DIR,f)); return {name:f,size:s.size,mtime:s.mtimeMs}; });\n  return {docs};\n});\nfastify.post('/docs/upload', async(req,rep)=>{\n  if(!auth(req,rep))return;\n  const data = await req.file();\n  if(!data)return rep.code(400).send({error:'no file'});\n  const fname=`${Date.now()}_${data.filename}`;\n  await pipeline(data.file, createWriteStream(join(DOCS_DIR,fname)));\n  return {ok:true,filename:fname};\n});\nfastify.delete('/docs/:name', async(req,rep)=>{\n  if(!auth(req,rep))return;\n  const fp=join(DOCS_DIR,req.params.name);\n  if(existsSync(fp))unlinkSync(fp);\n  return {ok:true};\n});\n\n// ── cron ──\nfastify.get('/cron', async(req,rep)=>{\n  if(!auth(req,rep))return;\n  try{ const c=execSync('crontab -l 2>/dev/null').toString(); return {cron:c}; }catch{return {cron:''};}\n});\nfastify.post('/cron', async(req,rep)=>{\n  if(!auth(req,rep))return;\n  const {entry}=req.body;\n  if(!entry)return rep.code(400).send({error:'entry required'});\n  try{\n    const cur=execSync('crontab -l 2>/dev/null').toString();\n    const updated=cur.trim()+'\\n'+entry+'\\n';\n    execSync(`echo ${JSON.stringify(updated)} | crontab -`);\n    return {ok:true};\n  }catch(e){return rep.code(500).send({error:e.message});}\n});\n\n// ── search events ──\nfastify.get('/search', async(req,rep)=>{\n  if(!auth(req,rep))return;\n  const q=(req.query.q||'').toLowerCase();\n  if(!q)return {results:[]};\n  const evs=loadEvents().filter(e=>e.type==='response'&&e.response?.toLowerCase().includes(q));\n  return {results:evs.slice(-50)};\n});\n\n// ── websocket ──\nfastify.get('/ws', {websocket:true}, (socket,req)=>{\n  const url   = new URL(req.url,'http://localhost');\n  const t     = url.searchParams.get('token');\n  const since = parseInt(url.searchParams.get('since')||'0');\n  if(t!==TOKEN){socket.send(JSON.stringify({type:'error',message:'Unauthorized'}));socket.close();return;}\n  clients.add(socket);\n  socket.send(JSON.stringify({type:'connected'}));\n  const missed=getEventsSince(since);\n  if(missed.length) socket.send(JSON.stringify({type:'replay',events:missed}));\n\n  socket.on('message', async raw=>{\n    let d; try{d=JSON.parse(raw.toString());}catch{return;}\n    const {agentId,message,mode,pane,sessionId,type}=d;\n    if(type==='stop'){activeRT.forEach(r=>r.stop());return;}\n    if(!message)return;\n    const mem=jread(MEMORY_FILE,{facts:[]});\n    const mc=mem.facts.length?`\\n\\n[Memory: ${mem.facts.map(f=>f.fact).join('; ')}]`:'';\n\n    if(mode==='roundtable'){\n      const rtId='rt_'+Date.now(); runRoundtable(rtId,message,sessionId);\n    }else if(mode==='council'){\n      Object.keys(AGENTS).forEach(id=>broadcast({type:'thinking',agentId:id,agent:AGENTS[id],pane:'council',sessionId}));\n      await Promise.all(Object.keys(AGENTS).map(async id=>{\n        const r=await runAgent(id,message+mc);\n        broadcast({type:'response',agentId:id,agent:AGENTS[id],response:r,pane:'council',sessionId});\n      }));\n      broadcast({type:'council_done',pane:'council',sessionId});\n    }else{\n      const tid=agentId||'rafael';\n      broadcast({type:'thinking',agentId:tid,agent:AGENTS[tid],pane,sessionId});\n      const r=await runAgent(tid,message+mc);\n      broadcast({type:'response',agentId:tid,agent:AGENTS[tid],response:r,pane,sessionId});\n      broadcast({type:'council_done',pane,sessionId});\n    }\n  });\n  socket.on('close',()=>clients.delete(socket));\n});\n\nconst PORT=parseInt(process.env.PORT||'3001');\nawait fastify.listen({port:PORT,host:'127.0.0.1'});\nconsole.log(`✅  Council Room API on http://127.0.0.1:${PORT}`);\nEOF\necho \"Backend v2 written: $(wc -c < ~/council-room/backend/server.js) bytes\""}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-sonnet-4-6","usage":{"input":1,"output":5131,"cacheRead":52630,"cacheWrite":117,"totalTokens":57879,"cost":{"input":0.000003,"output":0.076965,"cacheRead":0.015789,"cacheWrite":0.00043875,"total":0.09319575000000001}},"stopReason":"toolUse","timestamp":1772985304237}}
{"type":"message","id":"e273e1c5","parentId":"82b76ca6","timestamp":"2026-03-08T15:56:06.430Z","message":{"role":"toolResult","toolCallId":"tooluse_aDuSx6MvZZiWTAULC79yZ4","toolName":"exec","content":[{"type":"text","text":"Backend v2 written: 13973 bytes"}],"details":{"status":"completed","exitCode":0,"durationMs":29,"aggregated":"Backend v2 written: 13973 bytes","cwd":"/home/openclaw/.openclaw/workspace"},"isError":false,"timestamp":1772985366425}}
{"type":"message","id":"8b3e933d","parentId":"e273e1c5","timestamp":"2026-03-08T16:01:23.271Z","message":{"role":"assistant","content":[{"type":"text","text":"Now the full frontend v2:"},{"type":"toolCall","id":"tooluse_OfxqTKlbtS1tqKYyEQ654q","name":"write","arguments":{"file_path":"/home/openclaw/council-room/frontend/index.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Council Room v2</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap\" rel=\"stylesheet\">\n<style>\n*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}\n:root{--bg:#0A0A0F;--s1:#13131A;--s2:#1C1C27;--s3:#252535;--b1:#2E2E3E;--b2:#3E3E52;--gold:#C9A84C;--violet:#7C6FCD;--ivory:#F0EDE8;--ash:#7A7A8C;--sage:#4CAF82;--ember:#E05C5C;--sky:#4A9ECD;--r:#7C6FCD;--u:#C9A84C;--m:#4CAF82;--g:#E05C5C;--rg:#7A8FCD;--rad:.75rem}\nbody{background:var(--bg);color:var(--ivory);font-family:'Inter',sans-serif;height:100vh;overflow:hidden;display:flex;flex-direction:column}\n::-webkit-scrollbar{width:3px;height:3px}::-webkit-scrollbar-thumb{background:var(--b2);border-radius:2px}\n\n/* LOGIN */\n#login{position:fixed;inset:0;z-index:999;background:var(--bg);display:flex;align-items:center;justify-content:center}\n.lcard{background:var(--s1);border:1px solid var(--b1);border-radius:16px;padding:2.5rem;width:300px;text-align:center}\n.lcard h2{font-size:1.3rem;margin:.5rem 0 .25rem}.lcard p{font-size:.75rem;color:var(--ash);margin-bottom:1.2rem}\ninput.inp{width:100%;padding:.65rem .9rem;background:var(--s2);border:1px solid var(--b1);border-radius:8px;color:var(--ivory);font-family:'JetBrains Mono',monospace;font-size:.82rem;outline:none;margin-bottom:.6rem;transition:border-color .2s}\ninput.inp:focus{border-color:var(--violet)}\n.btn{width:100%;padding:.65rem;background:var(--violet);border:none;border-radius:8px;color:#fff;font-family:'Inter',sans-serif;font-weight:600;font-size:.85rem;cursor:pointer}\n.btn:hover{filter:brightness(1.15)}.btn:disabled{opacity:.4;cursor:not-allowed}\n.err{color:var(--ember);font-size:.72rem;margin-top:.4rem}\n\n/* APP */\n#app{display:none;flex-direction:column;height:100vh}\nheader{background:rgba(19,19,26,.98);backdrop-filter:blur(20px);border-bottom:1px solid var(--b1);padding:0 1rem;height:50px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;z-index:50}\n.hlogo{display:flex;align-items:center;gap:.5rem;font-weight:700;font-size:.9rem}\n.hlogo-icon{width:24px;height:24px;background:linear-gradient(135deg,var(--violet),var(--gold));border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:11px}\n.hright{display:flex;align-items:center;gap:.5rem}\n.pill{display:flex;align-items:center;gap:.3rem;font-size:.68rem;color:var(--ash);background:var(--s2);border:1px solid var(--b1);padding:.2rem .55rem;border-radius:20px}\n.dot{width:6px;height:6px;border-radius:50%;animation:pulse 2s infinite}\n@keyframes pulse{0%,100%{box-shadow:0 0 0 0 currentColor}50%{box-shadow:0 0 0 3px transparent}}\n.ibtn{background:none;border:1px solid var(--b1);border-radius:7px;color:var(--ash);cursor:pointer;padding:.28rem .55rem;font-size:.74rem;font-family:'Inter',sans-serif;transition:all .15s}\n.ibtn:hover{border-color:var(--violet);color:var(--ivory)}\n.ibtn.active{border-color:var(--violet);background:rgba(124,111,205,.12);color:var(--ivory)}\n\n/* TABS */\nnav{background:var(--s1);border-bottom:1px solid var(--b1);display:flex;align-items:center;padding:0 1rem;gap:.15rem;flex-shrink:0;overflow-x:auto}\n.tab{padding:.55rem .8rem;border:none;background:none;color:var(--ash);font-family:'Inter',sans-serif;font-size:.78rem;font-weight:500;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:all .15s;display:flex;align-items:center;gap:.35rem}\n.tab:hover{color:var(--ivory)}.tab.active{color:var(--ivory);border-bottom-color:var(--violet)}\n\n/* TAB PANELS */\n.panels{flex:1;overflow:hidden;display:flex;flex-direction:column}\n.panel{display:none;flex:1;overflow:hidden;flex-direction:column}\n.panel.active{display:flex}\n\n/* ── CHAT PANEL ── */\n.chat-layout{display:flex;flex:1;overflow:hidden}\n.sidebar{width:190px;flex-shrink:0;background:var(--s1);border-right:1px solid var(--b1);display:flex;flex-direction:column;overflow-y:auto}\n.sb-sec{padding:.6rem .5rem .3rem}\n.sb-lbl{font-size:.6rem;font-weight:700;color:var(--ash);text-transform:uppercase;letter-spacing:.08em;padding:0 .4rem;margin-bottom:.3rem}\n.ab{display:flex;align-items:center;gap:.5rem;width:100%;padding:.45rem .55rem;background:none;border:none;border-radius:6px;color:var(--ash);cursor:pointer;font-family:'Inter',sans-serif;font-size:.78rem;text-align:left;transition:all .15s;margin-bottom:2px}\n.ab:hover{background:rgba(255,255,255,.05);color:var(--ivory)}.ab.on{background:rgba(124,111,205,.1);color:var(--ivory)}\n.adot{width:7px;height:7px;border-radius:50%;flex-shrink:0}\n.aname{font-weight:500;font-size:.78rem;line-height:1.2}\n.arole{font-size:.63rem;color:var(--ash)}\n.sb-mem{padding:.6rem .5rem;border-top:1px solid var(--b1);margin-top:auto}\n.sb-lbl2{font-size:.6rem;font-weight:700;color:var(--ash);text-transform:uppercase;letter-spacing:.08em;padding:0 .4rem;margin-bottom:.4rem}\n.mlist{max-height:140px;overflow-y:auto;margin-bottom:.4rem;display:flex;flex-direction:column;gap:.25rem}\n.mitem{display:flex;align-items:flex-start;gap:.3rem;padding:.28rem .4rem;background:rgba(201,168,76,.06);border:1px solid rgba(201,168,76,.1);border-radius:5px;font-size:.7rem}\n.mtext{flex:1;line-height:1.4;color:var(--ivory)}.mdel{background:none;border:none;color:var(--ash);cursor:pointer;font-size:9px;padding:1px 2px;border-radius:3px}.mdel:hover{color:var(--ember)}\n.madd{display:flex;gap:.3rem}\n.minp{flex:1;background:var(--s2);border:1px solid var(--b1);border-radius:5px;padding:.3rem .45rem;color:var(--ivory);font-family:'Inter',sans-serif;font-size:.7rem;outline:none}.minp:focus{border-color:var(--gold)}\n.msave{background:var(--gold);border:none;border-radius:5px;color:var(--bg);font-weight:700;font-size:.7rem;padding:.3rem .45rem;cursor:pointer;white-space:nowrap}\n\n.chat-main{flex:1;display:flex;flex-direction:column;overflow:hidden}\n.modebar{display:flex;align-items:center;gap:.4rem;padding:.5rem .9rem;border-bottom:1px solid var(--b1);background:var(--s1);flex-shrink:0;flex-wrap:wrap}\n.mtog{display:flex;background:var(--s2);border:1px solid var(--b1);border-radius:7px;padding:2px}\n.mb{padding:.28rem .65rem;border:none;background:none;color:var(--ash);font-family:'Inter',sans-serif;font-size:.73rem;font-weight:500;border-radius:5px;cursor:pointer;transition:all .15s;white-space:nowrap}\n.mb.on{background:var(--violet);color:#fff}.mb.ong{background:var(--gold);color:#0A0A0F}\n.albl{font-size:.73rem;color:var(--ash);margin-left:.2rem}\n.albl strong{color:var(--ivory)}\n.rtbtn{margin-left:auto;display:none}\n.stopbtn{display:none;border-color:var(--ember)!important;color:var(--ember)!important}\n.sessbar{display:flex;align-items:center;gap:.3rem;padding:.35rem .9rem;background:var(--bg);border-bottom:1px solid rgba(255,255,255,.04);overflow-x:auto;flex-shrink:0}\n.sc{padding:.18rem .5rem;border:1px solid var(--b1);border-radius:20px;background:var(--s2);cursor:pointer;font-size:.68rem;color:var(--ash);white-space:nowrap;transition:all .15s}\n.sc:hover{border-color:var(--violet);color:var(--ivory)}.sc.on{border-color:var(--violet);background:rgba(124,111,205,.1);color:var(--ivory)}\n.snew{padding:.18rem .5rem;border:1px dashed var(--b1);border-radius:20px;background:none;cursor:pointer;font-size:.68rem;color:var(--ash);white-space:nowrap;transition:all .15s}.snew:hover{border-color:var(--sage);color:var(--sage)}\n\n.panes{flex:1;overflow:hidden;position:relative}\n.pane{position:absolute;inset:0;overflow-y:auto;padding:.9rem;display:none;flex-direction:column;gap:.6rem;scroll-behavior:smooth}\n.pane.on{display:flex}\n.msg{display:flex;gap:.55rem;animation:mi .2s ease;max-width:88%}\n@keyframes mi{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:none}}\n.msg.me{align-self:flex-end;flex-direction:row-reverse}\n.ava{width:28px;height:28px;border-radius:6px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:13px;background:rgba(255,255,255,.05)}\n.mbody{flex:1;min-width:0}\n.mmeta{display:flex;align-items:center;gap:.4rem;margin-bottom:.2rem}\n.mname{font-size:.67rem;font-weight:600}.mtime{font-size:.6rem;color:var(--ash);font-family:'JetBrains Mono',monospace}\n.mpin{background:none;border:none;color:var(--ash);cursor:pointer;font-size:.65rem;padding:1px 3px;opacity:0;transition:opacity .15s}\n.msg:hover .mpin{opacity:1}.mpin:hover{color:var(--gold)}\n.bub{background:var(--s2);border:1px solid var(--b1);border-radius:9px;padding:.6rem .85rem;font-size:.82rem;line-height:1.6;color:var(--ivory);white-space:pre-wrap;word-break:break-word}\n.msg.me .bub{background:rgba(124,111,205,.09);border-color:rgba(124,111,205,.18)}\n.bub strong,.bub b{font-weight:600}.bub em{font-style:italic;color:#bbb8cc}\n.bub code{font-family:'JetBrains Mono',monospace;font-size:.77rem;background:rgba(255,255,255,.06);padding:.1em .3em;border-radius:3px}\n.think{display:flex;align-items:center;gap:.4rem;padding:.25rem .4rem;color:var(--ash);font-size:.7rem;font-style:italic;animation:mi .2s ease}\n.dots span{display:inline-block;width:3px;height:3px;border-radius:50%;background:currentColor;margin:0 1px;animation:dt 1.2s infinite}\n.dots span:nth-child(2){animation-delay:.2s}.dots span:nth-child(3){animation-delay:.4s}\n@keyframes dt{0%,80%,100%{transform:scale(.6);opacity:.4}40%{transform:scale(1);opacity:1}}\n.empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.5rem;opacity:.25;text-align:center;padding:2rem}\n.empty .ei{font-size:2rem}.empty .et{font-size:.9rem;font-weight:600}.empty .es{font-size:.72rem;max-width:200px;line-height:1.5}\n\n.iarea{border-top:1px solid var(--b1);padding:.65rem .9rem;background:var(--s1);flex-shrink:0}\n.iwrap{display:flex;align-items:flex-end;gap:.5rem;background:var(--s2);border:1px solid var(--b1);border-radius:9px;padding:.5rem .6rem;transition:border-color .2s}.iwrap:focus-within{border-color:var(--violet)}\n#inp{flex:1;background:none;border:none;outline:none;color:var(--ivory);font-family:'Inter',sans-serif;font-size:.84rem;resize:none;max-height:100px;line-height:1.5}\n#inp::placeholder{color:var(--ash)}\n.snd{width:30px;height:30px;border-radius:6px;border:none;background:var(--violet);color:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;transition:all .15s}\n.snd:hover{filter:brightness(1.15)}.snd:disabled{opacity:.35;cursor:not-allowed}.snd.cmode{background:var(--gold);color:var(--bg)}\n.ihint{font-size:.64rem;color:var(--ash);margin-top:.3rem;padding:0 .15rem}\n.cmd-palette{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.7);display:none;align-items:flex-start;justify-content:center;padding-top:15vh}\n.cmd-palette.open{display:flex}\n.cpal{background:var(--s1);border:1px solid var(--b1);border-radius:12px;width:480px;max-width:95vw;overflow:hidden;box-shadow:0 25px 60px rgba(0,0,0,.5)}\n.cpal-inp{width:100%;padding:.85rem 1rem;background:var(--s2);border:none;border-bottom:1px solid var(--b1);color:var(--ivory);font-family:'Inter',sans-serif;font-size:.9rem;outline:none}\n.cpal-list{max-height:320px;overflow-y:auto}\n.cpal-item{padding:.65rem 1rem;cursor:pointer;display:flex;align-items:center;gap:.65rem;transition:background .1s;border-bottom:1px solid rgba(255,255,255,.03)}\n.cpal-item:hover{background:rgba(255,255,255,.04)}.cpal-item.sel{background:rgba(124,111,205,.1)}\n.cpal-icon{font-size:1rem;width:24px;text-align:center}.cpal-label{font-size:.83rem;font-weight:500}.cpal-desc{font-size:.7rem;color:var(--ash)}\n\n/* ── MISSION CONTROL ── */\n.mc{flex:1;overflow-y:auto;padding:1.25rem}\n.mc-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;margin-bottom:1.25rem}\n.card{background:var(--s1);border:1px solid var(--b1);border-radius:var(--rad);padding:1rem}\n.card-title{font-size:.68rem;font-weight:600;color:var(--ash);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.5rem}\n.card-val{font-size:2rem;font-weight:700;line-height:1}\n.card-sub{font-size:.7rem;color:var(--ash);margin-top:.3rem}\n.prog{height:4px;background:var(--b1);border-radius:2px;margin-top:.6rem;overflow:hidden}\n.progbar{height:100%;border-radius:2px;background:var(--violet);transition:width .4s}\n\n.sprint-board{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.25rem}\n.col{background:var(--s1);border:1px solid var(--b1);border-radius:var(--rad);padding:.75rem;min-height:200px}\n.col-h{font-size:.73rem;font-weight:700;color:var(--ash);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.65rem;display:flex;align-items:center;justify-content:space-between}\n.col-cnt{font-size:.65rem;background:var(--s2);padding:.1rem .4rem;border-radius:20px}\n.task{background:var(--s2);border:1px solid var(--b1);border-radius:6px;padding:.5rem .65rem;margin-bottom:.4rem;font-size:.75rem;line-height:1.5;cursor:grab;transition:all .15s;position:relative}\n.task:hover{border-color:var(--violet)}.task.dragging{opacity:.4}\n.task-del{position:absolute;top:.3rem;right:.4rem;background:none;border:none;color:var(--ash);cursor:pointer;font-size:.65rem;opacity:0;transition:opacity .15s}\n.task:hover .task-del{opacity:1}.task-del:hover{color:var(--ember)}\n.task-add{width:100%;padding:.4rem .5rem;background:none;border:1px dashed var(--b1);border-radius:5px;color:var(--ash);font-family:'Inter',sans-serif;font-size:.73rem;cursor:pointer;transition:all .15s;text-align:left}\n.task-add:hover{border-color:var(--sage);color:var(--sage)}\n\n.pipe{background:var(--s1);border:1px solid var(--b1);border-radius:var(--rad);padding:.75rem;margin-bottom:1.25rem}\n.pipe-h{display:flex;align-items:center;justify-content:space-between;margin-bottom:.65rem}\n.pipe-title{font-size:.75rem;font-weight:700;color:var(--ivory)}\n.pipe-add{background:var(--violet);border:none;border-radius:6px;color:#fff;font-family:'Inter',sans-serif;font-size:.7rem;padding:.3rem .65rem;cursor:pointer}\n.ptable{width:100%;border-collapse:collapse;font-size:.76rem}\n.ptable th{color:var(--ash);font-weight:600;text-align:left;padding:.3rem .5rem;border-bottom:1px solid var(--b1);font-size:.67rem;text-transform:uppercase;letter-spacing:.06em}\n.ptable td{padding:.4rem .5rem;border-bottom:1px solid rgba(255,255,255,.04)}\n.pstatus{padding:.15rem .45rem;border-radius:20px;font-size:.65rem;font-weight:600}\n.ps-lead{background:rgba(124,175,130,.12);color:var(--sage);border:1px solid rgba(76,175,130,.2)}\n.ps-con{background:rgba(201,168,76,.12);color:var(--gold);border:1px solid rgba(201,168,76,.2)}\n.ps-pay{background:rgba(124,111,205,.12);color:var(--violet);border:1px solid rgba(124,111,205,.2)}\n\n.journal{background:var(--s1);border:1px solid var(--b1);border-radius:var(--rad);padding:.75rem}\n.journal textarea{width:100%;background:var(--s2);border:1px solid var(--b1);border-radius:6px;padding:.6rem .75rem;color:var(--ivory);font-family:'Inter',sans-serif;font-size:.8rem;line-height:1.6;outline:none;resize:none;min-height:100px;transition:border-color .2s}\n.journal textarea:focus{border-color:var(--violet)}\n\n/* ── ANALYTICS ── */\n.an{flex:1;overflow-y:auto;padding:1.25rem;display:flex;flex-direction:column;gap:1rem}\n.agrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:.9rem}\n.acard{background:var(--s1);border:1px solid var(--b1);border-radius:var(--rad);padding:.85rem}\n.acard-name{font-size:.7rem;font-weight:700;margin-bottom:.4rem;display:flex;align-items:center;gap:.4rem}\n.acard-tok{font-size:1.5rem;font-weight:700}\n.acard-sub{font-size:.67rem;color:var(--ash);margin-top:.2rem}\n.acard-bar{height:3px;background:var(--b1);border-radius:2px;margin-top:.5rem;overflow:hidden}\n.acard-bar div{height:100%;border-radius:2px}\n.sys{background:var(--s1);border:1px solid var(--b1);border-radius:var(--rad);padding:.85rem}\n.sys-title{font-size:.73rem;font-weight:700;margin-bottom:.65rem}\n.sysrow{display:flex;align-items:center;gap:.75rem;margin-bottom:.5rem}\n.sysrow-lbl{font-size:.7rem;color:var(--ash);width:60px}\n.sysbar{flex:1;height:6px;background:var(--b1);border-radius:3px;overflow:hidden}\n.sysbar div{height:100%;border-radius:3px;transition:width .5s}\n.sysval{font-size:.7rem;font-family:'JetBrains Mono',monospace;width:60px;text-align:right}\n.hrly{background:var(--s1);border:1px solid var(--b1);border-radius:var(--rad);padding:.85rem}\n.hrly-title{font-size:.73rem;font-weight:700;margin-bottom:.65rem}\n.hrly-bars{display:flex;align-items:flex-end;gap:3px;height:80px}\n.hrly-bar{flex:1;min-width:6px;border-radius:2px 2px 0 0;background:var(--violet);opacity:.7;transition:height .4s;cursor:pointer;position:relative}\n.hrly-bar:hover{opacity:1}\n.hrly-tip{position:absolute;bottom:100%;left:50%;transform:translateX(-50%);background:var(--s3);border:1px solid var(--b1);border-radius:4px;padding:.2rem .4rem;font-size:.6rem;white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .15s}\n.hrly-bar:hover .hrly-tip{opacity:1}\n\n/* ── FILES ── */\n.files{flex:1;display:flex;overflow:hidden}\n.ftree{width:220px;flex-shrink:0;background:var(--s1);border-right:1px solid var(--b1);display:flex;flex-direction:column;overflow:hidden}\n.ftree-top{padding:.6rem .75rem;border-bottom:1px solid var(--b1);display:flex;align-items:center;gap:.4rem}\n.agent-sel{background:var(--s2);border:1px solid var(--b1);border-radius:6px;color:var(--ivory);font-family:'Inter',sans-serif;font-size:.75rem;padding:.3rem .5rem;outline:none;flex:1}\n.ftree-list{flex:1;overflow-y:auto;padding:.4rem}\n.fitem{display:flex;align-items:center;gap:.4rem;padding:.35rem .45rem;border-radius:5px;cursor:pointer;font-size:.75rem;transition:all .15s}\n.fitem:hover{background:rgba(255,255,255,.05)}.fitem.on{background:rgba(124,111,205,.1);color:var(--ivory)}\n.ficon{font-size:.85rem;flex-shrink:0}.fname{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}\n.fedit{flex:1;display:flex;flex-direction:column;overflow:hidden}\n.fedit-top{padding:.55rem .85rem;border-bottom:1px solid var(--b1);display:flex;align-items:center;justify-content:space-between;font-size:.75rem;background:var(--s1);flex-shrink:0}\n.fpath{color:var(--ash);font-family:'JetBrains Mono',monospace;font-size:.7rem}\n.fsave{background:var(--sage);border:none;border-radius:6px;color:#fff;font-family:'Inter',sans-serif;font-size:.73rem;font-weight:600;padding:.28rem .65rem;cursor:pointer}\n.fsave:hover{filter:brightness(1.1)}\n#feditor{flex:1;background:var(--bg);border:none;outline:none;color:var(--ivory);font-family:'JetBrains Mono',monospace;font-size:.78rem;line-height:1.65;padding:1rem;resize:none;overflow-y:auto}\n\n/* ── SETTINGS ── */\n.settings{flex:1;overflow-y:auto;padding:1.25rem;display:flex;flex-direction:column;gap:1.25rem}\n.scard{background:var(--s1);border:1px solid var(--b1);border-radius:var(--rad);padding:1rem}\n.scard-h{font-size:.78rem;font-weight:700;margin-bottom:.85rem;padding-bottom:.5rem;border-bottom:1px solid var(--b1)}\n.srow{display:flex;align-items:center;gap:.75rem;margin-bottom:.65rem}\n.srow-lbl{font-size:.75rem;color:var(--ash);min-width:100px}\n.srow-val{flex:1}\n.sel{width:100%;background:var(--s2);border:1px solid var(--b1);border-radius:6px;color:var(--ivory);font-family:'Inter',sans-serif;font-size:.78rem;padding:.4rem .55rem;outline:none;transition:border-color .2s}\n.sel:focus{border-color:var(--violet)}\n.sinp{width:100%;background:var(--s2);border:1px solid var(--b1);border-radius:6px;color:var(--ivory);font-family:'Inter',sans-serif;font-size:.78rem;padding:.4rem .55rem;outline:none;transition:border-color .2s}\n.sinp:focus{border-color:var(--violet)}\n.stog{display:flex;align-items:center;gap:.5rem;cursor:pointer}\n.tog-track{width:36px;height:20px;background:var(--b1);border-radius:20px;position:relative;transition:background .2s;flex-shrink:0}\n.tog-thumb{width:16px;height:16px;background:#fff;border-radius:50%;position:absolute;top:2px;left:2px;transition:left .2s}\n.tog-track.on{background:var(--violet)}.tog-track.on .tog-thumb{left:18px}\n.plug-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:.6rem}\n.plug{background:var(--s2);border:1px solid var(--b1);border-radius:8px;padding:.65rem;display:flex;flex-direction:column;gap:.4rem}\n.plug-name{font-size:.75rem;font-weight:600;display:flex;align-items:center;gap:.35rem}\n.plug-desc{font-size:.67rem;color:var(--ash);line-height:1.4}\n.cron-list{display:flex;flex-direction:column;gap:.4rem;margin-bottom:.65rem}\n.cronitem{background:var(--s2);border:1px solid var(--b1);border-radius:6px;padding:.45rem .65rem;display:flex;align-items:center;gap:.5rem;font-size:.74rem;font-family:'JetBrains Mono',monospace}\n.cron-del{background:none;border:none;color:var(--ash);cursor:pointer;font-size:.7rem;margin-left:auto}.cron-del:hover{color:var(--ember)}\n.cron-add{display:flex;gap:.4rem;align-items:center}\n.cron-inp{flex:1;background:var(--s2);border:1px solid var(--b1);border-radius:6px;color:var(--ivory);font-family:'JetBrains Mono',monospace;font-size:.73rem;padding:.35rem .55rem;outline:none}.cron-inp:focus{border-color:var(--violet)}\n.sbtn2{background:var(--violet);border:none;border-radius:6px;color:#fff;font-family:'Inter',sans-serif;font-size:.73rem;font-weight:600;padding:.35rem .65rem;cursor:pointer}\n.docs-area{margin-top:.5rem}\n.doc-drop{border:2px dashed var(--b1);border-radius:8px;padding:1.5rem;text-align:center;cursor:pointer;transition:all .2s;font-size:.78rem;color:var(--ash)}\n.doc-drop:hover,.doc-drop.drag{border-color:var(--violet);color:var(--ivory)}\n.doc-list{display:flex;flex-direction:column;gap:.35rem;margin-top:.6rem}\n.docitem{display:flex;align-items:center;gap:.5rem;background:var(--s2);border:1px solid var(--b1);border-radius:6px;padding:.4rem .6rem;font-size:.74rem}\n.doc-name{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}\n.doc-del{background:none;border:none;color:var(--ash);cursor:pointer;font-size:.7rem}.doc-del:hover{color:var(--ember)}\n.search-area{background:var(--s1);border:1px solid var(--b1);border-radius:var(--rad);padding:.75rem;margin-bottom:1rem}\n.srch-row{display:flex;gap:.5rem}\n.srch-inp{flex:1;background:var(--s2);border:1px solid var(--b1);border-radius:7px;color:var(--ivory);font-family:'Inter',sans-serif;font-size:.82rem;padding:.5rem .75rem;outline:none}.srch-inp:focus{border-color:var(--violet)}\n.srch-btn{background:var(--violet);border:none;border-radius:7px;color:#fff;font-family:'Inter',sans-serif;font-size:.78rem;font-weight:600;padding:.5rem .9rem;cursor:pointer}\n.srch-results{margin-top:.75rem;display:flex;flex-direction:column;gap:.4rem}\n.sresult{background:var(--s2);border:1px solid var(--b1);border-radius:6px;padding:.5rem .65rem;font-size:.75rem}\n.sresult-agent{font-size:.67rem;font-weight:600;margin-bottom:.25rem}\n.sresult-text{line-height:1.5;color:var(--ivory);white-space:pre-wrap;word-break:break-word}\n\n/* PINS PANEL */\n.pins-panel{background:var(--s1);border:1px solid var(--b1);border-radius:var(--rad);padding:.75rem;margin-bottom:1rem}\n.pins-list{display:flex;flex-direction:column;gap:.4rem;max-height:200px;overflow-y:auto}\n.pinitem{background:var(--s2);border-left:3px solid var(--gold);border-radius:0 6px 6px 0;padding:.4rem .6rem;font-size:.75rem;display:flex;gap:.5rem;align-items:flex-start}\n.pinitem-text{flex:1;line-height:1.5}.pinitem-del{background:none;border:none;color:var(--ash);cursor:pointer;font-size:.67rem}.pinitem-del:hover{color:var(--ember)}\n\n@media(max-width:640px){.sidebar{display:none}.sprint-board{grid-template-columns:1fr}.agrid{grid-template-columns:repeat(2,1fr)}.ftree{width:160px}}\n</style>\n</head>\n<body>\n\n<!-- LOGIN -->\n<div id=\"login\">\n  <div class=\"lcard\">\n    <div style=\"font-size:2rem\">⚡</div>\n    <h2>Council Room</h2>\n    <p>Enter your access token</p>\n    <input class=\"inp\" type=\"password\" id=\"tkey\" placeholder=\"Token...\" onkeydown=\"if(event.key==='Enter')doLogin()\">\n    <button class=\"btn\" onclick=\"doLogin()\">Enter</button>\n    <div class=\"err\" id=\"lerr\"></div>\n  </div>\n</div>\n\n<!-- APP -->\n<div id=\"app\">\n  <header>\n    <div class=\"hlogo\"><div class=\"hlogo-icon\">⚡</div>Council Room</div>\n    <div class=\"hright\">\n      <div id=\"connPill\" class=\"pill\"><div class=\"dot\" style=\"background:var(--sage);color:var(--sage)\"></div>5 online</div>\n      <button class=\"ibtn\" onclick=\"openPalette()\">⌘K</button>\n      <button class=\"ibtn\" onclick=\"toggleTheme()\">🌗</button>\n    </div>\n  </header>\n  <nav>\n    <button class=\"tab active\" onclick=\"showTab('chat')\" id=\"tab-chat\">💬 Chat</button>\n    <button class=\"tab\" onclick=\"showTab('mc')\" id=\"tab-mc\">🎯 Mission Control</button>\n    <button class=\"tab\" onclick=\"showTab('analytics')\" id=\"tab-analytics\">📊 Analytics</button>\n    <button class=\"tab\" onclick=\"showTab('files')\" id=\"tab-files\">📁 Files</button>\n    <button class=\"tab\" onclick=\"showTab('settings')\" id=\"tab-settings\">⚙️ Settings</button>\n  </nav>\n  <div class=\"panels\">\n\n    <!-- ── CHAT ── -->\n    <div class=\"panel active\" id=\"panel-chat\">\n      <div class=\"chat-layout\">\n        <div class=\"sidebar\">\n          <div class=\"sb-sec\">\n            <div class=\"sb-lbl\">Broadcast</div>\n            <button class=\"ab on\" id=\"btn-council\" onclick=\"setCouncil()\"><div class=\"adot\" style=\"background:var(--gold)\"></div><div><div class=\"aname\" style=\"color:var(--gold)\">@Council</div><div class=\"arole\">All 5 agents</div></div></button>\n          </div>\n          <div class=\"sb-sec\">\n            <div class=\"sb-lbl\">Private</div>\n            <button class=\"ab\" id=\"btn-rafael\" onclick=\"setPrivate('rafael')\"><div class=\"adot\" style=\"background:var(--r)\"></div><div><div class=\"aname\">🧭 Rafael</div><div class=\"arole\">The Guide</div></div></button>\n            <button class=\"ab\" id=\"btn-uriel\" onclick=\"setPrivate('uriel')\"><div class=\"adot\" style=\"background:var(--u)\"></div><div><div class=\"aname\">🔥 Uriel</div><div class=\"arole\">God's Fire</div></div></button>\n            <button class=\"ab\" id=\"btn-michael\" onclick=\"setPrivate('michael')\"><div class=\"adot\" style=\"background:var(--m)\"></div><div><div class=\"aname\">🛡️ Michael</div><div class=\"arole\">Wise Advisor</div></div></button>\n            <button class=\"ab\" id=\"btn-gabriel\" onclick=\"setPrivate('gabriel')\"><div class=\"adot\" style=\"background:var(--g)\"></div><div><div class=\"aname\">📣 Gabriel</div><div class=\"arole\">The Voice</div></div></button>\n            <button class=\"ab\" id=\"btn-raguel\" onclick=\"setPrivate('raguel')\"><div class=\"adot\" style=\"background:var(--rg)\"></div><div><div class=\"aname\">🤝 Raguel</div><div class=\"arole\">The Friend</div></div></button>\n          </div>\n          <div class=\"sb-mem\">\n            <div class=\"sb-lbl2\">🧠 Memory</div>\n            <div class=\"mlist\" id=\"memList\"></div>\n            <div class=\"madd\">\n              <input class=\"minp\" id=\"minp\" placeholder=\"Remember this...\" onkeydown=\"if(event.key==='Enter')addMem()\">\n              <button class=\"msave\" onclick=\"addMem()\">Save</button>\n            </div>\n          </div>\n        </div>\n        <div class=\"chat-main\">\n          <div class=\"modebar\">\n            <div class=\"mtog\">\n              <button class=\"mb ong on\" id=\"mCouncil\" onclick=\"setCouncil()\">⚡ @Council</button>\n              <button class=\"mb\" id=\"mPrivate\" onclick=\"setPrivate(curAgent)\">🔒 Private</button>\n            </div>\n            <span class=\"albl\" id=\"albl\">→ <strong>@Council</strong></span>\n            <button class=\"ibtn rtbtn\" id=\"rtbtn\" onclick=\"startRT()\">🗣️ Roundtable</button>\n            <button class=\"ibtn stopbtn\" id=\"stopbtn\" onclick=\"stopRT()\">⏹ Stop</button>\n          </div>\n          <div class=\"sessbar\" id=\"sessbar\"></div>\n          <div class=\"panes\" id=\"panes\"></div>\n          <div class=\"iarea\">\n            <div class=\"iwrap\">\n              <textarea id=\"inp\" rows=\"1\" placeholder=\"Message the Council... (or /standup /risk-check /pitch-me)\" onkeydown=\"onKey(event)\" oninput=\"autoH(this)\"></textarea>\n              <button class=\"snd cmode\" id=\"snd\" onclick=\"sendMsg()\"><svg width=\"14\" height=\"14\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" viewBox=\"0 0 24 24\"><line x1=\"22\" y1=\"2\" x2=\"11\" y2=\"13\"/><polygon points=\"22 2 15 22 11 13 2 9 22 2\"/></svg></button>\n            </div>\n            <div class=\"ihint\" id=\"ihint\">@Council — all 5 agents respond • /standup /risk-check /pitch-me</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- ── MISSION CONTROL ── -->\n    <div class=\"panel\" id=\"panel-mc\">\n      <div class=\"mc\">\n        <div class=\"mc-grid\">\n          <div class=\"card\">\n            <div class=\"card-title\">⏳ Days to Launch</div>\n            <div class=\"card-val\" id=\"daysLeft\" style=\"color:var(--gold)\">--</div>\n            <div class=\"card-sub\">April 5, 2026</div>\n          </div>\n          <div class=\"card\">\n            <div class=\"card-title\">💰 Monthly Revenue</div>\n            <div style=\"display:flex;align-items:center;gap:.4rem;margin-bottom:.3rem\">\n              <div class=\"card-val\" id=\"revVal\" style=\"color:var(--sage)\">$0</div>\n              <button onclick=\"editRev()\" style=\"background:none;border:none;color:var(--ash);cursor:pointer;font-size:.7rem\">✏️</button>\n            </div>\n            <div class=\"card-sub\">Target: $5,000/mo</div>\n            <div class=\"prog\"><div class=\"progbar\" id=\"revProg\" style=\"background:var(--sage)\"></div></div>\n          </div>\n          <div class=\"card\">\n            <div class=\"card-title\">👥 Bookkeepers</div>\n            <div style=\"display:flex;align-items:center;gap:.4rem;margin-bottom:.3rem\">\n              <div class=\"card-val\" id=\"bkVal\" style=\"color:var(--violet)\">0</div>\n              <button onclick=\"editBk()\" style=\"background:none;border:none;color:var(--ash);cursor:pointer;font-size:.7rem\">✏️</button>\n            </div>\n            <div class=\"card-sub\">Target: 20</div>\n            <div class=\"prog\"><div class=\"progbar\" id=\"bkProg\" style=\"background:var(--violet)\"></div></div>\n          </div>\n          <div class=\"card\">\n            <div class=\"card-title\">🤖 Council Activity</div>\n            <div class=\"card-val\" id=\"tokTotal\" style=\"color:var(--sky)\">0</div>\n            <div class=\"card-sub\">tokens used today</div>\n          </div>\n        </div>\n\n        <div class=\"sprint-board\">\n          <div class=\"col\" id=\"col-todo\" ondragover=\"event.preventDefault()\" ondrop=\"dropTask(event,'todo')\">\n            <div class=\"col-h\" style=\"color:var(--ash)\">📋 Todo <span class=\"col-cnt\" id=\"cnt-todo\">0</span></div>\n            <div id=\"tasks-todo\"></div>\n            <button class=\"task-add\" onclick=\"addTask('todo')\">+ Add task</button>\n          </div>\n          <div class=\"col\" id=\"col-doing\" ondragover=\"event.preventDefault()\" ondrop=\"dropTask(event,'doing')\">\n            <div class=\"col-h\" style=\"color:var(--gold)\">⚡ In Progress <span class=\"col-cnt\" id=\"cnt-doing\">0</span></div>\n            <div id=\"tasks-doing\"></div>\n            <button class=\"task-add\" onclick=\"addTask('doing')\">+ Add task</button>\n          </div>\n          <div class=\"col\" id=\"col-done\" ondragover=\"event.preventDefault()\" ondrop=\"dropTask(event,'done')\">\n            <div class=\"col-h\" style=\"color:var(--sage)\">✅ Done <span class=\"col-cnt\" id=\"cnt-done\">0</span></div>\n            <div id=\"tasks-done\"></div>\n            <button class=\"task-add\" onclick=\"addTask('done')\">+ Add task</button>\n          </div>\n        </div>\n\n        <div class=\"pipe\">\n          <div class=\"pipe-h\">\n            <span class=\"pipe-title\">👥 Bookkeeper Pipeline</span>\n            <button class=\"pipe-add\" onclick=\"addBookkeeper()\">+ Add</button>\n          </div>\n          <table class=\"ptable\">\n            <tr><th>Name</th><th>Status</th><th>Contact</th><th>Notes</th><th></th></tr>\n            <tbody id=\"pipe-body\"></tbody>\n          </table>\n        </div>\n\n        <div class=\"journal\">\n          <div class=\"pipe-h\" style=\"margin-bottom:.5rem\">\n            <span class=\"pipe-title\">📓 Daily Journal</span>\n            <span style=\"font-size:.68rem;color:var(--ash)\" id=\"jdate\"></span>\n          </div>\n          <textarea id=\"journal\" placeholder=\"What happened today? What's on your mind?\" oninput=\"saveJournal()\" rows=\"4\"></textarea>\n        </div>\n      </div>\n    </div>\n\n    <!-- ── ANALYTICS ── -->\n    <div class=\"panel\" id=\"panel-analytics\">\n      <div class=\"an\">\n        <div class=\"search-area\">\n          <div class=\"pipe-title\" style=\"margin-bottom:.5rem\">🔍 Search Conversations</div>\n          <div class=\"srch-row\">\n            <input class=\"srch-inp\" id=\"srchInp\" placeholder=\"Search all agent responses...\" onkeydown=\"if(event.key==='Enter')doSearch()\">\n            <button class=\"srch-btn\" onclick=\"doSearch()\">Search</button>\n          </div>\n          <div class=\"srch-results\" id=\"srchRes\"></div>\n        </div>\n        <div class=\"sys\" id=\"sysCard\">\n          <div class=\"sys-title\">🖥️ VPS Health</div>\n          <div id=\"sysRows\"></div>\n        </div>\n        <div>\n          <div style=\"font-size:.73rem;font-weight:700;margin-bottom:.6rem\">🤖 Token Usage by Agent</div>\n          <div class=\"agrid\" id=\"agentCards\"></div>\n        </div>\n        <div class=\"hrly\">\n          <div class=\"hrly-title\">📈 Hourly Token Activity (last 24h)</div>\n          <div class=\"hrly-bars\" id=\"hrlyBars\"></div>\n        </div>\n        <div class=\"pins-panel\">\n          <div class=\"pipe-h\" style=\"margin-bottom:.5rem\"><span class=\"pipe-title\">📌 Pinned Messages</span></div>\n          <div class=\"pins-list\" id=\"pinsList\"></div>\n        </div>\n      </div>\n    </div>\n\n    <!-- ── FILES ── -->\n    <div class=\"panel\" id=\"panel-files\">\n      <div class=\"files\">\n        <div class=\"ftree\">\n          <div class=\"ftree-top\">\n            <select class=\"agent-sel\" id=\"fileAgent\" onchange=\"loadFiles('')\">\n              <option value=\"michael\">🛡️ Michael</option>\n              <option value=\"rafael\">🧭 Rafael</option>\n              <option value=\"uriel\">🔥 Uriel</option>\n              <option value=\"gabriel\">📣 Gabriel</option>\n              <option value=\"raguel\">🤝 Raguel</option>\n            </select>\n          </div>\n          <div class=\"ftree-list\" id=\"ftreeList\"></div>\n        </div>\n        <div class=\"fedit\">\n          <div class=\"fedit-top\">\n            <span class=\"fpath\" id=\"fpath\">Select a file to edit</span>\n            <div style=\"display:flex;gap:.4rem\">\n              <button class=\"ibtn\" onclick=\"newFile()\" style=\"font-size:.7rem\">+ New</button>\n              <button class=\"fsave\" onclick=\"saveFile()\" id=\"fsaveBtn\" disabled>Save</button>\n            </div>\n          </div>\n          <textarea id=\"feditor\" placeholder=\"Select a file from the sidebar to edit it...\"></textarea>\n        </div>\n      </div>\n    </div>\n\n    <!-- ── SETTINGS ── -->\n    <div class=\"panel\" id=\"panel-settings\">\n      <div class=\"settings\">\n        <div class=\"scard\">\n          <div class=\"scard-h\">🤖 Agent Configuration</div>\n          <div id=\"agentConfigs\"></div>\n        </div>\n        <div class=\"scard\">\n          <div class=\"scard-h\">🔌 Plugins</div>\n          <div class=\"plug-grid\" id=\"plugGrid\"></div>\n        </div>\n        <div class=\"scard\">\n          <div class=\"scard-h\">⏰ Cron Jobs</div>\n          <div class=\"cron-list\" id=\"cronList\"></div>\n          <div class=\"cron-add\">\n            <input class=\"cron-inp\" id=\"cronInp\" placeholder=\"0 8 * * * openclaw agent --agent main --message 'Morning standup'\">\n            <button class=\"sbtn2\" onclick=\"addCron()\">Add</button>\n          </div>\n        </div>\n        <div class=\"scard\">\n          <div class=\"scard-h\">📁 Document Vault</div>\n          <div class=\"docs-area\">\n            <div class=\"doc-drop\" id=\"docDrop\" onclick=\"document.getElementById('docFile').click()\" ondragover=\"event.preventDefault();this.classList.add('drag')\" ondragleave=\"this.classList.remove('drag')\" ondrop=\"dropDoc(event)\">\n              📎 Click or drag files to upload (PDF, CSV, TXT, images)\n            </div>\n            <input type=\"file\" id=\"docFile\" style=\"display:none\" onchange=\"uploadDoc(this.files[0])\" accept=\".pdf,.csv,.txt,.md,.jpg,.png\">\n            <div class=\"doc-list\" id=\"docList\"></div>\n          </div>\n        </div>\n        <div class=\"scard\">\n          <div class=\"scard-h\">🌗 Appearance</div>\n          <div class=\"srow\">\n            <span class=\"srow-lbl\">Language</span>\n            <div class=\"srow-val\">\n              <select class=\"sel\" id=\"langSel\" onchange=\"setLang(this.value)\">\n                <option value=\"en\">English</option>\n                <option value=\"id\">Bahasa Indonesia</option>\n              </select>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<!-- COMMAND PALETTE -->\n<div class=\"cmd-palette\" id=\"cmdpal\" onclick=\"if(event.target===this)closePalette()\">\n  <div class=\"cpal\">\n    <input class=\"cpal-inp\" id=\"cpalInp\" placeholder=\"Type a command...\" oninput=\"filterPal(this.value)\" onkeydown=\"palKey(event)\">\n    <div class=\"cpal-list\" id=\"cpalList\"></div>\n  </div>\n</div>\n\n<script>\nconst API = window.location.origin+'/council-api';\nconst WS_URL = API.replace('https://','wss://').replace('http://','ws://')+'/ws';\nconst AGENTS = {rafael:{name:'Rafael',emoji:'🧭',role:'The Guide',color:'--r'},uriel:{name:'Uriel',emoji:'🔥',role:\"God's Fire\",color:'--u'},michael:{name:'Michael',emoji:'🛡️',role:'Wise Advisor',color:'--m'},gabriel:{name:'Gabriel',emoji:'📣',role:'The Voice',color:'--g'},raguel:{name:'Raguel',emoji:'🤝',role:'The Friend',color:'--rg'}};\nlet token=localStorage.getItem('crt')||'',mode='council',curAgent='rafael',ws=null,thinkEls={};\nlet lastTs=parseInt(localStorage.getItem('crt_lts')||'0');\nlet curFile=null,curFileAgent='michael';\nlet palSel=0,palCmds=[];\n\n// ── BOOT ──\nasync function doLogin(){\n  const t=document.getElementById('tkey').value.trim();if(!t)return;\n  try{const r=await fetch(`${API}/health`,{headers:{'x-council-token':t}});\n    if(r.ok||r.status===200)boot(t);else document.getElementById('lerr').textContent='Invalid token.';}\n  catch{boot(t);}\n}\nfunction boot(t){\n  token=t;localStorage.setItem('crt',t);\n  document.getElementById('login').style.display='none';\n  document.getElementById('app').style.display='flex';\n  connectWS();initSessions();loadMem();loadMC();loadAnalytics();loadFiles('');loadSettings();\n}\nif(token)setTimeout(()=>boot(token),50);\n\n// ── TAB ──\nfunction showTab(id){\n  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));\n  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));\n  document.getElementById('tab-'+id).classList.add('active');\n  document.getElementById('panel-'+id).classList.add('active');\n  if(id==='analytics')loadAnalytics();\n  if(id==='files')loadFiles('');\n  if(id==='settings')loadSettings();\n}\n\n// ── WS ──\nfunction connectWS(){\n  ws=new WebSocket(`${WS_URL}?token=${token}&since=${lastTs}`);\n  ws.onmessage=e=>{\n    const d=JSON.parse(e.data);\n    if(d.type==='replay'){d.events.forEach(ev=>{if(ev.serverTs>lastTs){handleWS(ev);lastTs=ev.serverTs;localStorage.setItem('crt_lts',lastTs);}});}\n    else{handleWS(d);if(d.serverTs){lastTs=d.serverTs;localStorage.setItem('crt_lts',lastTs);}}\n  };\n  ws.onclose=()=>setTimeout(connectWS,3000);\n  ws.onerror=()=>{};\n}\nfunction handleWS(d){\n  const pane=d.pane||(mode==='council'?'council':curAgent);\n  if(d.type==='thinking'){if(!thinkEls[d.agentId])thinkEls[d.agentId]=addThink(pane,d.agentId);}\n  else if(d.type==='response'){\n    rmThink(d.agentId);\n    const m={from:'agent',agentId:d.agentId,text:d.response,ts:Date.now()};\n    addPaneMsg(pane,m);appendMsg(pane,m);scrollPane(pane);\n  }else if(d.type==='council_done'){\n    Object.keys(thinkEls).forEach(rmThink);\n    document.getElementById('snd').disabled=false;\n    document.getElementById('stopbtn').style.display='none';\n    if(mode==='council')document.getElementById('rtbtn').style.display='';\n  }else if(d.type==='error'){\n    Object.keys(thinkEls).forEach(rmThink);\n    document.getElementById('snd').disabled=false;\n  }\n}\n\n// ── SESSIONS ──\nlet sessions=JSON.parse(localStorage.getItem('crt_sess')||'[]'),curSess=null;\nfunction initSessions(){if(!sessions.length)newSess();else switchSess(sessions[sessions.length-1].id);}\nfunction newSess(){const id='s'+Date.now();sessions.push({id,label:'Chat '+(sessions.length+1),panes:{}});saveSess();switchSess(id);}\nfunction switchSess(id){curSess=id;renderSessBar();renderPanes();}\nfunction saveSess(){if(sessions.length>10)sessions=sessions.slice(-10);localStorage.setItem('crt_sess',JSON.stringify(sessions));}\nfunction getSess(){return sessions.find(s=>s.id===curSess);}\nfunction getPaneMsgs(p){return getSess()?.panes?.[p]||[];}\nfunction addPaneMsg(p,m){const s=getSess();if(!s)return;if(!s.panes[p])s.panes[p]=[];s.panes[p].push(m);if(s.panes[p].length>100)s.panes[p]=s.panes[p].slice(-100);saveSess();}\nfunction renderSessBar(){\n  const bar=document.getElementById('sessbar');\n  bar.innerHTML=sessions.map(s=>`<button class=\"sc${s.id===curSess?' on':''}\" onclick=\"switchSess('${s.id}')\">${s.label}</button>`).join('')+'<button class=\"snew\" onclick=\"newSess()\">+ New</button>';\n}\nconst PANES=['council','rafael','uriel','michael','gabriel','raguel'];\nfunction renderPanes(){\n  const wrap=document.getElementById('panes');wrap.innerHTML='';\n  PANES.forEach(id=>{\n    const div=document.createElement('div');div.className='pane';div.id='pane-'+id;\n    const msgs=getPaneMsgs(id);\n    if(!msgs.length){const labels={council:'@Council',rafael:'Rafael',uriel:'Uriel',michael:'Michael',gabriel:'Gabriel',raguel:'Raguel'};div.innerHTML=`<div class=\"empty\"><div class=\"ei\">${id==='council'?'⚡':AGENTS[id]?.emoji}</div><div class=\"et\">${labels[id]}</div><div class=\"es\">Start a conversation</div></div>`;}\n    else msgs.forEach(m=>appendMsg2(div,m));\n    wrap.appendChild(div);\n  });\n  showPane(mode==='council'?'council':curAgent);\n}\nfunction showPane(id){document.querySelectorAll('.pane').forEach(p=>{p.classList.remove('on');p.style.display='none';});const p=document.getElementById('pane-'+id);if(p){p.classList.add('on');p.style.display='flex';p.scrollTop=p.scrollHeight;}}\nfunction scrollPane(id){const p=document.getElementById('pane-'+id);if(p)p.scrollTop=p.scrollHeight;}\n\n// ── MODES ──\nfunction setCouncil(){\n  mode='council';\n  document.querySelectorAll('.ab').forEach(b=>b.classList.remove('on'));\n  document.getElementById('btn-council').classList.add('on');\n  document.getElementById('mCouncil').classList.add('on','ong');\n  document.getElementById('mPrivate').classList.remove('on');\n  document.getElementById('albl').innerHTML='→ <strong>@Council</strong>';\n  document.getElementById('snd').className='snd cmode';\n  document.getElementById('ihint').textContent='@Council — all 5 agents respond • /standup /risk-check /pitch-me';\n  document.getElementById('inp').placeholder='Message the Council...';\n  document.getElementById('rtbtn').style.display='';\n  document.getElementById('stopbtn').style.display='none';\n  showPane('council');\n}\nfunction setPrivate(id){\n  mode='private';curAgent=id;const a=AGENTS[id];\n  document.querySelectorAll('.ab').forEach(b=>b.classList.remove('on'));\n  document.getElementById('btn-'+id)?.classList.add('on');\n  document.getElementById('mPrivate').classList.add('on');\n  document.getElementById('mCouncil').classList.remove('on','ong');\n  document.getElementById('albl').innerHTML=`→ <strong>${a.emoji} ${a.name}</strong>`;\n  document.getElementById('snd').className='snd';\n  document.getElementById('ihint').textContent=`Private — ${a.name} (${a.role})`;\n  document.getElementById('inp').placeholder=`Message ${a.name}...`;\n  document.getElementById('rtbtn').style.display='none';\n  document.getElementById('stopbtn').style.display='none';\n  showPane(id);\n}\n\n// ── SEND ──\nfunction sendMsg(){\n  const el=document.getElementById('inp');let msg=el.value.trim();if(!msg||!ws||ws.readyState!==1)return;\n  // slash commands\n  if(msg==='/standup') msg='Please give me a quick standup: what is each of you focusing on today for DataFlow?';\n  else if(msg==='/risk-check') msg='Michael, please do a risk check: what are the top 3 risks to our DataFloat sprint right now?';\n  else if(msg==='/pitch-me') msg='Gabriel, give me a fresh one-liner pitch for DataFlow.';\n  const pane=mode==='council'?'council':curAgent;\n  const m={from:'user',agentId:null,text:el.value.trim(),ts:Date.now()};\n  addPaneMsg(pane,m);\n  document.getElementById('pane-'+pane)?.querySelector('.empty')?.remove();\n  appendMsg(pane,m);scrollPane(pane);\n  el.value='';el.style.height='auto';\n  document.getElementById('snd').disabled=true;\n  ws.send(JSON.stringify({mode,agentId:curAgent,message:msg,pane,sessionId:curSess}));\n}\nfunction onKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMsg();}}\nfunction autoH(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,100)+'px';}\n\n// ── ROUNDTABLE ──\nfunction startRT(){\n  const el=document.getElementById('inp');const msg=el.value.trim();\n  if(!msg){el.placeholder='⬆️ Type a topic first...';el.focus();setTimeout(()=>el.placeholder='Message the Council...',3000);return;}\n  if(!ws||ws.readyState!==1)return;\n  setCouncil();\n  const m={from:'user',agentId:null,text:'🗣️ Roundtable: '+msg,ts:Date.now()};\n  addPaneMsg('council',m);document.getElementById('pane-council')?.querySelector('.empty')?.remove();\n  appendMsg('council',m);scrollPane('council');\n  el.value='';el.style.height='auto';\n  document.getElementById('snd').disabled=true;\n  document.getElementById('rtbtn').style.display='none';\n  document.getElementById('stopbtn').style.display='';\n  ws.send(JSON.stringify({mode:'roundtable',message:msg,pane:'council',sessionId:curSess}));\n}\nfunction stopRT(){if(ws&&ws.readyState===1)ws.send(JSON.stringify({type:'stop'}));document.getElementById('stopbtn').style.display='none';document.getElementById('rtbtn').style.display='';document.getElementById('snd').disabled=false;}\n\n// ── RENDER MESSAGES ──\nfunction tnow(){return new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'});}\nfunction tfmt(ts){return ts?new Date(ts).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}):tnow();}\nfunction fmt(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\\*\\*(.*?)\\*\\*/g,'<strong>$1</strong>').replace(/__(.*?)__/g,'<strong>$1</strong>').replace(/\\*(.*?)\\*/g,'<em>$1</em>').replace(/`(.*?)`/g,'<code>$1</code>').replace(/\\n/g,'<br>');}\nfunction makeMsgEl(m){\n  const isU=m.from==='user';const a=m.agentId?AGENTS[m.agentId]:null;\n  const cv=m.agentId?`var(${AGENTS[m.agentId]?.color||'--violet'})`:'var(--gold)';\n  const name=isU?'Lucy':(a?`${a.emoji} ${a.name}`:'⚡ Council');\n  const d=document.createElement('div');d.className='msg'+(isU?' me':'');\n  if(!isU)d.style.borderLeft=`2px solid ${cv}`;\n  const pinBtn=isU?'':` <button class=\"mpin\" onclick=\"pinMsg('${m.agentId||''}','${(m.text||'').replace(/'/g,'&apos;').substring(0,200)}',${m.ts||0})\" title=\"Pin\">📌</button>`;\n  d.innerHTML=`<div class=\"ava\">${isU?'👤':(a?.emoji||'⚡')}</div><div class=\"mbody\"><div class=\"mmeta\"><span class=\"mname\" style=\"color:${cv}\">${name}</span><span class=\"mtime\">${tfmt(m.ts)}</span>${pinBtn}</div><div class=\"bub\">${fmt(m.text||'')}</div></div>`;\n  return d;\n}\nfunction appendMsg(pane,m){appendMsg2(document.getElementById('pane-'+pane),m);}\nfunction appendMsg2(p,m){if(!p)return;p.appendChild(makeMsgEl(m));}\nfunction addThink(pane,agentId){\n  const p=document.getElementById('pane-'+pane);if(!p)return null;\n  const a=AGENTS[agentId];const cv=`var(${a?.color||'--violet'})`;\n  const d=document.createElement('div');d.className='think';d.id='th-'+agentId;d.style.color=cv;\n  d.innerHTML=`${a?.emoji||'⚡'} <span style=\"font-weight:500\">${a?.name||'?'}</span> is thinking <div class=\"dots\"><span></span><span></span><span></span></div>`;\n  p.appendChild(d);p.scrollTop=p.scrollHeight;return d;\n}\nfunction rmThink(id){document.getElementById('th-'+id)?.remove();delete thinkEls[id];}\n\n// ── MEMORY ──\nlet memFacts=[];\nasync function loadMem(){try{const r=await fetch(`${API}/memory`,{headers:{'x-council-token':token}});if(r.ok){const d=await r.json();memFacts=d.facts||[];renderMem();}}catch{}}\nasync function addMem(){const el=document.getElementById('minp');const f=el.value.trim();if(!f)return;await fetch(`${API}/memory`,{method:'POST',headers:{'x-council-token':token,'content-type':'application/json'},body:JSON.stringify({fact:f})});el.value='';loadMem();}\nasync function delMem(i){await fetch(`${API}/memory/${i}`,{method:'DELETE',headers:{'x-council-token':token}});loadMem();}\nfunction renderMem(){const el=document.getElementById('memList');if(!el)return;el.innerHTML=memFacts.length?memFacts.map((f,i)=>`<div class=\"mitem\"><span class=\"mtext\">${f.fact}</span><button class=\"mdel\" onclick=\"delMem(${i})\">✕</button></div>`).join(''):'<div style=\"font-size:.68rem;color:var(--ash);padding:.2rem .4rem\">No memories yet</div>';}\n\n// ── PINS ──\nasync function pinMsg(agentId,text,ts){await fetch(`${API}/pins`,{method:'POST',headers:{'x-council-token':token,'content-type':'application/json'},body:JSON.stringify({agentId,text,ts})});}\nasync function loadPins(){try{const r=await fetch(`${API}/pins`,{headers:{'x-council-token':token}});if(r.ok){const d=await r.json();renderPins(d.pins||[]);}}catch{}}\nasync function delPin(i){await fetch(`${API}/pins/${i}`,{method:'DELETE',headers:{'x-council-token':token}});loadPins();}\nfunction renderPins(pins){const el=document.getElementById('pinsList');if(!el)return;el.innerHTML=pins.length?pins.map((p,i)=>`<div class=\"pinitem\"><div class=\"pinitem-text\"><strong style=\"color:var(${AGENTS[p.agentId]?.color||'--gold'})\">${AGENTS[p.agentId]?.emoji||'⚡'} ${AGENTS[p.agentId]?.name||'Council'}</strong><br>${p.text.substring(0,120)}${p.text.length>120?'...':''}</div><button class=\"pinitem-del\" onclick=\"delPin(${i})\">✕</button></div>`).join(''):'<div style=\"font-size:.72rem;color:var(--ash)\">No pinned messages yet</div>';}\n\n// ── MISSION CONTROL ──\nfunction loadMC(){\n  // Countdown\n  const diff=Math.max(0,Math.ceil((new Date('2026-04-05')-new Date())/86400000));\n  document.getElementById('daysLeft').textContent=diff;\n  // Revenue\n  const rev=parseInt(localStorage.getItem('mc_rev')||'0');\n  document.getElementById('revVal').textContent='$'+rev.toLocaleString();\n  document.getElementById('revProg').style.width=Math.min(100,rev/50)+'%';\n  // Bookkeepers\n  const bk=parseInt(localStorage.getItem('mc_bk')||'0');\n  document.getElementById('bkVal').textContent=bk;\n  document.getElementById('bkProg').style.width=Math.min(100,bk/20*100)+'%';\n  // Journal\n  const today=new Date().toLocaleDateString('en-CA');\n  document.getElementById('jdate').textContent=today;\n  document.getElementById('journal').value=localStorage.getItem('journal_'+today)||'';\n  // Sprint board\n  renderTasks();\n  // Pipeline\n  renderPipeline();\n}\nfunction editRev(){const v=prompt('Current monthly revenue ($):',localStorage.getItem('mc_rev')||'0');if(v!==null){localStorage.setItem('mc_rev',parseInt(v)||0);loadMC();}}\nfunction editBk(){const v=prompt('Bookkeepers committed:',localStorage.getItem('mc_bk')||'0');if(v!==null){localStorage.setItem('mc_bk',parseInt(v)||0);loadMC();}}\nfunction saveJournal(){const today=new Date().toLocaleDateString('en-CA');localStorage.setItem('journal_'+today,document.getElementById('journal').value);}\n\n// Sprint board\nlet tasks=JSON.parse(localStorage.getItem('mc_tasks')||'{\"todo\":[],\"doing\":[],\"done\":[]}');\nfunction saveTasks(){localStorage.setItem('mc_tasks',JSON.stringify(tasks));}\nfunction renderTasks(){\n  ['todo','doing','done'].forEach(col=>{\n    const el=document.getElementById('tasks-'+col);\n    el.innerHTML=tasks[col].map((t,i)=>`<div class=\"task\" draggable=\"true\" ondragstart=\"dragTask(event,'${col}',${i})\">${t}<button class=\"task-del\" onclick=\"delTask('${col}',${i})\">✕</button></div>`).join('');\n    document.getElementById('cnt-'+col).textContent=tasks[col].length;\n  });\n}\nfunction addTask(col){const t=prompt('Task:');if(t){tasks[col].push(t);saveTasks();renderTasks();}}\nfunction delTask(col,i){tasks[col].splice(i,1);saveTasks();renderTasks();}\nlet dragSrc=null,dragI=null;\nfunction dragTask(e,col,i){dragSrc=col;dragI=i;e.currentTarget.classList.add('dragging');}\nfunction dropTask(e,col){e.preventDefault();if(dragSrc&&dragI!==null){const t=tasks[dragSrc].splice(dragI,1)[0];tasks[col].push(t);saveTasks();renderTasks();dragSrc=null;dragI=null;}}\n\n// Pipeline\nlet pipeline=JSON.parse(localStorage.getItem('mc_pipeline')||'[]');\nfunction savePipeline(){localStorage.setItem('mc_pipeline',JSON.stringify(pipeline));}\nfunction addBookkeeper(){const n=prompt('Name:');if(!n)return;const c=prompt('Contact:');pipeline.push({name:n,contact:c||'',status:'lead',notes:''});savePipeline();renderPipeline();}\nfunction delBK(i){pipeline.splice(i,1);savePipeline();renderPipeline();}\nfunction setBKStatus(i,v){pipeline[i].status=v;savePipeline();renderPipeline();}\nfunction renderPipeline(){\n  const el=document.getElementById('pipe-body');if(!el)return;\n  const st={lead:'ps-lead',con:'ps-con',pay:'ps-pay'};const sl={lead:'Lead',con:'Committed',pay:'Paid'};\n  el.innerHTML=pipeline.map((p,i)=>`<tr><td>${p.name}</td><td><select class=\"pstatus ${st[p.status]||'ps-lead'}\" onchange=\"setBKStatus(${i},this.value)\">${Object.keys(sl).map(k=>`<option value=\"${k}\"${p.status===k?' selected':''}>${sl[k]}</option>`).join('')}</select></td><td>${p.contact}</td><td>${p.notes}</td><td><button style=\"background:none;border:none;color:var(--ash);cursor:pointer;font-size:.7rem\" onclick=\"delBK(${i})\">✕</button></td></tr>`).join('')||'<tr><td colspan=\"5\" style=\"color:var(--ash);font-size:.73rem;padding:.5rem\">No bookkeepers yet — add the first one!</td></tr>';\n}\n\n// ── ANALYTICS ──\nasync function loadAnalytics(){\n  loadPins();\n  try{\n    const [sys,tok]=await Promise.all([\n      fetch(`${API}/system`,{headers:{'x-council-token':token}}).then(r=>r.json()),\n      fetch(`${API}/tokens`,{headers:{'x-council-token':token}}).then(r=>r.json()),\n    ]);\n    renderSys(sys);renderTok(tok);\n  }catch(e){}\n}\nfunction renderSys(s){\n  const el=document.getElementById('sysRows');if(!el||s.error)return;\n  const mb=v=>Math.round(v/1024/1024);\n  const gb=v=>(v/1024/1024/1024).toFixed(1);\n  const memPct=Math.round((s.memory?.used||0)/(s.memory?.total||1)*100);\n  const diskPct=Math.round((s.disk?.used||0)/(s.disk?.total||1)*100);\n  const cpuPct=Math.min(100,Math.round((s.cpu?.load1||0)/4*100));\n  const uptH=Math.floor((s.uptime||0)/3600);\n  el.innerHTML=`\n    <div class=\"sysrow\"><span class=\"sysrow-lbl\">CPU</span><div class=\"sysbar\"><div style=\"width:${cpuPct}%;background:${cpuPct>80?'var(--ember)':cpuPct>60?'var(--gold)':'var(--sage)'}\"></div></div><span class=\"sysval\">${cpuPct}%</span></div>\n    <div class=\"sysrow\"><span class=\"sysrow-lbl\">RAM</span><div class=\"sysbar\"><div style=\"width:${memPct}%;background:${memPct>80?'var(--ember)':memPct>60?'var(--gold)':'var(--violet)'}\"></div></div><span class=\"sysval\">${mb(s.memory?.used)}/${mb(s.memory?.total)} MB</span></div>\n    <div class=\"sysrow\"><span class=\"sysrow-lbl\">Disk</span><div class=\"sysbar\"><div style=\"width:${diskPct}%;background:${diskPct>80?'var(--ember)':'var(--sky)'}\"></div></div><span class=\"sysval\">${gb(s.disk?.used)}/${gb(s.disk?.total)} GB</span></div>\n    <div style=\"font-size:.68rem;color:var(--ash);margin-top:.3rem\">Uptime: ${uptH}h • Load: ${s.cpu?.load1} / ${s.cpu?.load5} / ${s.cpu?.load15}</div>`;\n}\nfunction renderTok(d){\n  // today's total\n  const today=new Date().toISOString().slice(0,10);\n  const todayH=d.hourly?.filter(h=>h.hour.startsWith(today))||[];\n  const todayTok=todayH.reduce((a,h)=>a+h.tokens,0);\n  document.getElementById('tokTotal').textContent=todayTok.toLocaleString();\n\n  const agents=d.agents||{};const maxTok=Math.max(1,...Object.values(agents).map(a=>a.total));\n  const COST_PER_1K=0.003;\n  const el=document.getElementById('agentCards');if(!el)return;\n  el.innerHTML=Object.entries(AGENTS).map(([id,a])=>{\n    const ag=agents[id]||{total:0};const pct=Math.round(ag.total/maxTok*100);\n    const cost=(ag.total/1000*COST_PER_1K).toFixed(3);\n    return `<div class=\"acard\"><div class=\"acard-name\"><span>${a.emoji}</span>${a.name}</div><div class=\"acard-tok\" style=\"color:var(${a.color})\">${(ag.total||0).toLocaleString()}</div><div class=\"acard-sub\">~$${cost} • ${ag.sessions||0} msgs</div><div class=\"acard-bar\"><div style=\"width:${pct}%;background:var(${a.color})\"></div></div></div>`;\n  }).join('');\n\n  // hourly bars\n  const last24=Array.from({length:24},(_,i)=>{const d=new Date();d.setHours(d.getHours()-23+i);return d.toISOString().slice(0,13);});\n  const maxH=Math.max(1,...last24.map(h=>d.hourly?.find(x=>x.hour===h)?.tokens||0));\n  const bars=document.getElementById('hrlyBars');if(!bars)return;\n  bars.innerHTML=last24.map(h=>{const hd=d.hourly?.find(x=>x.hour===h);const tok=hd?.tokens||0;const pct=Math.round(tok/maxH*100);const lbl=h.slice(11)+':00';return `<div class=\"hrly-bar\" style=\"height:${Math.max(4,pct)}%\"><div class=\"hrly-tip\">${lbl}<br>${tok} tok</div></div>`;}).join('');\n}\n\n// ── SEARCH ──\nasync function doSearch(){\n  const q=document.getElementById('srchInp').value.trim();if(!q)return;\n  const r=await fetch(`${API}/search?q=${encodeURIComponent(q)}`,{headers:{'x-council-token':token}});\n  const d=await r.json();\n  const el=document.getElementById('srchRes');\n  el.innerHTML=d.results?.length?d.results.slice(-20).reverse().map(e=>`<div class=\"sresult\"><div class=\"sresult-agent\" style=\"color:var(${AGENTS[e.agentId]?.color||'--violet'})\">${AGENTS[e.agentId]?.emoji||'⚡'} ${AGENTS[e.agentId]?.name||e.agentId}</div><div class=\"sresult-text\">${fmt(e.response?.substring(0,300)||'')}</div></div>`).join(''):'<div style=\"font-size:.74rem;color:var(--ash);padding:.3rem\">No results</div>';\n}\n\n// ── FILES ──\nasync function loadFiles(relPath){\n  const agent=document.getElementById('fileAgent')?.value||'michael';\n  try{\n    const r=await fetch(`${API}/files?agent=${agent}&path=${encodeURIComponent(relPath)}`,{headers:{'x-council-token':token}});\n    const d=await r.json();\n    const el=document.getElementById('ftreeList');if(!el)return;\n    el.innerHTML=d.items?.map(f=>`<div class=\"fitem${curFile===f.path?' on':''}\" onclick=\"${f.isDir?`loadFiles('${relPath?relPath+'/':''}${f.name}')`:` openFile('${relPath?relPath+'/':''}${f.name}')`}\"><span class=\"ficon\">${f.isDir?'📁':getIcon(f.name)}</span><span class=\"fname\">${f.name}</span></div>`).join('')||'';\n  }catch{}\n}\nfunction getIcon(n){const e=n.split('.').pop();return {md:'📝',json:'📋',js:'📜',sh:'🔧',txt:'📄',html:'🌐',css:'🎨',py:'🐍'}[e]||'📄';}\nasync function openFile(relPath){\n  const agent=document.getElementById('fileAgent')?.value||'michael';\n  curFile=relPath;curFileAgent=agent;\n  try{\n    const r=await fetch(`${API}/file?agent=${agent}&path=${encodeURIComponent(relPath)}`,{headers:{'x-council-token':token}});\n    const d=await r.json();\n    document.getElementById('feditor').value=d.content||'';\n    document.getElementById('fpath').textContent=relPath;\n    document.getElementById('fsaveBtn').disabled=false;\n    loadFiles(relPath.includes('/')?relPath.split('/').slice(0,-1).join('/'):'');\n  }catch{}\n}\nasync function saveFile(){\n  if(!curFile)return;\n  const content=document.getElementById('feditor').value;\n  await fetch(`${API}/file`,{method:'POST',headers:{'x-council-token':token,'content-type':'application/json'},body:JSON.stringify({agent:curFileAgent,path:curFile,content})});\n  document.getElementById('fsaveBtn').textContent='Saved ✓';setTimeout(()=>document.getElementById('fsaveBtn').textContent='Save',1500);\n}\nfunction newFile(){const n=prompt('Filename (e.g. notes.md):');if(n){curFile=n;document.getElementById('feditor').value='';document.getElementById('fpath').textContent=n;document.getElementById('fsaveBtn').disabled=false;}}\n\n// ── SETTINGS ──\nasync function loadSettings(){\n  loadDocs();loadCron();loadAgentConfigs();loadPlugins();\n}\nasync function loadAgentConfigs(){\n  const el=document.getElementById('agentConfigs');if(!el)return;\n  const models=['amazon-bedrock/us.anthropic.claude-sonnet-4-6','amazon-bedrock/us.anthropic.claude-haiku-4-5','anthropic/claude-3-5-sonnet','openai/gpt-4o','openai/gpt-4o-mini'];\n  el.innerHTML=Object.entries(AGENTS).map(([id,a])=>`\n    <div class=\"srow\">\n      <span class=\"srow-lbl\">${a.emoji} ${a.name}</span>\n      <div class=\"srow-val\" style=\"display:flex;gap:.4rem;align-items:center\">\n        <select class=\"sel\" id=\"model-${id}\">${models.map(m=>`<option value=\"${m}\"${m.includes('sonnet-4-6')?` selected`:''} >${m.split('/').pop()}</option>`).join('')}</select>\n        <button class=\"ibtn\" onclick=\"restartAgent('${id}')\">↺ Restart</button>\n      </div>\n    </div>`).join('');\n}\nasync function restartAgent(id){if(confirm(`Restart ${AGENTS[id].name}?`)){alert(`${AGENTS[id].name} restart requested (manual restart needed via CLI).`);}}\nfunction loadPlugins(){\n  const el=document.getElementById('plugGrid');if(!el)return;\n  const plugs=[{name:'Telegram',emoji:'📱',desc:'Telegram bot messages',on:true},{name:'Discord',emoji:'💬',desc:'Discord integration',on:false},{name:'WhatsApp',emoji:'💚',desc:'WhatsApp Business',on:false},{name:'Slack',emoji:'🔷',desc:'Slack workspace',on:false},{name:'Email',emoji:'📧',desc:'Email via himalaya',on:false},{name:'Calendar',emoji:'📅',desc:'Google Calendar',on:false}];\n  el.innerHTML=plugs.map(p=>`<div class=\"plug\"><div class=\"plug-name\">${p.emoji} ${p.name}</div><div class=\"plug-desc\">${p.desc}</div><label class=\"stog\"><div class=\"tog-track${p.on?' on':''}\" onclick=\"this.classList.toggle('on')\"><div class=\"tog-thumb\"></div></div><span style=\"font-size:.7rem;color:var(--ash)\">${p.on?'Active':'Off'}</span></label></div>`).join('');\n}\nasync function loadCron(){\n  try{const r=await fetch(`${API}/cron`,{headers:{'x-council-token':token}});const d=await r.json();renderCron(d.cron||'');}catch{renderCron('');}\n}\nfunction renderCron(raw){\n  const el=document.getElementById('cronList');if(!el)return;\n  const lines=raw.trim().split('\\n').filter(l=>l.trim()&&!l.startsWith('#'));\n  el.innerHTML=lines.length?lines.map((l,i)=>`<div class=\"cronitem\">${l}<button class=\"cron-del\" onclick=\"delCron(${i})\">✕</button></div>`).join(''):'<div style=\"font-size:.72rem;color:var(--ash)\">No cron jobs</div>';\n}\nasync function addCron(){const v=document.getElementById('cronInp').value.trim();if(!v)return;await fetch(`${API}/cron`,{method:'POST',headers:{'x-council-token':token,'content-type':'application/json'},body:JSON.stringify({entry:v})});document.getElementById('cronInp').value='';loadCron();}\nasync function delCron(i){try{const r=await fetch(`${API}/cron`,{headers:{'x-council-token':token}});const d=await r.json();const lines=d.cron.trim().split('\\n').filter(l=>l.trim()&&!l.startsWith('#'));lines.splice(i,1);await fetch(`${API}/cron`,{method:'POST',headers:{'x-council-token':token,'content-type':'application/json'},body:JSON.stringify({entry:lines.join('\\n')})});}catch{}loadCron();}\n\nasync function loadDocs(){\n  try{const r=await fetch(`${API}/docs`,{headers:{'x-council-token':token}});const d=await r.json();renderDocs(d.docs||[]);}catch{renderDocs([]);}\n}\nfunction renderDocs(docs){const el=document.getElementById('docList');if(!el)return;el.innerHTML=docs.map(d=>`<div class=\"docitem\"><span class=\"doc-name\">📎 ${d.name.replace(/^\\d+_/,'')}</span><span style=\"font-size:.67rem;color:var(--ash)\">${(d.size/1024).toFixed(1)}KB</span><button class=\"doc-del\" onclick=\"delDoc('${d.name}')\">✕</button></div>`).join('');}\nasync function uploadDoc(file){if(!file)return;const fd=new FormData();fd.append('file',file);await fetch(`${API}/docs/upload`,{method:'POST',headers:{'x-council-token':token},body:fd});loadDocs();}\nfunction dropDoc(e){e.preventDefault();document.getElementById('docDrop').classList.remove('drag');const f=e.dataTransfer.files[0];if(f)uploadDoc(f);}\nasync function delDoc(name){await fetch(`${API}/docs/${encodeURIComponent(name)}`,{method:'DELETE',headers:{'x-council-token':token}});loadDocs();}\n\n// ── COMMAND PALETTE ──\nconst cmds=[\n  {icon:'⚡',label:'@Council',desc:'Message all agents',fn:()=>setCouncil()},\n  {icon:'🗣️',label:'Roundtable',desc:'Start a roundtable',fn:()=>{setCouncil();document.getElementById('inp').focus();}},\n  {icon:'📊',label:'Mission Control',desc:'View sprint & metrics',fn:()=>showTab('mc')},\n  {icon:'📁',label:'Files',desc:'Browse agent workspaces',fn:()=>showTab('files')},\n  {icon:'⚙️',label:'Settings',desc:'Configure agents & plugins',fn:()=>showTab('settings')},\n  {icon:'📈',label:'Analytics',desc:'Token usage & VPS health',fn:()=>showTab('analytics')},\n  {icon:'🧭',label:'Chat with Rafael',desc:'Private — The Guide',fn:()=>setPrivate('rafael')},\n  {icon:'🔥',label:'Chat with Uriel',desc:'Private — God\\'s Fire',fn:()=>setPrivate('uriel')},\n  {icon:'🛡️',label:'Chat with Michael',desc:'Private — Wise Advisor',fn:()=>setPrivate('michael')},\n  {icon:'📣',label:'Chat with Gabriel',desc:'Private — The Voice',fn:()=>setPrivate('gabriel')},\n  {icon:'🤝',label:'Chat with Raguel',desc:'Private — The Friend',fn:()=>setPrivate('raguel')},\n  {icon:'📋',label:'/standup',desc:'Daily standup from all agents',fn:()=>{document.getElementById('inp').value='/standup';sendMsg();}},\n  {icon:'⚠️',label:'/risk-check',desc:'Michael audits the sprint',fn:()=>{document.getElementById('inp').value='/risk-check';sendMsg();}},\n  {icon:'📣',label:'/pitch-me',desc:'Gabriel writes a pitch',fn:()=>{document.getElementById('inp').value='/pitch-me';sendMsg();}},\n  {icon:'➕',label:'New Chat',desc:'Start a fresh session',fn:()=>newSess()},\n  {icon:'🌗',label:'Toggle Theme',desc:'Dark/light mode',fn:()=>toggleTheme()},\n];\nfunction openPalette(){palCmds=[...cmds];palSel=0;document.getElementById('cmdpal').classList.add('open');document.getElementById('cpalInp').value='';renderPal(palCmds);setTimeout(()=>document.getElementById('cpalInp').focus(),50);}\nfunction closePalette(){document.getElementById('cmdpal').classList.remove('open');}\nfunction filterPal(q){palCmds=q?cmds.filter(c=>c.label.toLowerCase().includes(q.toLowerCase())||c.desc.toLowerCase().includes(q.toLowerCase())):cmds;palSel=0;renderPal(palCmds);}\nfunction renderPal(cs){document.getElementById('cpalList').innerHTML=cs.map((c,i)=>`<div class=\"cpal-item${i===palSel?' sel':''}\" onclick=\"runCmd(${i})\"><span class=\"cpal-icon\">${c.icon}</span><div><div class=\"cpal-label\">${c.label}</div><div class=\"cpal-desc\">${c.desc}</div></div></div>`).join('');}\nfunction runCmd(i){palCmds[i]?.fn();closePalette();}\nfunction palKey(e){if(e.key==='ArrowDown'){palSel=Math.min(palSel+1,palCmds.length-1);renderPal(palCmds);}else if(e.key==='ArrowUp'){palSel=Math.max(palSel-1,0);renderPal(palCmds);}else if(e.key==='Enter'){runCmd(palSel);}else if(e.key==='Escape')closePalette();}\ndocument.addEventListener('keydown',e=>{if((e.metaKey||e.ctrlKey)&&e.key==='k'){e.preventDefault();openPalette();}});\n\n// ── THEME ──\nlet lightMode=localStorage.getItem('theme')==='light';\nfunction toggleTheme(){lightMode=!lightMode;localStorage.setItem('theme',lightMode?'light':'dark');applyTheme();}\nfunction applyTheme(){if(lightMode){document.documentElement.style.setProperty('--bg','#F4F4F8');document.documentElement.style.setProperty('--s1','#FFFFFF');document.documentElement.style.setProperty('--s2','#F0F0F5');document.documentElement.style.setProperty('--s3','#E8E8EF');document.documentElement.style.setProperty('--b1','#DDDDE8');document.documentElement.style.setProperty('--ivory','#1A1A2E');document.documentElement.style.setProperty('--ash','#6060A0');}else{document.documentElement.style.setProperty('--bg','#0A0A0F');document.documentElement.style.setProperty('--s1','#13131A');document.documentElement.style.setProperty('--s2','#1C1C27');document.documentElement.style.setProperty('--s3','#252535');document.documentElement.style.setProperty('--b1','#2E2E3E');document.documentElement.style.setProperty('--ivory','#F0EDE8');document.documentElement.style.setProperty('--ash','#7A7A8C');}}\napplyTheme();\n\n// ── LANGUAGE ──\nconst STRINGS={en:{chatPlaceholder:'Message the Council...',hint:'@Council — all 5 agents respond • /standup /risk-check /pitch-me'},id:{chatPlaceholder:'Pesan ke Dewan...',hint:'@Council — semua 5 agen merespons • /standup /risk-check /pitch-me'}};\nfunction setLang(l){localStorage.setItem('lang',l);const s=STRINGS[l]||STRINGS.en;document.getElementById('inp').placeholder=s.chatPlaceholder;document.getElementById('ihint').textContent=s.hint;}\nconst savedLang=localStorage.getItem('lang')||'en';if(document.getElementById('langSel'))document.getElementById('langSel').value=savedLang;setLang(savedLang);\n</script>\n</body>\n</html>\n"}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-sonnet-4-6","usage":{"input":1,"output":24986,"cacheRead":52747,"cacheWrite":5154,"totalTokens":82888,"cost":{"input":0.000003,"output":0.37479,"cacheRead":0.0158241,"cacheWrite":0.0193275,"total":0.4099446}},"stopReason":"toolUse","timestamp":1772985366430}}
