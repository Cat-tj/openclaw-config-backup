{"type":"message","id":"bc577bcc","parentId":"0e86b927","timestamp":"2026-03-08T15:26:31.415Z","message":{"role":"assistant","content":[{"type":"text","text":"Now update the frontend with pane-tagging fix + memory feature:"},{"type":"toolCall","id":"tooluse_uiaK3teQ6MWldl93BNO1Rj","name":"exec","arguments":{"command":"cat > ~/council-room/frontend/index.html << 'HTMLEOF'\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Council Room</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400&display=swap\" rel=\"stylesheet\">\n<style>\n*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}\n:root{--bg:#0A0A0F;--surface:#13131A;--panel:#1C1C27;--border:#2E2E3E;--gold:#C9A84C;--violet:#7C6FCD;--ivory:#F0EDE8;--ash:#7A7A8C;--sage:#4CAF82;--ember:#E05C5C;--rafael:#7C6FCD;--uriel:#C9A84C;--michael:#4CAF82;--gabriel:#E05C5C;--raguel:#7A8FCD}\nbody{background:var(--bg);color:var(--ivory);font-family:'Inter',sans-serif;height:100vh;display:flex;flex-direction:column;overflow:hidden}\n#loginScreen{position:fixed;inset:0;z-index:100;background:var(--bg);display:flex;align-items:center;justify-content:center}\n.lcard{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:2.5rem;width:320px;text-align:center}\n.llogo{font-size:2.5rem;margin-bottom:.6rem}.ltitle{font-size:1.2rem;font-weight:700;margin-bottom:.25rem}.lsub{font-size:.78rem;color:var(--ash);margin-bottom:1.25rem}\n.linput{width:100%;padding:.7rem 1rem;background:var(--panel);border:1px solid var(--border);border-radius:8px;color:var(--ivory);font-family:'JetBrains Mono',monospace;font-size:.85rem;outline:none;margin-bottom:.75rem;transition:border-color .2s}.linput:focus{border-color:var(--violet)}\n.lbtn{width:100%;padding:.7rem;background:var(--violet);border:none;border-radius:8px;color:#fff;font-family:'Inter',sans-serif;font-weight:600;font-size:.88rem;cursor:pointer}.lbtn:hover{background:#9f8fe0}\n.lerr{color:var(--ember);font-size:.75rem;margin-top:.5rem}\n#app{display:none;flex-direction:column;height:100vh}\nheader{background:rgba(19,19,26,.97);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:0 1rem;height:52px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}\n.logo{display:flex;align-items:center;gap:.5rem;font-weight:700;font-size:.95rem}\n.logo-icon{width:26px;height:26px;background:linear-gradient(135deg,var(--violet),var(--gold));border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:12px}\n.hbtns{display:flex;align-items:center;gap:.5rem}\n.sbadge{display:flex;align-items:center;gap:.35rem;font-size:.7rem;color:var(--ash);background:var(--panel);border:1px solid var(--border);padding:.25rem .6rem;border-radius:20px}\n.dot{width:6px;height:6px;border-radius:50%;background:var(--sage);animation:pulse 2s infinite}\n@keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(76,175,130,.4)}50%{opacity:.7;box-shadow:0 0 0 4px rgba(76,175,130,0)}}\n.icon-btn{background:none;border:1px solid var(--border);border-radius:7px;color:var(--ash);cursor:pointer;padding:.3rem .55rem;font-size:.78rem;transition:all .15s;font-family:'Inter',sans-serif}.icon-btn:hover{border-color:var(--violet);color:var(--ivory)}\n.layout{display:flex;flex:1;overflow:hidden}\n.sidebar{width:200px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);overflow-y:auto;display:flex;flex-direction:column}\n.sb-section{padding:.75rem .6rem .4rem}\n.sb-label{font-size:.62rem;font-weight:700;color:var(--ash);text-transform:uppercase;letter-spacing:.1em;padding:0 .4rem;margin-bottom:.35rem}\n.ab{display:flex;align-items:center;gap:.55rem;width:100%;padding:.55rem .65rem;background:none;border:none;border-radius:7px;color:var(--ash);cursor:pointer;font-family:'Inter',sans-serif;font-size:.8rem;text-align:left;transition:all .15s;margin-bottom:2px}\n.ab:hover{background:rgba(255,255,255,.05);color:var(--ivory)}.ab.active{background:rgba(124,111,205,.12);color:var(--ivory)}\n.adot{width:7px;height:7px;border-radius:50%;flex-shrink:0}.aname{font-weight:500;font-size:.8rem;line-height:1.2}.arole{font-size:.65rem;color:var(--ash)}\n.sb-memory{padding:.75rem .6rem;border-top:1px solid var(--border);margin-top:auto}\n.mem-title{font-size:.62rem;font-weight:700;color:var(--ash);text-transform:uppercase;letter-spacing:.1em;padding:0 .4rem;margin-bottom:.5rem}\n.mem-list{display:flex;flex-direction:column;gap:.3rem;max-height:160px;overflow-y:auto;margin-bottom:.5rem}\n.mem-item{display:flex;align-items:flex-start;gap:.3rem;padding:.3rem .4rem;background:rgba(201,168,76,.06);border:1px solid rgba(201,168,76,.12);border-radius:6px;font-size:.72rem;color:var(--ivory)}\n.mem-text{flex:1;line-height:1.4}.mem-del{background:none;border:none;color:var(--ash);cursor:pointer;font-size:10px;flex-shrink:0;padding:1px 3px;border-radius:3px;transition:color .15s}.mem-del:hover{color:var(--ember)}\n.mem-input-wrap{display:flex;gap:.3rem}\n.mem-input{flex:1;background:var(--panel);border:1px solid var(--border);border-radius:6px;padding:.35rem .5rem;color:var(--ivory);font-family:'Inter',sans-serif;font-size:.72rem;outline:none;transition:border-color .2s}.mem-input:focus{border-color:var(--gold)}\n.mem-add-btn{background:var(--gold);border:none;border-radius:6px;color:var(--bg);font-weight:700;font-size:.72rem;padding:.35rem .5rem;cursor:pointer;white-space:nowrap}\n.chat-area{flex:1;display:flex;flex-direction:column;overflow:hidden}\n.mode-bar{display:flex;align-items:center;gap:.4rem;padding:.6rem 1rem;border-bottom:1px solid var(--border);background:var(--surface);flex-shrink:0;flex-wrap:wrap}\n.mtoggle{display:flex;background:var(--panel);border:1px solid var(--border);border-radius:8px;padding:3px;flex-shrink:0}\n.mbtn{padding:.3rem .75rem;border:none;background:none;color:var(--ash);font-family:'Inter',sans-serif;font-size:.75rem;font-weight:500;border-radius:5px;cursor:pointer;transition:all .15s;white-space:nowrap}\n.mbtn.active{background:var(--violet);color:#fff}.mbtn.cactive{background:var(--gold);color:#0A0A0F}\n.agent-picker{display:none;align-items:center;gap:.3rem;flex-wrap:wrap}\n.apick{padding:.28rem .6rem;border:1px solid var(--border);background:var(--panel);border-radius:20px;color:var(--ash);font-family:'Inter',sans-serif;font-size:.72rem;cursor:pointer;transition:all .15s;white-space:nowrap}\n.apick:hover{border-color:var(--violet);color:var(--ivory)}.apick.active{border-color:var(--violet);background:rgba(124,111,205,.15);color:var(--ivory)}\n.active-label{font-size:.75rem;color:var(--ash);white-space:nowrap}.active-label strong{color:var(--ivory)}\n.chat-pane{display:none;flex:1;overflow-y:auto;padding:1rem;flex-direction:column;gap:.65rem;scroll-behavior:smooth}\n.chat-pane.active{display:flex}\n.chat-pane::-webkit-scrollbar{width:3px}.chat-pane::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}\n.msg{display:flex;gap:.6rem;animation:mi .22s ease;max-width:90%}\n@keyframes mi{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:none}}\n.msg.user{align-self:flex-end;flex-direction:row-reverse}\n.mavatar{width:30px;height:30px;border-radius:7px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:14px}\n.mbody{flex:1;min-width:0}.mmeta{display:flex;align-items:center;gap:.4rem;margin-bottom:.25rem}\n.mname{font-size:.68rem;font-weight:600}.mtime{font-size:.62rem;color:var(--ash);font-family:'JetBrains Mono',monospace}\n.mbubble{background:var(--panel);border:1px solid var(--border);border-radius:10px;padding:.65rem .9rem;font-size:.84rem;line-height:1.62;color:var(--ivory);white-space:pre-wrap;word-break:break-word}\n.msg.user .mbubble{background:rgba(124,111,205,.1);border-color:rgba(124,111,205,.2)}\n.mbubble strong,.mbubble b{font-weight:600}.mbubble em{font-style:italic;color:#bbb8cc}\n.mbubble code{font-family:'JetBrains Mono',monospace;font-size:.78rem;background:rgba(255,255,255,.07);padding:.1em .3em;border-radius:3px}\n.trow{display:flex;align-items:center;gap:.4rem;padding:.3rem .4rem;color:var(--ash);font-size:.72rem;font-style:italic;animation:mi .2s ease}\n.tdots span{display:inline-block;width:4px;height:4px;border-radius:50%;background:currentColor;margin:0 1px;animation:td 1.2s infinite}\n.tdots span:nth-child(2){animation-delay:.2s}.tdots span:nth-child(3){animation-delay:.4s}\n@keyframes td{0%,80%,100%{transform:scale(.6);opacity:.4}40%{transform:scale(1);opacity:1}}\n.empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--ash);text-align:center;gap:.6rem;padding:2rem}\n.eicon{font-size:2.5rem;opacity:.2}.etitle{font-size:.95rem;font-weight:600;color:var(--ivory);opacity:.3}.esub{font-size:.75rem;max-width:240px;opacity:.4;line-height:1.5}\n/* SESSION SWITCHER */\n.session-bar{display:flex;align-items:center;gap:.4rem;padding:.4rem 1rem;border-bottom:1px solid rgba(255,255,255,.04);background:var(--bg);font-size:.7rem;color:var(--ash);flex-shrink:0;overflow-x:auto}\n.sess-chip{padding:.2rem .55rem;border:1px solid var(--border);border-radius:20px;background:var(--panel);cursor:pointer;white-space:nowrap;transition:all .15s}\n.sess-chip:hover{border-color:var(--violet);color:var(--ivory)}.sess-chip.active{border-color:var(--violet);background:rgba(124,111,205,.12);color:var(--ivory)}\n.sess-new{padding:.2rem .55rem;border:1px dashed var(--border);border-radius:20px;background:none;cursor:pointer;white-space:nowrap;color:var(--ash);transition:all .15s}.sess-new:hover{border-color:var(--sage);color:var(--sage)}\n.input-area{border-top:1px solid var(--border);padding:.75rem 1rem;background:var(--surface);flex-shrink:0}\n.iwrap{display:flex;align-items:flex-end;gap:.6rem;background:var(--panel);border:1px solid var(--border);border-radius:10px;padding:.55rem .65rem;transition:border-color .2s}.iwrap:focus-within{border-color:var(--violet)}\n#msgInput{flex:1;background:none;border:none;outline:none;color:var(--ivory);font-family:'Inter',sans-serif;font-size:.86rem;resize:none;max-height:110px;line-height:1.5}\n#msgInput::placeholder{color:var(--ash)}\n.sbtn{width:32px;height:32px;border-radius:7px;border:none;background:var(--violet);color:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;transition:all .15s}\n.sbtn:hover{background:#9f8fe0}.sbtn:disabled{opacity:.4;cursor:not-allowed}.sbtn.council{background:var(--gold);color:var(--bg)}\n.ihint{font-size:.66rem;color:var(--ash);margin-top:.35rem;padding:0 .2rem}\n@media(min-width:641px){.agent-picker{display:none!important}}\n@media(max-width:640px){.sidebar{display:none}.agent-picker{display:flex}}\n</style>\n</head>\n<body>\n<div id=\"loginScreen\">\n  <div class=\"lcard\">\n    <div class=\"llogo\">⚡</div>\n    <div class=\"ltitle\">Council Room</div>\n    <div class=\"lsub\">Enter your access token</div>\n    <input type=\"password\" class=\"linput\" id=\"tokenInput\" placeholder=\"Token...\" onkeydown=\"if(event.key==='Enter')login()\">\n    <button class=\"lbtn\" onclick=\"login()\">Enter</button>\n    <div class=\"lerr\" id=\"lerr\"></div>\n  </div>\n</div>\n\n<div id=\"app\">\n  <header>\n    <div class=\"logo\"><div class=\"logo-icon\">⚡</div>Council Room</div>\n    <div class=\"hbtns\">\n      <button class=\"icon-btn\" onclick=\"newSession()\">+ New Chat</button>\n      <div class=\"sbadge\"><div class=\"dot\"></div>5 online</div>\n    </div>\n  </header>\n\n  <div class=\"layout\">\n    <div class=\"sidebar\">\n      <div class=\"sb-section\">\n        <div class=\"sb-label\">Broadcast</div>\n        <button class=\"ab active\" onclick=\"setCouncil()\" id=\"btn-council\"><div class=\"adot\" style=\"background:var(--gold)\"></div><div><div class=\"aname\" style=\"color:var(--gold)\">@Council</div><div class=\"arole\">All 5 agents</div></div></button>\n      </div>\n      <div class=\"sb-section\">\n        <div class=\"sb-label\">Private</div>\n        <button class=\"ab\" onclick=\"setPrivate('rafael')\" id=\"btn-rafael\"><div class=\"adot\" style=\"background:var(--rafael)\"></div><div><div class=\"aname\">🧭 Rafael</div><div class=\"arole\">The Guide</div></div></button>\n        <button class=\"ab\" onclick=\"setPrivate('uriel')\" id=\"btn-uriel\"><div class=\"adot\" style=\"background:var(--uriel)\"></div><div><div class=\"aname\">🔥 Uriel</div><div class=\"arole\">God's Fire</div></div></button>\n        <button class=\"ab\" onclick=\"setPrivate('michael')\" id=\"btn-michael\"><div class=\"adot\" style=\"background:var(--michael)\"></div><div><div class=\"aname\">🛡️ Michael</div><div class=\"arole\">Wise Advisor</div></div></button>\n        <button class=\"ab\" onclick=\"setPrivate('gabriel')\" id=\"btn-gabriel\"><div class=\"adot\" style=\"background:var(--gabriel)\"></div><div><div class=\"aname\">📣 Gabriel</div><div class=\"arole\">The Voice</div></div></button>\n        <button class=\"ab\" onclick=\"setPrivate('raguel')\" id=\"btn-raguel\"><div class=\"adot\" style=\"background:var(--raguel)\"></div><div><div class=\"aname\">🤝 Raguel</div><div class=\"arole\">The Friend</div></div></button>\n      </div>\n      <!-- MEMORY PANEL -->\n      <div class=\"sb-memory\">\n        <div class=\"mem-title\">🧠 Memory</div>\n        <div class=\"mem-list\" id=\"memList\"></div>\n        <div class=\"mem-input-wrap\">\n          <input class=\"mem-input\" id=\"memInput\" placeholder=\"Remember this...\" onkeydown=\"if(event.key==='Enter')addMemory()\">\n          <button class=\"mem-add-btn\" onclick=\"addMemory()\">Save</button>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"chat-area\">\n      <div class=\"mode-bar\">\n        <div class=\"mtoggle\">\n          <button class=\"mbtn cactive active\" id=\"mCouncil\" onclick=\"setCouncil()\">⚡ @Council</button>\n          <button class=\"mbtn\" id=\"mPrivate\" onclick=\"setPrivate(currentAgent)\">🔒 Private</button>\n        </div>\n        <div class=\"agent-picker\" id=\"agentPicker\">\n          <button class=\"apick\" onclick=\"setPrivate('rafael')\" id=\"pick-rafael\">🧭 Rafael</button>\n          <button class=\"apick\" onclick=\"setPrivate('uriel')\" id=\"pick-uriel\">🔥 Uriel</button>\n          <button class=\"apick\" onclick=\"setPrivate('michael')\" id=\"pick-michael\">🛡️ Michael</button>\n          <button class=\"apick\" onclick=\"setPrivate('gabriel')\" id=\"pick-gabriel\">📣 Gabriel</button>\n          <button class=\"apick\" onclick=\"setPrivate('raguel')\" id=\"pick-raguel\">🤝 Raguel</button>\n        </div>\n        <div class=\"active-label\" id=\"activeLabel\">→ <strong>@Council</strong></div>\n      </div>\n\n      <!-- SESSION BAR -->\n      <div class=\"session-bar\" id=\"sessionBar\"></div>\n\n      <!-- CHAT PANES -->\n      <div id=\"panesWrap\" style=\"flex:1;overflow:hidden;display:flex;flex-direction:column;position:relative\"></div>\n\n      <div class=\"input-area\">\n        <div class=\"iwrap\">\n          <textarea id=\"msgInput\" rows=\"1\" placeholder=\"Message the Council...\" onkeydown=\"handleKey(event)\" oninput=\"autoResize(this)\"></textarea>\n          <button class=\"sbtn council\" id=\"sendBtn\" onclick=\"send()\">\n            <svg width=\"15\" height=\"15\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" viewBox=\"0 0 24 24\"><line x1=\"22\" y1=\"2\" x2=\"11\" y2=\"13\"/><polygon points=\"22 2 15 22 11 13 2 9 22 2\"/></svg>\n          </button>\n        </div>\n        <div class=\"ihint\" id=\"ihint\">@Council — all 5 agents respond</div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\nconst API = window.location.origin+'/council-api';\nconst WS_URL = API.replace('https://','wss://').replace('http://','ws://')+'/ws';\nconst AGENTS={rafael:{name:'Rafael',emoji:'🧭',role:'The Guide'},uriel:{name:'Uriel',emoji:'🔥',role:\"God's Fire\"},michael:{name:'Michael',emoji:'🛡️',role:'Wise Advisor'},gabriel:{name:'Gabriel',emoji:'📣',role:'The Voice'},raguel:{name:'Raguel',emoji:'🤝',role:'The Friend'}};\nconst COLORS={rafael:'--rafael',uriel:'--uriel',michael:'--michael',gabriel:'--gabriel',raguel:'--raguel'};\n\nlet token=localStorage.getItem('council_token')||'';\nlet mode='council', currentAgent='rafael';\nlet ws=null, thinking={};\n\n// ── SESSIONS (new chat / history) ──\nlet sessions = JSON.parse(localStorage.getItem('council_sessions')||'[]');\nlet currentSessionId = null;\n\nfunction initSessions() {\n  if (sessions.length === 0) createSession();\n  else switchSession(sessions[sessions.length-1].id);\n  renderSessionBar();\n}\n\nfunction createSession() {\n  const id = 'sess_'+Date.now();\n  const label = 'Chat '+(sessions.length+1);\n  const panes = {}; // per agent/council pane messages\n  sessions.push({id, label, created: Date.now(), panes});\n  saveSessions();\n  switchSession(id);\n  renderSessionBar();\n}\n\nfunction newSession() {\n  createSession();\n}\n\nfunction switchSession(id) {\n  currentSessionId = id;\n  renderSessionBar();\n  renderAllPanes();\n}\n\nfunction saveSessions() {\n  // Keep last 10 sessions, trim messages to last 50 per pane\n  if (sessions.length > 10) sessions = sessions.slice(-10);\n  localStorage.setItem('council_sessions', JSON.stringify(sessions));\n}\n\nfunction getSession() { return sessions.find(s=>s.id===currentSessionId); }\nfunction getPaneMessages(pane) { const s=getSession(); return s?.panes?.[pane]||[]; }\nfunction addPaneMessage(pane, msg) {\n  const s=getSession(); if(!s)return;\n  if(!s.panes[pane]) s.panes[pane]=[];\n  s.panes[pane].push(msg);\n  if(s.panes[pane].length>100) s.panes[pane]=s.panes[pane].slice(-100);\n  saveSessions();\n}\n\nfunction renderSessionBar() {\n  const bar = document.getElementById('sessionBar');\n  bar.innerHTML = sessions.map(s=>\n    `<button class=\"sess-chip${s.id===currentSessionId?' active':''}\" onclick=\"switchSession('${s.id}')\">${s.label}</button>`\n  ).join('') + `<button class=\"sess-new\" onclick=\"newSession()\">+ New</button>`;\n}\n\n// ── PANE RENDERING ──\nconst PANE_IDS = ['council','rafael','uriel','michael','gabriel','raguel'];\n\nfunction renderAllPanes() {\n  const wrap = document.getElementById('panesWrap');\n  wrap.innerHTML = '';\n  PANE_IDS.forEach(id => {\n    const div = document.createElement('div');\n    div.className = 'chat-pane'+(id==='council'&&mode==='council'?' active':id===currentAgent&&mode==='private'?' active':'');\n    div.id = 'pane-'+id;\n    div.style.cssText = 'flex:1;overflow-y:auto;padding:1rem;display:none;flex-direction:column;gap:.65rem;scroll-behavior:smooth';\n    if(div.classList.contains('active')) div.style.display='flex';\n    const msgs = getPaneMessages(id);\n    if (msgs.length === 0) {\n      const labels={council:'@Council — all 5 agents',rafael:'Rafael — The Guide',uriel:'Uriel — God\\'s Fire',michael:'Michael — Wise Advisor',gabriel:'Gabriel — The Voice',raguel:'Raguel — The Friend'};\n      div.innerHTML=`<div class=\"empty\"><div class=\"eicon\">${id==='council'?'⚡':AGENTS[id]?.emoji||'⚡'}</div><div class=\"etitle\">${labels[id]||id}</div><div class=\"esub\">Start a conversation.</div></div>`;\n    } else {\n      msgs.forEach(m => appendMsgEl(div, m));\n    }\n    wrap.appendChild(div);\n  });\n}\n\nfunction showPane(id) {\n  document.querySelectorAll('.chat-pane,[id^=\"pane-\"]').forEach(p=>{p.style.display='none';p.classList.remove('active');});\n  const p = document.getElementById('pane-'+id);\n  if(p){p.style.display='flex';p.classList.add('active');p.scrollTop=p.scrollHeight;}\n}\n\n// ── AUTH ──\nasync function login(){\n  const t=document.getElementById('tokenInput').value.trim();if(!t)return;\n  try{const r=await fetch(`${API}/health`,{headers:{'x-council-token':t}});\n    if(r.ok)boot(t);else document.getElementById('lerr').textContent='Invalid token.';}\n  catch{boot(t);}\n}\nfunction boot(t){\n  token=t;localStorage.setItem('council_token',t);\n  document.getElementById('loginScreen').style.display='none';\n  document.getElementById('app').style.display='flex';\n  connectWS(); initSessions(); loadMemory();\n}\nif(token)setTimeout(()=>boot(token),50);\n\n// ── WS ──\nfunction connectWS(){\n  ws=new WebSocket(`${WS_URL}?token=${token}`);\n  ws.onmessage=e=>handle(JSON.parse(e.data));\n  ws.onclose=()=>setTimeout(connectWS,3000);\n  ws.onerror=()=>{};\n}\n\nfunction handle(d){\n  const targetPane = d.pane || (mode==='council'?'council':currentAgent);\n  if(d.type==='thinking'){\n    if(!thinking[d.agentId]){thinking[d.agentId]=addThinkingEl(targetPane,d.agentId);}\n  }else if(d.type==='response'){\n    removeThinking(d.agentId);\n    const msg={from:'agent',agentId:d.agentId,text:d.response,ts:Date.now()};\n    addPaneMessage(targetPane,msg);\n    appendMsgEl(document.getElementById('pane-'+targetPane),msg);\n    scrollPane(targetPane);\n  }else if(d.type==='council_done'){\n    Object.keys(thinking).forEach(removeThinking);thinking={};\n    document.getElementById('sendBtn').disabled=false;\n  }else if(d.type==='error'){\n    Object.keys(thinking).forEach(removeThinking);thinking={};\n    document.getElementById('sendBtn').disabled=false;\n  }\n}\n\n// ── MODES ──\nfunction setCouncil(){\n  mode='council';\n  document.querySelectorAll('.ab').forEach(b=>b.classList.remove('active'));\n  document.getElementById('btn-council').classList.add('active');\n  document.getElementById('mCouncil').classList.add('active','cactive');\n  document.getElementById('mPrivate').classList.remove('active');\n  document.getElementById('activeLabel').innerHTML='→ <strong>@Council</strong>';\n  document.getElementById('agentPicker').style.display='none';\n  document.getElementById('sendBtn').className='sbtn council';\n  document.getElementById('ihint').textContent='@Council — all 5 agents respond';\n  document.getElementById('msgInput').placeholder='Message the Council...';\n  showPane('council');\n}\nfunction setPrivate(id){\n  mode='private';currentAgent=id;const a=AGENTS[id];\n  document.querySelectorAll('.ab').forEach(b=>b.classList.remove('active'));\n  document.getElementById('btn-'+id)?.classList.add('active');\n  document.getElementById('mPrivate').classList.add('active');\n  document.getElementById('mCouncil').classList.remove('active','cactive');\n  document.getElementById('activeLabel').innerHTML=`→ <strong>${a.emoji} ${a.name}</strong>`;\n  document.getElementById('agentPicker').style.display='';\n  document.querySelectorAll('.apick').forEach(b=>b.classList.remove('active'));\n  document.getElementById('pick-'+id)?.classList.add('active');\n  document.getElementById('sendBtn').className='sbtn';\n  document.getElementById('ihint').textContent=`Private — ${a.name} (${a.role})`;\n  document.getElementById('msgInput').placeholder=`Message ${a.name}...`;\n  showPane(id);\n}\n\n// ── SEND ──\nfunction send(){\n  const inp=document.getElementById('msgInput');const msg=inp.value.trim();\n  if(!msg||!ws||ws.readyState!==1)return;\n  const pane=mode==='council'?'council':currentAgent;\n  const msgObj={from:'user',agentId:null,text:msg,ts:Date.now()};\n  addPaneMessage(pane,msgObj);\n  const p=document.getElementById('pane-'+pane);\n  p?.querySelector('.empty')?.remove();\n  appendMsgEl(p,msgObj);scrollPane(pane);\n  inp.value='';inp.style.height='auto';\n  document.getElementById('sendBtn').disabled=true;\n  ws.send(JSON.stringify({mode,agentId:currentAgent,message:msg,pane,sessionId:currentSessionId}));\n}\nfunction handleKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();send();}}\nfunction autoResize(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,110)+'px';}\nfunction scrollPane(pane){const p=document.getElementById('pane-'+pane);if(p)p.scrollTop=p.scrollHeight;}\n\n// ── RENDER ──\nfunction tnow(){return new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'});}\nfunction tfmt(ts){return ts?new Date(ts).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}):tnow();}\n\nfunction appendMsgEl(p, m) {\n  if(!p)return;\n  const isUser=m.from==='user';\n  const a=m.agentId?AGENTS[m.agentId]:null;\n  const cv=m.agentId?`var(${COLORS[m.agentId]||'--violet'})`:'var(--gold)';\n  const name=isUser?'Lucy':(a?`${a.emoji} ${a.name}`:'⚡ Council');\n  const abg=isUser?'rgba(124,111,205,.18)':'rgba(255,255,255,.06)';\n  const d=document.createElement('div');\n  d.className='msg'+(isUser?' user':'');\n  if(!isUser)d.style.borderLeft=`2px solid ${cv}`;\n  d.innerHTML=`<div class=\"mavatar\" style=\"background:${abg}\">${isUser?'👤':(a?.emoji||'⚡')}</div><div class=\"mbody\"><div class=\"mmeta\"><span class=\"mname\" style=\"color:${cv}\">${name}</span><span class=\"mtime\">${tfmt(m.ts)}</span></div><div class=\"mbubble\">${fmt(m.text)}</div></div>`;\n  p.appendChild(d);\n}\n\nfunction addThinkingEl(pane, agentId){\n  const p=document.getElementById('pane-'+pane);if(!p)return null;\n  const a=AGENTS[agentId];const cv=`var(${COLORS[agentId]||'--violet'})`;\n  const d=document.createElement('div');d.className='trow';d.id='t-'+agentId;d.style.color=cv;\n  d.innerHTML=`${a?.emoji||'⚡'} <span style=\"font-weight:500\">${a?.name||'?'}</span> is thinking <div class=\"tdots\"><span></span><span></span><span></span></div>`;\n  p.appendChild(d);p.scrollTop=p.scrollHeight;return d;\n}\nfunction removeThinking(id){document.getElementById('t-'+id)?.remove();delete thinking[id];}\n\nfunction fmt(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\\*\\*(.*?)\\*\\*/g,'<strong>$1</strong>').replace(/__(.*?)__/g,'<strong>$1</strong>').replace(/\\*(.*?)\\*/g,'<em>$1</em>').replace(/`(.*?)`/g,'<code>$1</code>').replace(/\\n/g,'<br>');}\n\n// ── MEMORY ──\nlet memFacts = [];\n\nasync function loadMemory(){\n  try{const r=await fetch(`${API}/memory`,{headers:{'x-council-token':token}});\n    if(r.ok){const d=await r.json();memFacts=d.facts||[];renderMemory();}}\n  catch{}\n}\nasync function addMemory(){\n  const inp=document.getElementById('memInput');const fact=inp.value.trim();if(!fact)return;\n  try{await fetch(`${API}/memory`,{method:'POST',headers:{'x-council-token':token,'content-type':'application/json'},body:JSON.stringify({fact})});\n    inp.value='';loadMemory();}catch{}\n}\nasync function delMemory(idx){\n  try{await fetch(`${API}/memory/${idx}`,{method:'DELETE',headers:{'x-council-token':token}});loadMemory();}catch{}\n}\nfunction renderMemory(){\n  const el=document.getElementById('memList');\n  if(!el)return;\n  if(memFacts.length===0){el.innerHTML='<div style=\"font-size:.68rem;color:var(--ash);padding:.2rem .4rem\">No memories yet</div>';return;}\n  el.innerHTML=memFacts.map((f,i)=>\n    `<div class=\"mem-item\"><span class=\"mem-text\">${f.fact}</span><button class=\"mem-del\" onclick=\"delMemory(${i})\">✕</button></div>`\n  ).join('');\n}\n</script>\n</body>\n</html>\nHTMLEOF\necho \"Done: $(wc -c < ~/council-room/frontend/index.html) bytes\""}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-sonnet-4-6","usage":{"input":1,"output":9384,"cacheRead":153080,"cacheWrite":2339,"totalTokens":164804,"cost":{"input":0.000003,"output":0.14076,"cacheRead":0.045924,"cacheWrite":0.00877125,"total":0.19545825}},"stopReason":"toolUse","timestamp":1772983471224}}
