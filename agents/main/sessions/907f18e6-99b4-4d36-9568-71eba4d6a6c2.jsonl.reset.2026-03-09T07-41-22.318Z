{"type":"message","id":"dee30782","parentId":"51d23b5e","timestamp":"2026-03-08T15:03:51.600Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"tooluse_a185BGASHM176tLQIJ8omc","name":"exec","arguments":{"command":"cd ~/council-room/backend\n# Add \"type\": \"module\" to package.json for ES modules\nnode -e \"\nconst fs = require('fs');\nconst pkg = JSON.parse(fs.readFileSync('package.json'));\npkg.type = 'module';\npkg.scripts.start = 'node server.js';\nfs.writeFileSync('package.json', JSON.stringify(pkg, null, 2));\nconsole.log('done');\n\""}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-sonnet-4-6","usage":{"input":1,"output":158,"cacheRead":117341,"cacheWrite":1843,"totalTokens":119343,"cost":{"input":0.000003,"output":0.00237,"cacheRead":0.0352023,"cacheWrite":0.00691125,"total":0.04448655}},"stopReason":"toolUse","timestamp":1772982227655}}
{"type":"message","id":"91bcd2d6","parentId":"dee30782","timestamp":"2026-03-08T15:03:51.686Z","message":{"role":"toolResult","toolCallId":"tooluse_a185BGASHM176tLQIJ8omc","toolName":"exec","content":[{"type":"text","text":"done"}],"details":{"status":"completed","exitCode":0,"durationMs":71,"aggregated":"done","cwd":"/home/openclaw/.openclaw/workspace"},"isError":false,"timestamp":1772982231675}}
{"type":"message","id":"b58de88a","parentId":"91bcd2d6","timestamp":"2026-03-08T15:05:22.618Z","message":{"role":"assistant","content":[{"type":"text","text":"Now build the frontend:"},{"type":"toolCall","id":"tooluse_Tjaztlo7nopnh2Jy5YZ2Zw","name":"write","arguments":{"content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Council Room</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap\" rel=\"stylesheet\">\n<style>\n*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n:root {\n  --bg:       #0A0A0F;\n  --surface:  #13131A;\n  --panel:    #1C1C27;\n  --border:   #2E2E3E;\n  --gold:     #C9A84C;\n  --violet:   #7C6FCD;\n  --ivory:    #F0EDE8;\n  --ash:      #7A7A8C;\n  --sage:     #4CAF82;\n  --ember:    #E05C5C;\n  --rafael:   #7C6FCD;\n  --uriel:    #C9A84C;\n  --michael:  #4CAF82;\n  --gabriel:  #E05C5C;\n  --raguel:   #7A8FCD;\n  --council:  #C9A84C;\n}\n\nbody {\n  background: var(--bg);\n  color: var(--ivory);\n  font-family: 'Inter', sans-serif;\n  height: 100vh;\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n}\n\n/* ─── LOGIN SCREEN ─── */\n#loginScreen {\n  position: fixed; inset: 0; z-index: 100;\n  background: var(--bg);\n  display: flex; align-items: center; justify-content: center;\n  flex-direction: column; gap: 1.5rem;\n}\n.login-card {\n  background: var(--surface);\n  border: 1px solid var(--border);\n  border-radius: 16px;\n  padding: 2.5rem;\n  width: 340px;\n  text-align: center;\n}\n.login-logo { font-size: 2.5rem; margin-bottom: 0.75rem; }\n.login-title { font-size: 1.3rem; font-weight: 700; margin-bottom: 0.25rem; }\n.login-sub { font-size: 0.8rem; color: var(--ash); margin-bottom: 1.5rem; }\n.login-input {\n  width: 100%; padding: 0.75rem 1rem;\n  background: var(--panel); border: 1px solid var(--border);\n  border-radius: 8px; color: var(--ivory);\n  font-family: 'JetBrains Mono', monospace; font-size: 0.85rem;\n  outline: none; margin-bottom: 1rem;\n  transition: border-color 0.2s;\n}\n.login-input:focus { border-color: var(--violet); }\n.login-btn {\n  width: 100%; padding: 0.75rem;\n  background: var(--violet); border: none; border-radius: 8px;\n  color: #fff; font-family: 'Inter', sans-serif;\n  font-weight: 600; font-size: 0.9rem; cursor: pointer;\n  transition: all 0.15s;\n}\n.login-btn:hover { background: #9f8fe0; box-shadow: 0 0 20px rgba(124,111,205,0.4); }\n.login-error { color: var(--ember); font-size: 0.78rem; margin-top: -0.5rem; }\n\n/* ─── APP ─── */\n#app { display: none; flex-direction: column; height: 100vh; }\n\n/* HEADER */\nheader {\n  background: rgba(19,19,26,0.95);\n  backdrop-filter: blur(20px);\n  border-bottom: 1px solid var(--border);\n  padding: 0 1.5rem;\n  height: 56px;\n  display: flex; align-items: center; justify-content: space-between;\n  flex-shrink: 0;\n  z-index: 10;\n}\n.logo { display: flex; align-items: center; gap: 0.6rem; font-weight: 700; font-size: 1rem; }\n.logo-icon {\n  width: 28px; height: 28px;\n  background: linear-gradient(135deg, var(--violet), var(--gold));\n  border-radius: 7px; display: flex; align-items: center; justify-content: center;\n  font-size: 13px; box-shadow: 0 0 12px rgba(124,111,205,0.4);\n}\n.header-right { display: flex; align-items: center; gap: 0.75rem; }\n.status-badge {\n  display: flex; align-items: center; gap: 0.4rem;\n  font-size: 0.72rem; color: var(--ash);\n  background: var(--panel); border: 1px solid var(--border);\n  padding: 0.3rem 0.7rem; border-radius: 20px;\n}\n.dot { width: 6px; height: 6px; border-radius: 50%; background: var(--sage); animation: pulse 2s infinite; }\n@keyframes pulse { 0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(76,175,130,0.4)} 50%{opacity:.7;box-shadow:0 0 0 4px rgba(76,175,130,0)} }\n\n/* LAYOUT */\n.layout { display: flex; flex: 1; overflow: hidden; }\n\n/* SIDEBAR */\n.sidebar {\n  width: 220px; flex-shrink: 0;\n  background: var(--surface);\n  border-right: 1px solid var(--border);\n  display: flex; flex-direction: column;\n  overflow-y: auto;\n}\n.sidebar-section { padding: 1rem 0.75rem 0.5rem; }\n.sidebar-label {\n  font-size: 0.65rem; font-weight: 700; color: var(--ash);\n  text-transform: uppercase; letter-spacing: 0.1em;\n  padding: 0 0.5rem; margin-bottom: 0.4rem;\n}\n.agent-btn {\n  display: flex; align-items: center; gap: 0.65rem;\n  width: 100%; padding: 0.6rem 0.75rem;\n  background: none; border: none; border-radius: 8px;\n  color: var(--ash); cursor: pointer;\n  font-family: 'Inter', sans-serif; font-size: 0.83rem;\n  text-align: left; transition: all 0.15s;\n  margin-bottom: 2px;\n}\n.agent-btn:hover { background: rgba(255,255,255,0.05); color: var(--ivory); }\n.agent-btn.active { background: rgba(124,111,205,0.12); color: var(--ivory); }\n.agent-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }\n.agent-info { flex: 1; }\n.agent-btn-name { font-weight: 500; font-size: 0.82rem; line-height: 1.2; }\n.agent-btn-role { font-size: 0.68rem; color: var(--ash); }\n.mode-council .agent-btn-name { color: var(--gold); }\n\n/* MAIN CHAT */\n.chat-area {\n  flex: 1; display: flex; flex-direction: column;\n  overflow: hidden; position: relative;\n}\n\n/* MODE BAR */\n.mode-bar {\n  display: flex; align-items: center; gap: 0.5rem;\n  padding: 0.75rem 1.25rem;\n  border-bottom: 1px solid var(--border);\n  background: var(--surface);\n  flex-shrink: 0;\n}\n.mode-toggle {\n  display: flex; background: var(--panel); border: 1px solid var(--border);\n  border-radius: 8px; padding: 3px;\n}\n.mode-btn {\n  padding: 0.35rem 0.85rem; border: none; background: none;\n  color: var(--ash); font-family: 'Inter', sans-serif;\n  font-size: 0.78rem; font-weight: 500; border-radius: 6px;\n  cursor: pointer; transition: all 0.15s; white-space: nowrap;\n}\n.mode-btn.active { background: var(--violet); color: #fff; box-shadow: 0 0 10px rgba(124,111,205,0.3); }\n.mode-btn.council-active { background: var(--gold); color: #0A0A0F; }\n.active-label {\n  font-size: 0.78rem; color: var(--ash);\n  display: flex; align-items: center; gap: 0.4rem;\n}\n.active-label strong { color: var(--ivory); }\n\n/* MESSAGES */\n.messages {\n  flex: 1; overflow-y: auto;\n  padding: 1.25rem;\n  display: flex; flex-direction: column; gap: 1rem;\n  scroll-behavior: smooth;\n}\n.messages::-webkit-scrollbar { width: 4px; }\n.messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }\n\n.msg { display: flex; gap: 0.75rem; animation: msgIn 0.25s ease; max-width: 85%; }\n@keyframes msgIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:none} }\n.msg.user { align-self: flex-end; flex-direction: row-reverse; }\n.msg-avatar {\n  width: 32px; height: 32px; border-radius: 8px; flex-shrink: 0;\n  display: flex; align-items: center; justify-content: center;\n  font-size: 14px; font-weight: 600;\n}\n.msg-body { flex: 1; }\n.msg-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.3rem; }\n.msg-name { font-size: 0.72rem; font-weight: 600; }\n.msg-time { font-size: 0.65rem; color: var(--ash); font-family: 'JetBrains Mono', monospace; }\n.msg-bubble {\n  background: var(--panel); border: 1px solid var(--border);\n  border-radius: 12px; padding: 0.75rem 1rem;\n  font-size: 0.85rem; line-height: 1.6; color: var(--ivory);\n  white-space: pre-wrap; word-break: break-word;\n}\n.msg.user .msg-bubble {\n  background: rgba(124,111,205,0.15);\n  border-color: rgba(124,111,205,0.25);\n}\n.msg-bubble strong { font-weight: 600; }\n.msg-bubble em { font-style: italic; color: #c8c4d8; }\n.msg-bubble code {\n  font-family: 'JetBrains Mono', monospace; font-size: 0.8rem;\n  background: rgba(255,255,255,0.07); padding: 0.1em 0.3em; border-radius: 3px;\n}\n\n/* THINKING */\n.thinking {\n  display: flex; align-items: center; gap: 0.5rem;\n  padding: 0.5rem 0.75rem;\n  color: var(--ash); font-size: 0.78rem; font-style: italic;\n}\n.think-dots span {\n  display: inline-block; width: 5px; height: 5px; border-radius: 50%;\n  background: var(--ash); margin: 0 1px;\n  animation: think 1.2s infinite;\n}\n.think-dots span:nth-child(2) { animation-delay: 0.2s; }\n.think-dots span:nth-child(3) { animation-delay: 0.4s; }\n@keyframes think { 0%,80%,100%{transform:scale(0.6);opacity:0.4} 40%{transform:scale(1);opacity:1} }\n\n/* EMPTY STATE */\n.empty-state {\n  flex: 1; display: flex; flex-direction: column;\n  align-items: center; justify-content: center;\n  color: var(--ash); text-align: center; gap: 0.75rem;\n}\n.empty-icon { font-size: 3rem; opacity: 0.3; }\n.empty-title { font-size: 1rem; font-weight: 600; color: var(--ivory); opacity: 0.4; }\n.empty-sub { font-size: 0.8rem; max-width: 280px; opacity: 0.5; line-height: 1.5; }\n\n/* INPUT */\n.input-area {\n  border-top: 1px solid var(--border);\n  padding: 1rem 1.25rem;\n  background: var(--surface);\n  flex-shrink: 0;\n}\n.input-wrap {\n  display: flex; align-items: flex-end; gap: 0.75rem;\n  background: var(--panel); border: 1px solid var(--border);\n  border-radius: 12px; padding: 0.6rem 0.75rem;\n  transition: border-color 0.2s;\n}\n.input-wrap:focus-within { border-color: var(--violet); }\n#msgInput {\n  flex: 1; background: none; border: none; outline: none;\n  color: var(--ivory); font-family: 'Inter', sans-serif;\n  font-size: 0.88rem; resize: none; max-height: 120px;\n  line-height: 1.5;\n}\n#msgInput::placeholder { color: var(--ash); }\n.send-btn {\n  width: 34px; height: 34px; border-radius: 8px; border: none;\n  background: var(--violet); color: #fff;\n  display: flex; align-items: center; justify-content: center;\n  cursor: pointer; flex-shrink: 0; transition: all 0.15s;\n}\n.send-btn:hover { background: #9f8fe0; box-shadow: 0 0 12px rgba(124,111,205,0.4); }\n.send-btn:disabled { opacity: 0.4; cursor: not-allowed; }\n.send-btn.council { background: var(--gold); color: var(--bg); }\n.send-btn.council:hover { box-shadow: 0 0 12px rgba(201,168,76,0.4); }\n.input-hint { font-size: 0.68rem; color: var(--ash); margin-top: 0.4rem; padding: 0 0.25rem; }\n\n@media (max-width: 640px) {\n  .sidebar { display: none; }\n  .mode-bar { padding: 0.5rem 0.75rem; }\n}\n</style>\n</head>\n<body>\n\n<!-- LOGIN -->\n<div id=\"loginScreen\">\n  <div class=\"login-card\">\n    <div class=\"login-logo\">⚡</div>\n    <div class=\"login-title\">Council Room</div>\n    <div class=\"login-sub\">Enter your access token to continue</div>\n    <input type=\"password\" class=\"login-input\" id=\"tokenInput\" placeholder=\"Access token...\" onkeydown=\"if(event.key==='Enter')login()\">\n    <button class=\"login-btn\" onclick=\"login()\">Enter the Council</button>\n    <div class=\"login-error\" id=\"loginError\" style=\"display:none;margin-top:0.75rem\"></div>\n  </div>\n</div>\n\n<!-- APP -->\n<div id=\"app\">\n  <header>\n    <div class=\"logo\">\n      <div class=\"logo-icon\">⚡</div>\n      Council Room\n    </div>\n    <div class=\"header-right\">\n      <div class=\"status-badge\"><div class=\"dot\"></div>5 agents online</div>\n    </div>\n  </header>\n\n  <div class=\"layout\">\n    <!-- SIDEBAR -->\n    <div class=\"sidebar\">\n      <div class=\"sidebar-section\">\n        <div class=\"sidebar-label\">Broadcast</div>\n        <button class=\"agent-btn mode-council active\" onclick=\"selectMode('council')\" id=\"btn-council\">\n          <div class=\"agent-dot\" style=\"background:var(--gold)\"></div>\n          <div class=\"agent-info\">\n            <div class=\"agent-btn-name\">@Council</div>\n            <div class=\"agent-btn-role\">All agents</div>\n          </div>\n        </button>\n      </div>\n      <div class=\"sidebar-section\">\n        <div class=\"sidebar-label\">Private</div>\n        <button class=\"agent-btn\" onclick=\"selectAgent('rafael')\" id=\"btn-rafael\">\n          <div class=\"agent-dot\" style=\"background:var(--rafael)\"></div>\n          <div class=\"agent-info\">\n            <div class=\"agent-btn-name\">🧭 Rafael</div>\n            <div class=\"agent-btn-role\">The Guide</div>\n          </div>\n        </button>\n        <button class=\"agent-btn\" onclick=\"selectAgent('uriel')\" id=\"btn-uriel\">\n          <div class=\"agent-dot\" style=\"background:var(--uriel)\"></div>\n          <div class=\"agent-info\">\n            <div class=\"agent-btn-name\">🔥 Uriel</div>\n            <div class=\"agent-btn-role\">God's Fire</div>\n          </div>\n        </button>\n        <button class=\"agent-btn\" onclick=\"selectAgent('michael')\" id=\"btn-michael\">\n          <div class=\"agent-dot\" style=\"background:var(--michael)\"></div>\n          <div class=\"agent-info\">\n            <div class=\"agent-btn-name\">🛡️ Michael</div>\n            <div class=\"agent-btn-role\">Wise Advisor</div>\n          </div>\n        </button>\n        <button class=\"agent-btn\" onclick=\"selectAgent('gabriel')\" id=\"btn-gabriel\">\n          <div class=\"agent-dot\" style=\"background:var(--gabriel)\"></div>\n          <div class=\"agent-info\">\n            <div class=\"agent-btn-name\">📣 Gabriel</div>\n            <div class=\"agent-btn-role\">The Voice</div>\n          </div>\n        </button>\n        <button class=\"agent-btn\" onclick=\"selectAgent('raguel')\" id=\"btn-raguel\">\n          <div class=\"agent-dot\" style=\"background:var(--raguel)\"></div>\n          <div class=\"agent-info\">\n            <div class=\"agent-btn-name\">🤝 Raguel</div>\n            <div class=\"agent-btn-role\">The Friend</div>\n          </div>\n        </button>\n      </div>\n    </div>\n\n    <!-- CHAT -->\n    <div class=\"chat-area\">\n      <div class=\"mode-bar\">\n        <div class=\"mode-toggle\">\n          <button class=\"mode-btn council-active active\" id=\"modeCouncil\" onclick=\"selectMode('council')\">⚡ @Council</button>\n          <button class=\"mode-btn\" id=\"modePrivate\" onclick=\"selectAgent(currentAgent||'rafael')\">🔒 Private</button>\n        </div>\n        <div class=\"active-label\">Speaking with: <strong id=\"activeName\">@Council</strong></div>\n      </div>\n\n      <div class=\"messages\" id=\"messages\">\n        <div class=\"empty-state\" id=\"emptyState\">\n          <div class=\"empty-icon\">⚡</div>\n          <div class=\"empty-title\">Council Room</div>\n          <div class=\"empty-sub\">The Council is assembled and ready. Send a message to begin.</div>\n        </div>\n      </div>\n\n      <div class=\"input-area\">\n        <div class=\"input-wrap\">\n          <textarea id=\"msgInput\" rows=\"1\" placeholder=\"Message the Council...\" onkeydown=\"handleKey(event)\" oninput=\"autoResize(this)\"></textarea>\n          <button class=\"send-btn council\" id=\"sendBtn\" onclick=\"sendMessage()\">\n            <svg width=\"16\" height=\"16\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" viewBox=\"0 0 24 24\"><line x1=\"22\" y1=\"2\" x2=\"11\" y2=\"13\"/><polygon points=\"22 2 15 22 11 13 2 9 22 2\"/></svg>\n          </button>\n        </div>\n        <div class=\"input-hint\" id=\"inputHint\">@Council mode — Rafael will coordinate the Council's response</div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\nconst API_BASE = window.location.origin.replace(/\\/council.*/, '') + '/council-api';\nconst WS_URL = API_BASE.replace('https://', 'wss://').replace('http://', 'ws://') + '/ws';\n\nconst AGENTS = {\n  rafael:  { name: 'Rafael',  emoji: '🧭', role: 'The Guide',        color: 'var(--rafael)' },\n  uriel:   { name: 'Uriel',   emoji: '🔥', role: \"God's Fire\",       color: 'var(--uriel)'  },\n  michael: { name: 'Michael', emoji: '🛡️', role: 'The Wise Advisor', color: 'var(--michael)'},\n  gabriel: { name: 'Gabriel', emoji: '📣', role: 'The Voice',        color: 'var(--gabriel)'},\n  raguel:  { name: 'Raguel',  emoji: '🤝', role: 'The Friend',       color: 'var(--raguel)' },\n};\n\nlet token = localStorage.getItem('council_token') || '';\nlet mode = 'council'; // 'council' | 'private'\nlet currentAgent = 'rafael';\nlet ws = null;\nlet thinkingEl = null;\nlet msgHistory = JSON.parse(localStorage.getItem('council_history') || '[]');\n\n// ─── AUTH ───\nasync function login() {\n  const t = document.getElementById('tokenInput').value.trim();\n  if (!t) return;\n  try {\n    const res = await fetch(`${API_BASE}/health`, { headers: { 'x-council-token': t } });\n    if (res.ok) {\n      token = t;\n      localStorage.setItem('council_token', t);\n      document.getElementById('loginScreen').style.display = 'none';\n      document.getElementById('app').style.display = 'flex';\n      connectWS();\n      renderHistory();\n    } else {\n      showLoginError('Invalid token. Check your Council access token.');\n    }\n  } catch {\n    // Try anyway — maybe network issue\n    token = t;\n    localStorage.setItem('council_token', t);\n    document.getElementById('loginScreen').style.display = 'none';\n    document.getElementById('app').style.display = 'flex';\n    connectWS();\n    renderHistory();\n  }\n}\n\nfunction showLoginError(msg) {\n  const el = document.getElementById('loginError');\n  el.textContent = msg; el.style.display = 'block';\n}\n\n// Auto-login if token exists\nif (token) {\n  document.getElementById('loginScreen').style.display = 'none';\n  document.getElementById('app').style.display = 'flex';\n  setTimeout(() => { connectWS(); renderHistory(); }, 100);\n}\n\n// ─── WEBSOCKET ───\nfunction connectWS() {\n  ws = new WebSocket(`${WS_URL}?token=${token}`);\n  ws.onopen = () => console.log('WS connected');\n  ws.onmessage = (e) => handleWS(JSON.parse(e.data));\n  ws.onclose = () => setTimeout(connectWS, 3000);\n  ws.onerror = () => {};\n}\n\nfunction handleWS(data) {\n  if (data.type === 'thinking') {\n    removeThinking();\n    thinkingEl = addThinking(data.agentId);\n  } else if (data.type === 'response') {\n    removeThinking();\n    addMessage('agent', data.agentId, data.response);\n  } else if (data.type === 'error') {\n    removeThinking();\n    addSystemMsg('⚠️ ' + data.message);\n  }\n  document.getElementById('sendBtn').disabled = false;\n}\n\n// ─── MODES ───\nfunction selectMode(m) {\n  mode = m;\n  document.querySelectorAll('.agent-btn').forEach(b => b.classList.remove('active'));\n  document.getElementById('btn-council').classList.add('active');\n  document.getElementById('modeCouncil').classList.add('active','council-active');\n  document.getElementById('modePrivate').classList.remove('active');\n  document.getElementById('activeName').textContent = '@Council';\n  document.getElementById('sendBtn').className = 'send-btn council';\n  document.getElementById('inputHint').textContent = '@Council mode — Rafael will coordinate the Council\\'s response';\n  document.getElementById('msgInput').placeholder = 'Message the Council...';\n}\n\nfunction selectAgent(agentId) {\n  mode = 'private';\n  currentAgent = agentId;\n  const a = AGENTS[agentId];\n  document.querySelectorAll('.agent-btn').forEach(b => b.classList.remove('active'));\n  document.getElementById('btn-' + agentId)?.classList.add('active');\n  document.getElementById('modePrivate').classList.add('active');\n  document.getElementById('modeCouncil').classList.remove('active','council-active');\n  document.getElementById('activeName').textContent = `${a.emoji} ${a.name}`;\n  document.getElementById('sendBtn').className = 'send-btn';\n  document.getElementById('inputHint').textContent = `Private mode — speaking directly with ${a.name} (${a.role})`;\n  document.getElementById('msgInput').placeholder = `Message ${a.name}...`;\n}\n\n// ─── MESSAGING ───\nfunction sendMessage() {\n  const input = document.getElementById('msgInput');\n  const msg = input.value.trim();\n  if (!msg || !ws || ws.readyState !== 1) return;\n\n  addMessage('user', null, msg);\n  input.value = ''; input.style.height = 'auto';\n  document.getElementById('sendBtn').disabled = true;\n  document.getElementById('emptyState')?.remove();\n\n  ws.send(JSON.stringify({\n    mode: mode,\n    agentId: mode === 'private' ? currentAgent : 'rafael',\n    message: msg\n  }));\n}\n\nfunction handleKey(e) {\n  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }\n}\n\nfunction autoResize(el) {\n  el.style.height = 'auto';\n  el.style.height = Math.min(el.scrollHeight, 120) + 'px';\n}\n\n// ─── RENDER ───\nfunction addMessage(from, agentId, text) {\n  const msgs = document.getElementById('messages');\n  const isUser = from === 'user';\n  const agent = agentId ? AGENTS[agentId] : null;\n  const now = new Date().toLocaleTimeString('en-US', {hour:'2-digit',minute:'2-digit'});\n\n  const div = document.createElement('div');\n  div.className = 'msg' + (isUser ? ' user' : '');\n\n  const avatarBg = isUser ? 'rgba(124,111,205,0.2)' : (agent ? `rgba(${hexToRgb(getAgentHex(agentId))},0.15)` : 'rgba(201,168,76,0.15)');\n  const name = isUser ? 'Lucy' : (agent ? `${agent.emoji} ${agent.name}` : '⚡ Council');\n  const nameColor = isUser ? 'var(--violet)' : (agentId ? `var(--${agentId})` : 'var(--gold)');\n\n  div.innerHTML = `\n    <div class=\"msg-avatar\" style=\"background:${avatarBg}\">${isUser ? '👤' : (agent?.emoji || '⚡')}</div>\n    <div class=\"msg-body\">\n      <div class=\"msg-meta\">\n        <span class=\"msg-name\" style=\"color:${nameColor}\">${name}</span>\n        <span class=\"msg-time\">${now}</span>\n      </div>\n      <div class=\"msg-bubble\">${formatText(text)}</div>\n    </div>`;\n\n  msgs.appendChild(div);\n  msgs.scrollTop = msgs.scrollHeight;\n\n  // Save to history\n  msgHistory.push({ from, agentId, text, time: Date.now() });\n  if (msgHistory.length > 200) msgHistory = msgHistory.slice(-200);\n  localStorage.setItem('council_history', JSON.stringify(msgHistory));\n}\n\nfunction addThinking(agentId) {\n  const msgs = document.getElementById('messages');\n  const agent = AGENTS[agentId];\n  const div = document.createElement('div');\n  div.className = 'thinking';\n  div.id = 'thinking-msg';\n  div.innerHTML = `<span style=\"color:${agentId?`var(--${agentId})`:'var(--gold)'};\">${agent?.emoji||'⚡'} ${agent?.name||'Council'}</span> is thinking <div class=\"think-dots\"><span></span><span></span><span></span></div>`;\n  msgs.appendChild(div);\n  msgs.scrollTop = msgs.scrollHeight;\n  return div;\n}\n\nfunction removeThinking() {\n  document.getElementById('thinking-msg')?.remove();\n}\n\nfunction addSystemMsg(text) {\n  const msgs = document.getElementById('messages');\n  const div = document.createElement('div');\n  div.style.cssText = 'text-align:center;font-size:0.75rem;color:var(--ash);padding:0.5rem;';\n  div.textContent = text;\n  msgs.appendChild(div);\n}\n\nfunction renderHistory() {\n  if (!msgHistory.length) return;\n  document.getElementById('emptyState')?.remove();\n  msgHistory.slice(-50).forEach(m => addMessage(m.from, m.agentId, m.text));\n}\n\nfunction formatText(text) {\n  return text\n    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')\n    .replace(/\\*\\*(.*?)\\*\\*/g,'<strong>$1</strong>')\n    .replace(/\\*(.*?)\\*/g,'<em>$1</em>')\n    .replace(/`(.*?)`/g,'<code>$1</code>')\n    .replace(/\\n/g,'<br>');\n}\n\nfunction getAgentHex(id) {\n  const map = {rafael:'7C6FCD',uriel:'C9A84C',michael:'4CAF82',gabriel:'E05C5C',raguel:'7A8FCD'};\n  return map[id] || 'C9A84C';\n}\nfunction hexToRgb(hex) {\n  const r=parseInt(hex.slice(0,2),16),g=parseInt(hex.slice(2,4),16),b=parseInt(hex.slice(4,6),16);\n  return `${r},${g},${b}`;\n}\n</script>\n</body>\n</html>\n","file_path":"/home/openclaw/council-room/frontend/index.html"}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-sonnet-4-6","usage":{"input":1,"output":8310,"cacheRead":119184,"cacheWrite":171,"totalTokens":127666,"cost":{"input":0.000003,"output":0.12465,"cacheRead":0.0357552,"cacheWrite":0.00064125,"total":0.16104945}},"stopReason":"toolUse","timestamp":1772982231687}}
