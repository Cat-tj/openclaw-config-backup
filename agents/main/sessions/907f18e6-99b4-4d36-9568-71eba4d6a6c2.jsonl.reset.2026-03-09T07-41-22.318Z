,timestamp:Date.now()};\n+189   }catch(e){\n+190     return rep.code(500).send({error:e.message});\n+191   }\n+192 });\n+193 \n+194 // ── model config per agent ──\n+195 fastify.get('/oc/agent/:id/config', async(req,rep)=>{\n+196   if(!auth(req,rep))return;\n+197   const id=req.params.id;\n+198   try{\n+199     const cfg = jread(OC_CONFIG,{});\n+200     return {agentId:id,currentModel:cfg.agents?.[id]?.model||'amazon-bedrock/us.anthropic.claude-sonnet-4-6'};\n+201   }catch{return rep.code(500).send({error:'Failed to read config'});}\n+202 });\n+203 \n+204 fastify.post('/oc/agent/:id/model', async(req,rep)=>{\n+205   if(!auth(req,rep))return;\n+206   const id=req.params.id;\n+207   const {model}=req.body;\n+208   if(!model)return rep.code(400).send({error:'model required'});\n+209   try{\n+210     const cfg = jread(OC_CONFIG,{});\n+211     if(!cfg.agents)cfg.agents={};\n+212     if(!cfg.agents[id])cfg.agents[id]={};\n+213     cfg.agents[id].model=model;\n+214     jwrite(OC_CONFIG,cfg);\n+215     const aid = id==='michael'?'main':id;\n+216     try{execSync(`pkill -f \"openclaw agent.*${aid}\" 2>/dev/null`);}catch{}\n+217     return {ok:true,message:`${AGENTS[id]?.name||id} model updated to ${model.split('/').pop()}, restarting...`,timestamp:Date.now()};\n+218   }catch(e){return rep.code(500).send({error:e.message});}\n+219 });\n+220 \n 171 // ── file explorer ──\n 172 function safeList(dir){\n 173   if(!existsSync(dir))return [];\n 174   return readdirSync(dir).map(f=>{ const fp=join(dir,f); const s=statSync(fp); return {name:f,path:fp,isDir:s.isDirectory(),size:s.size,mtime:s.mtimeMs}; }).sort((a,b)=>b.isDir-a.isDir||a.name.localeCompare(b.name));\n     ...","firstChangedLine":164},"isError":false,"timestamp":1772993028410}}
