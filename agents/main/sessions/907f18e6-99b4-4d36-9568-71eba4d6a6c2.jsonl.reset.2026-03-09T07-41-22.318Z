{"type":"message","id":"836982ec","parentId":"d9c6b0e5","timestamp":"2026-03-08T15:03:18.934Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"tooluse_bX081BfRudiAdxdSdCV9so","name":"exec","arguments":{"command":"cd ~/council-room/backend\nnpm init -y\nnpm install fastify @fastify/cors @fastify/websocket 2>&1 | tail -5"}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-sonnet-4-6","usage":{"input":1,"output":87,"cacheRead":116962,"cacheWrite":148,"totalTokens":117198,"cost":{"input":0.000003,"output":0.001305,"cacheRead":0.0350886,"cacheWrite":0.000555,"total":0.036951599999999994}},"stopReason":"toolUse","timestamp":1772982195950}}
{"type":"message","id":"be7003d9","parentId":"836982ec","timestamp":"2026-03-08T15:03:23.824Z","message":{"role":"toolResult","toolCallId":"tooluse_bX081BfRudiAdxdSdCV9so","toolName":"exec","content":[{"type":"text","text":"Wrote to /home/openclaw/council-room/backend/package.json:\n\n{\n  \"name\": \"backend\",\n  \"version\": \"1.0.0\",\n  \"description\": \"\",\n  \"main\": \"index.js\",\n  \"scripts\": {\n    \"test\": \"echo \\\"Error: no test specified\\\" && exit 1\"\n  },\n  \"keywords\": [],\n  \"author\": \"\",\n  \"license\": \"ISC\"\n}\n\n\n\n\n22 packages are looking for funding\n  run `npm fund` for details\n\nfound 0 vulnerabilities"}],"details":{"status":"completed","exitCode":0,"durationMs":4875,"aggregated":"Wrote to /home/openclaw/council-room/backend/package.json:\n\n{\n  \"name\": \"backend\",\n  \"version\": \"1.0.0\",\n  \"description\": \"\",\n  \"main\": \"index.js\",\n  \"scripts\": {\n    \"test\": \"echo \\\"Error: no test specified\\\" && exit 1\"\n  },\n  \"keywords\": [],\n  \"author\": \"\",\n  \"license\": \"ISC\"\n}\n\n\n\n\n22 packages are looking for funding\n  run `npm fund` for details\n\nfound 0 vulnerabilities","cwd":"/home/openclaw/.openclaw/workspace"},"isError":false,"timestamp":1772982203813}}
{"type":"message","id":"5eeb4f97","parentId":"be7003d9","timestamp":"2026-03-08T15:03:47.641Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"tooluse_fMm8iKpVHxfeEirhnxHaih","name":"write","arguments":{"content":"import Fastify from 'fastify';\nimport cors from '@fastify/cors';\nimport websocket from '@fastify/websocket';\nimport { spawn } from 'child_process';\nimport { readFileSync, existsSync } from 'fs';\nimport { createHash } from 'crypto';\n\nconst fastify = Fastify({ logger: false });\nawait fastify.register(cors, { origin: true });\nawait fastify.register(websocket);\n\n// Auth token — simple shared secret\nconst AUTH_TOKEN = process.env.COUNCIL_TOKEN || 'council-' + createHash('sha256')\n  .update('lucy-dataflow-2026').digest('hex').slice(0, 16);\n\nconsole.log(`🛡️  Council Room API starting...`);\nconsole.log(`🔑  Auth token: ${AUTH_TOKEN}`);\n\n// Agent definitions\nconst AGENTS = {\n  rafael:  { name: 'Rafael',  emoji: '🧭', role: 'The Guide',        color: '#7C6FCD' },\n  uriel:   { name: 'Uriel',   emoji: '🔥', role: \"God's Fire\",       color: '#C9A84C' },\n  michael: { name: 'Michael', emoji: '🛡️', role: 'The Wise Advisor', color: '#4CAF82' },\n  gabriel: { name: 'Gabriel', emoji: '📣', role: 'The Voice',        color: '#E05C5C' },\n  raguel:  { name: 'Raguel',  emoji: '🤝', role: 'The Friend',       color: '#7A8FCD' },\n};\n\n// Run openclaw agent and stream response\nfunction runAgent(agentId, message, onData, onDone, onError) {\n  const args = ['agent', '--agent', agentId, '--message', message, '--json'];\n  const proc = spawn('openclaw', args, {\n    env: { ...process.env, HOME: '/home/openclaw' }\n  });\n\n  let buffer = '';\n  proc.stdout.on('data', (chunk) => {\n    buffer += chunk.toString();\n    onData(chunk.toString());\n  });\n  proc.stderr.on('data', (chunk) => {\n    // Ignore stderr noise\n  });\n  proc.on('close', (code) => {\n    try {\n      const json = JSON.parse(buffer);\n      onDone(json.reply || json.text || buffer);\n    } catch {\n      onDone(buffer);\n    }\n  });\n  proc.on('error', onError);\n  return proc;\n}\n\n// Auth middleware\nfunction checkAuth(req, reply) {\n  const token = req.headers['x-council-token'] || req.query.token;\n  if (token !== AUTH_TOKEN) {\n    reply.code(401).send({ error: 'Unauthorized' });\n    return false;\n  }\n  return true;\n}\n\n// GET /agents — list all agents\nfastify.get('/agents', async (req, reply) => {\n  if (!checkAuth(req, reply)) return;\n  return { agents: AGENTS };\n});\n\n// POST /message — send to single agent\nfastify.post('/message', async (req, reply) => {\n  if (!checkAuth(req, reply)) return;\n  const { agentId, message } = req.body;\n  if (!agentId || !message) return reply.code(400).send({ error: 'agentId and message required' });\n  if (!AGENTS[agentId]) return reply.code(404).send({ error: 'Unknown agent' });\n\n  return new Promise((resolve) => {\n    runAgent(agentId, message,\n      () => {},\n      (response) => resolve({ agent: AGENTS[agentId], response, agentId }),\n      (err) => resolve({ error: err.message })\n    );\n  });\n});\n\n// POST /council — broadcast to all agents (sequential via Rafael)\nfastify.post('/council', async (req, reply) => {\n  if (!checkAuth(req, reply)) return;\n  const { message } = req.body;\n  if (!message) return reply.code(400).send({ error: 'message required' });\n\n  const councilPrompt = `Lucy says (to the full Council): \"${message}\"\\n\\nAs Rafael, The Guide, respond on behalf of the Council. Coordinate with context from all agents if needed. Be concise and direct.`;\n\n  return new Promise((resolve) => {\n    runAgent('rafael', councilPrompt,\n      () => {},\n      (response) => resolve({ agent: AGENTS['rafael'], response, mode: 'council' }),\n      (err) => resolve({ error: err.message })\n    );\n  });\n});\n\n// WebSocket — real-time streaming\nfastify.get('/ws', { websocket: true }, (socket, req) => {\n  const token = new URL(req.url, 'http://localhost').searchParams.get('token');\n  if (token !== AUTH_TOKEN) {\n    socket.send(JSON.stringify({ type: 'error', message: 'Unauthorized' }));\n    socket.close();\n    return;\n  }\n\n  socket.send(JSON.stringify({ type: 'connected', message: 'Council Room connected' }));\n\n  socket.on('message', (raw) => {\n    let data;\n    try { data = JSON.parse(raw.toString()); } catch { return; }\n\n    const { agentId, message, mode } = data;\n    if (!message) return;\n\n    const targetAgent = mode === 'council' ? 'rafael' : (agentId || 'rafael');\n    const agentInfo = AGENTS[targetAgent] || AGENTS['rafael'];\n\n    const prompt = mode === 'council'\n      ? `Lucy says (to the full Council): \"${message}\"\\n\\nAs Rafael, The Guide, respond on behalf of the Council. Be concise and direct.`\n      : message;\n\n    socket.send(JSON.stringify({ type: 'thinking', agentId: targetAgent, agent: agentInfo }));\n\n    runAgent(targetAgent, prompt,\n      (chunk) => socket.send(JSON.stringify({ type: 'chunk', agentId: targetAgent, chunk })),\n      (response) => socket.send(JSON.stringify({ type: 'response', agentId: targetAgent, agent: agentInfo, response })),\n      (err) => socket.send(JSON.stringify({ type: 'error', message: err.message }))\n    );\n  });\n});\n\n// Health check\nfastify.get('/health', async () => ({ status: 'ok', agents: Object.keys(AGENTS) }));\n\n// Start\nconst PORT = parseInt(process.env.PORT || '3001');\nawait fastify.listen({ port: PORT, host: '127.0.0.1' });\nconsole.log(`✅  Council Room API running on http://127.0.0.1:${PORT}`);\nconsole.log(`🧭  Agents: ${Object.keys(AGENTS).join(', ')}`);\n","file_path":"/home/openclaw/council-room/backend/server.js"}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-sonnet-4-6","usage":{"input":1,"output":1808,"cacheRead":117110,"cacheWrite":231,"totalTokens":119150,"cost":{"input":0.000003,"output":0.027120000000000002,"cacheRead":0.035133,"cacheWrite":0.00086625,"total":0.06312225}},"stopReason":"toolUse","timestamp":1772982203825}}
