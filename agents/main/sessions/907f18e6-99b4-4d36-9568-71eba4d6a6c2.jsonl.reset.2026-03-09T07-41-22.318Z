{"type":"message","id":"6ad554a8","parentId":"4b2f747e","timestamp":"2026-03-09T07:27:28.588Z","message":{"role":"assistant","content":[{"type":"text","text":"Good, the Caddy config already proxies `/council-api/*` to the backend, so `/council-api/chat/file/...` will work automatically.\n\nNow update the frontend to add file upload support:"},{"type":"toolCall","id":"tooluse_GnYcSLxM0wKSpjJt5FiR7W","name":"exec","arguments":{"command":"cat >> ~/council-room/frontend/index.html << 'JSEOF'\n<script>\n// ── PATCH: File upload in chat ──\n(function(){\n  // Add upload button to input area\n  const iwrap = document.querySelector('.iwrap');\n  if(!iwrap) return;\n  \n  // Create file input (hidden)\n  const fileInp = document.createElement('input');\n  fileInp.type = 'file';\n  fileInp.id = 'chatFile';\n  fileInp.style.display = 'none';\n  fileInp.accept = 'image/*,.pdf,.csv,.txt,.md,.doc,.docx,.xls,.xlsx';\n  fileInp.onchange = () => handleFileSelect(fileInp.files[0]);\n  document.body.appendChild(fileInp);\n  \n  // Create upload button\n  const uploadBtn = document.createElement('button');\n  uploadBtn.className = 'snd';\n  uploadBtn.style.background = 'var(--ash)';\n  uploadBtn.style.width = '30px';\n  uploadBtn.style.height = '30px';\n  uploadBtn.innerHTML = '📎';\n  uploadBtn.title = 'Attach file';\n  uploadBtn.onclick = (e) => { e.preventDefault(); fileInp.click(); };\n  iwrap.insertBefore(uploadBtn, document.getElementById('snd'));\n  \n  // Create preview area\n  const previewArea = document.createElement('div');\n  previewArea.id = 'filePreview';\n  previewArea.style.cssText = 'display:none;padding:.4rem .6rem;border-bottom:1px solid var(--b1);background:var(--s2);font-size:.72rem;color:var(--ivory);align-items:center;gap:.5rem';\n  const iarea = document.querySelector('.iarea');\n  iarea.parentNode.insertBefore(previewArea, iarea);\n  \n  // File state\n  window._chatAttachment = null;\n  \n  async function handleFileSelect(file) {\n    if(!file) return;\n    \n    // Upload immediately\n    const fd = new FormData();\n    fd.append('file', file);\n    try {\n      const r = await fetch(`${API}/chat/upload`, {\n        method: 'POST',\n        headers: {'x-council-token': token},\n        body: fd\n      });\n      const d = await r.json();\n      if(!d.ok) { alert('Upload failed'); return; }\n      \n      window._chatAttachment = d;\n      \n      // Show preview\n      const prev = document.getElementById('filePreview');\n      if(d.isImage) {\n        prev.innerHTML = `<div style=\"display:flex;align-items:center;gap:.5rem\"><img src=\"${d.url}\" style=\"max-height:60px;max-width:120px;border-radius:6px;object-fit:cover\"><div><strong>${d.originalName}</strong><br><span style=\"color:var(--ash)\">Image attached</span></div><button onclick=\"clearAttachment()\" style=\"background:none;border:none;color:var(--ember);cursor:pointer;margin-left:auto;font-size:.8rem\">✕</button></div>`;\n      } else {\n        prev.innerHTML = `<div style=\"display:flex;align-items:center;gap:.5rem\"><span>📎</span><div><strong>${d.originalName}</strong><br><span style=\"color:var(--ash)\">Document attached</span></div><button onclick=\"clearAttachment()\" style=\"background:none;border:none;color:var(--ember);cursor:pointer;margin-left:auto;font-size:.8rem\">✕</button></div>`;\n      }\n      prev.style.display = 'flex';\n    } catch(e) { alert('Upload error: '+e.message); }\n  }\n  \n  window.clearAttachment = function() {\n    window._chatAttachment = null;\n    document.getElementById('filePreview').style.display = 'none';\n    document.getElementById('chatFile').value = '';\n  };\n  \n  // Patch sendMsg to include attachment\n  const origSend = window.sendMsg;\n  window.sendMsg = function() {\n    const el = document.getElementById('inp');\n    let msg = el.value.trim();\n    if(!msg && !window._chatAttachment) return;\n    if(!ws || ws.readyState !== 1) return;\n    \n    // Slash commands\n    if(msg==='/standup') msg='Please give me a quick standup: what is each of you focusing on today for DataFlow?';\n    else if(msg==='/risk-check') msg='Michael, please do a risk check: what are the top 3 risks to our DataFloat sprint right now?';\n    else if(msg==='/pitch-me') msg='Gabriel, give me a fresh one-liner pitch for DataFlow.';\n    \n    const pane = mode==='council' ? 'council' : curAgent;\n    const att = window._chatAttachment;\n    \n    // User message with attachment preview\n    let displayText = msg || '';\n    if(att) {\n      if(att.isImage) {\n        displayText += (displayText ? '\\n' : '') + `[📷 ${att.originalName}]`;\n      } else {\n        displayText += (displayText ? '\\n' : '') + `[📎 ${att.originalName}]`;\n      }\n    }\n    \n    const m = {from:'user', agentId:null, text:displayText, ts:Date.now(), attachment:att};\n    addPaneMsg(pane, m);\n    document.getElementById('pane-'+pane)?.querySelector('.empty')?.remove();\n    appendMsgWithAttachment(pane, m);\n    scrollPane(pane);\n    el.value = '';\n    el.style.height = 'auto';\n    document.getElementById('snd').disabled = true;\n    \n    const payload = {mode, agentId:curAgent, message:msg||(att?`[User sent a file: ${att.originalName}]`:''), pane, sessionId:curSess};\n    if(att) payload.attachment = att;\n    ws.send(JSON.stringify(payload));\n    \n    clearAttachment();\n  };\n  \n  // Enhanced message renderer with image support\n  window.appendMsgWithAttachment = function(pane, m) {\n    const p = document.getElementById('pane-'+pane);\n    if(!p) return;\n    const el = makeMsgEl(m);\n    \n    // Add image preview if attachment is an image\n    if(m.attachment && m.attachment.isImage) {\n      const bub = el.querySelector('.bub');\n      if(bub) {\n        const img = document.createElement('img');\n        img.src = m.attachment.url;\n        img.style.cssText = 'max-width:100%;max-height:300px;border-radius:6px;margin-top:.4rem;cursor:pointer;display:block';\n        img.onclick = () => window.open(m.attachment.url, '_blank');\n        bub.appendChild(img);\n      }\n    }\n    p.appendChild(el);\n  };\n  \n  // Also support drag & drop on chat area\n  const chatMain = document.querySelector('.chat-main');\n  if(chatMain) {\n    chatMain.addEventListener('dragover', (e) => { e.preventDefault(); chatMain.style.outline = '2px dashed var(--violet)'; });\n    chatMain.addEventListener('dragleave', () => { chatMain.style.outline = ''; });\n    chatMain.addEventListener('drop', (e) => {\n      e.preventDefault();\n      chatMain.style.outline = '';\n      const file = e.dataTransfer.files[0];\n      if(file) handleFileSelect(file);\n    });\n  }\n  \n  // Support paste images (Ctrl+V)\n  document.addEventListener('paste', (e) => {\n    const items = e.clipboardData?.items;\n    if(!items) return;\n    for(const item of items) {\n      if(item.kind === 'file') {\n        const file = item.getAsFile();\n        if(file) { handleFileSelect(file); break; }\n      }\n    }\n  });\n})();\n</script>\nJSEOF\necho \"Frontend patch: $(wc -c < ~/council-room/frontend/index.html) bytes\""}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-opus-4-6-v1","usage":{"input":1,"output":2188,"cacheRead":171266,"cacheWrite":152,"totalTokens":173607,"cost":{"input":0.000005,"output":0.054700000000000006,"cacheRead":0.085633,"cacheWrite":0.00095,"total":0.14128800000000002}},"stopReason":"toolUse","timestamp":1773041215510}}
