!model)return rep.code(400).send({error:'model required'});\n  try{\n    const cfg = jread(OC_CONFIG,{});\n    if(!cfg.agents)cfg.agents={};\n    if(!cfg.agents[id])cfg.agents[id]={};\n    cfg.agents[id].model=model;\n    jwrite(OC_CONFIG,cfg);\n    const aid = id==='michael'?'main':id;\n    try{execSync(`pkill -f \"openclaw agent.*${aid}\" 2>/dev/null`);}catch{}\n    return {ok:true,message:`${AGENTS[id]?.name||id} model updated to ${model.split('/').pop()}, restarting...`,timestamp:Date.now()};\n  }catch(e){return rep.code(500).send({error:e.message});}\n});","old_string":"// ── openclaw agents list ──\nfastify.get('/oc/agents', async(req,rep)=>{\n  if(!auth(req,rep))return;\n  try{ const r=execSync('openclaw agents list --json 2>/dev/null').toString(); return {agents:JSON.parse(r)}; }\n  catch{ return {agents:Object.keys(AGENTS).map(id=>({id,name:AGENTS[id].name}))}; }\n});"}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-haiku-4-5-20251001-v1:0","usage":{"input":12,"output":1036,"cacheRead":91121,"cacheWrite":1264,"totalTokens":93433,"cost":{"input":0.000012,"output":0.005180000000000001,"cacheRead":0.009112100000000001,"cacheWrite":0.00158,"total":0.0158841}},"stopReason":"toolUse","timestamp":1772993022195}}
