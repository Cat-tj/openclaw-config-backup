{"type":"message","id":"00a0f7d7","parentId":"48926cc7","timestamp":"2026-04-03T19:19:27.924Z","message":{"role":"toolResult","toolCallId":"tooluse_Icu3gXrBKnSVQSqMXPtfej","toolName":"read","content":[{"type":"text","text":"  function renderRaceDetail(r) {\n    const isID = _lang === 'id';\n    return `\n      <div class=\"comp-detail-title\">${escapeHtml(r.name)}</div>\n      <div class=\"comp-detail-subtitle\">${isID ? 'Kecepatan' : 'Speed'}: ${r.speed || 30} ft · ${isID ? 'Ukuran' : 'Size'}: ${r.size || 'Medium'}${r.darkvision ? ` · Darkvision ${r.darkvision} ft.` : ''}</div>\n      ${r.abilityBonuses?.length ? `<div class=\"comp-detail-section\"><h3>${isID ? 'Skor Kemampuan' : 'Ability Scores'}</h3><p>${escapeHtml(r.abilityBonuses.join(', '))}</p></div>` : ''}\n      <div class=\"comp-detail-section\">\n        <h3>${isID ? 'Sifat' : 'Traits'}</h3>\n        <div class=\"comp-desc-text\"><p>${formatDesc(r.entries)}</p></div>\n      </div>\n      ${r.traitTags?.length ? `<div class=\"comp-detail-tags\">${r.traitTags.map(t => `<span class=\"comp-detail-tag\">${escapeHtml(t)}</span>`).join('')}</div>` : ''}\n      ${r.subraces?.length ? `<div class=\"comp-detail-section\"><h3>${isID ? 'Subspesies' : 'Subspecies'}</h3>${r.subraces.map(sr => `<p><strong>${escapeHtml(sr.name)}</strong>${sr.entries ? ': ' + escapeHtml(sr.entries.slice(0, 200)) : ''}</p>`).join('')}</div>` : ''}\n    `;\n  }\n\n  function renderItemDetail(item) {\n    const isID = _lang === 'id';\n    const costStr = item.value ? `${(item.value / 100).toFixed(item.value % 100 === 0 ? 0 : 2)} gp` : '—';\n    const weightStr = item.weight ? `${item.weight} lb` : '—';\n\n    let propsHtml = '';\n    if (item.dmg1) propsHtml += `<p><strong>Damage:</strong> ${escapeHtml(item.dmg1)} ${escapeHtml(item.dmgType)}</p>`;\n    if (item.ac) propsHtml += `<p><strong>AC:</strong> ${item.ac}</p>`;\n    if (item.range) propsHtml += `<p><strong>${isID ? 'Jangkauan' : 'Range'}:</strong> ${escapeHtml(item.range)}</p>`;\n    if (item.weaponCategory) propsHtml += `<p><strong>Category:</strong> ${escapeHtml(item.weaponCategory)}</p>`;\n    if (item.property?.length) {\n      propsHtml += `<p><strong>${isID ? 'Properti' : 'Properties'}:</strong> ${item.property.map(p => `<span class=\"item-prop-badge\">${escapeHtml(typeof p === 'string' ? p : (p.name || JSON.stringify(p)))}</span>`).join(' ')}</p>`;\n    }\n    if (item.reqAttune) propsHtml += `<p><strong>Attunement:</strong> ${item.reqAttuneText || 'Required'}</p>`;\n\n    return `\n      <div class=\"comp-detail-title\">${escapeHtml(item.name)}</div>\n      <div class=\"comp-detail-subtitle\">${escapeHtml(item.type || '')} · ${isID ? 'Harga' : 'Cost'}: ${costStr} · ${isID ? 'Berat' : 'Weight'}: ${weightStr}${item.rarity !== 'none' ? ` · ${escapeHtml(item.rarity)}` : ''}</div>\n      ${propsHtml ? `<div class=\"comp-detail-section\">${propsHtml}</div>` : ''}\n      ${item.entries ? `<div class=\"comp-detail-section\"><h3>${isID ? 'Deskripsi' : 'Description'}</h3><div class=\"comp-desc-text\"><p>${formatDesc(item.entries)}</p></div></div>` : ''}\n    `;\n  }\n\n  function renderFeatDetail(f) {\n    const isID = _lang === 'id';\n    const prereqs = (f.prerequisites || []).join(', ');\n    return `\n      <div class=\"comp-detail-title\">${escapeHtml(f.name)}</div>\n      <div class=\"comp-detail-subtitle\">${escapeHtml(f.category || 'General')} Feat${prereqs ? ` · ${isID ? 'Prasyarat' : 'Prerequisites'}: ${escapeHtml(prereqs)}` : ''}</div>\n      <div class=\"comp-detail-section\">\n        <h3>${isID ? 'Deskripsi' : 'Description'}</h3>\n        <div class=\"comp-desc-text\"><p>${formatDesc(f.entries)}</p></div>\n      </div>\n    `;\n  }\n\n  function renderBackgroundDetail(b) {\n    const isID = _lang === 'id';\n    const skills = (b.skillProficiencies || []).join(', ');\n    const tools = (b.toolProficiencies || []).join(', ');\n    return `\n      <div class=\"comp-detail-title\">${escapeHtml(b.name)}</div>\n      <div class=\"comp-detail-subtitle\">${isID ? 'Latar Belakang PHB 2024' : 'PHB 2024 Background'}</div>\n      ${skills ? `<div class=\"comp-detail-section\"><p><strong>${isID ? 'Keahlian' : 'Skill Proficiencies'}:</strong> ${escapeHtml(skills)}</p></div>` : ''}\n      ${tools ? `<div class=\"comp-detail-section\"><p><strong>${isID ? 'Alat' : 'Tool Proficiencies'}:</strong> ${escapeHtml(tools)}</p></div>` : ''}\n      <div class=\"comp-detail-section\">\n        <h3>${isID ? 'Deskripsi' : 'Description'}</h3>\n        <div class=\"comp-desc-text\"><p>${formatDesc(b.entries)}</p></div>\n      </div>\n    `;\n  }\n\n  function renderConditionDetail(c) {\n    const isID = _lang === 'id';\n    return `\n      <div class=\"comp-detail-title\">${escapeHtml(c.name)}</div>\n      <div class=\"comp-detail-subtitle\">${escapeHtml(c.type || 'Condition')}</div>\n      <div class=\"comp-detail-section\">\n        <div class=\"comp-desc-text\"><p>${formatDesc(c.entries)}</p></div>\n      </div>\n    `;\n  }\n\n  function renderGenericDetail(item) {\n    return `\n\n[92 more lines in file. Use offset=9428 to continue.]"}],"isError":false,"timestamp":1775243967904}}
