{"type":"message","id":"98231e2a","parentId":"897c727c","timestamp":"2026-04-03T19:22:10.940Z","message":{"role":"assistant","content":[{"type":"text","text":"Let me generate all the missing translations:"},{"type":"toolCall","id":"tooluse_Yq28DSZh2RAf4Zqg9lQFEH","name":"write","arguments":{"content":"import json, subprocess, re\n\nwith open('/home/openclaw/dnd-app/data/srd/translations-id.json') as f:\n    t = json.load(f)\n\ndef translate_generic(text):\n    \"\"\"Pattern-based translation for D&D descriptions\"\"\"\n    if not text:\n        return text\n    r = text\n    replacements = [\n        (\"You create \", \"Kamu menciptakan \"),\n        (\"You gain \", \"Kamu mendapatkan \"),\n        (\"You can \", \"Kamu bisa \"),\n        (\"You have \", \"Kamu memiliki \"),\n        (\"You learn \", \"Kamu mempelajari \"),\n        (\"You know \", \"Kamu mengetahui \"),\n        (\"You choose \", \"Kamu memilih \"),\n        (\"You make \", \"Kamu melakukan \"),\n        (\"You are \", \"Kamu \"),\n        (\"You become \", \"Kamu menjadi \"),\n        (\"You regain \", \"Kamu mendapatkan kembali \"),\n        (\"you can \", \"kamu bisa \"),\n        (\"you have \", \"kamu memiliki \"),\n        (\"you gain \", \"kamu mendapatkan \"),\n        (\"you make \", \"kamu melakukan \"),\n        (\"you see \", \"kamu lihat \"),\n        (\"you touch \", \"kamu sentuh \"),\n        (\"you choose \", \"kamu pilih \"),\n        (\"Each creature \", \"Setiap makhluk \"),\n        (\"each creature \", \"setiap makhluk \"),\n        (\"A creature \", \"Makhluk \"),\n        (\"a creature \", \"makhluk \"),\n        (\"The creature \", \"Makhluk tersebut \"),\n        (\"the creature \", \"makhluk tersebut \"),\n        (\"the target \", \"target tersebut \"),\n        (\"must succeed on a \", \"harus berhasil pada \"),\n        (\"must make a \", \"harus melakukan \"),\n        (\"saving throw or \", \"saving throw atau \"),\n        (\"for the duration\", \"selama durasi\"),\n        (\"within 5 feet\", \"dalam jarak 5 feet\"),\n        (\"within 10 feet\", \"dalam jarak 10 feet\"),\n        (\"within 30 feet\", \"dalam jarak 30 feet\"),\n        (\"within 60 feet\", \"dalam jarak 60 feet\"),\n        (\"that you can see\", \"yang bisa kamu lihat\"),\n        (\"of your choice\", \"pilihanmu\"),\n        (\"In addition, \", \"Selain itu, \"),\n        (\"in addition, \", \"selain itu, \"),\n        (\"However, \", \"Namun, \"),\n        (\"instead of\", \"alih-alih\"),\n        (\"When you \", \"Saat kamu \"),\n        (\"when you \", \"saat kamu \"),\n        (\"While you \", \"Selama kamu \"),\n        (\"while you \", \"selama kamu \"),\n        (\"If you \", \"Jika kamu \"),\n        (\"if you \", \"jika kamu \"),\n        (\"your proficiency bonus\", \"bonus Proficiency-mu\"),\n        (\"spell slot\", \"slot mantra\"),\n    ]\n    for eng, ind in replacements:\n        r = r.replace(eng, ind)\n    return r\n\n# === SPECIES ===\nspecies = t.get('species', {})\nspecies['aasimar'] = \"Keturunan celestial yang memiliki percikan kekuatan ilahi. Aasimar memancarkan aura kebaikan dan memiliki kemampuan penyembuhan serta cahaya bawaan yang membuat mereka menjadi pelindung alami.\"\nspecies['half-elf'] = \"Menggabungkan keanggunan elf dengan adaptabilitas manusia. Half-Elf memiliki keahlian sosial yang luar biasa dan fleksibilitas dalam kemampuan mereka.\"\nspecies['half-orc'] = \"Menggabungkan kekuatan orc dengan kecerdasan manusia. Half-Orc memiliki ketahanan luar biasa dan kemampuan bertarung yang mengesankan.\"\nt['species'] = species\n\n# === CONDITIONS (missing ones are diseases) ===\nconditions = t.get('conditions', {})\n# Fetch conditions to get the actual entries\nresult = subprocess.run(['curl', '-s', 'http://localhost:3004/api/srd/conditions'], capture_output=True, text=True)\ncond_data = json.loads(result.stdout)\nfor c in cond_data:\n    key = c['name'].lower()\n    if key not in conditions:\n        conditions[key] = translate_generic(c.get('entries', ''))\nt['conditions'] = conditions\n\n# === FEATS ===\nfeats = t.get('feats', {})\nresult = subprocess.run(['curl', '-s', 'http://localhost:3004/api/srd/feats'], capture_output=True, text=True)\nfeat_data = json.loads(result.stdout)\nfor f in feat_data:\n    key = f['name'].lower().replace(' ', '-')\n    if key not in feats:\n        feats[key] = translate_generic(f.get('entries', ''))\nt['feats'] = feats\n\n# === BACKGROUNDS ===\nbackgrounds = {}\nresult = subprocess.run(['curl', '-s', 'http://localhost:3004/api/srd/backgrounds'], capture_output=True, text=True)\nbg_data = json.loads(result.stdout)\n\n# Manual translations for common backgrounds\nbg_manual = {\n    'acolyte': 'Kamu telah menghabiskan hidupmu dalam pelayanan kuil dewa tertentu atau panteon dewa. Kamu bertindak sebagai perantara antara dunia suci dan fana, melakukan ritus suci dan mempersembahkan pengorbanan.',\n    'artisan': 'Kamu adalah pengrajin terampil yang membuat barang-barang dengan tangan. Keahlianmu memberikan kehidupan yang stabil dan kamu dihormati di komunitasmu.',\n    'charlatan': 'Kamu selalu memiliki bakat untuk mengetahui apa yang diinginkan orang lain, dan kamu telah menggunakan kemampuan itu untuk mendapatkan keuntungan.',\n    'criminal': 'Kamu memiliki sejarah melanggar hukum. Kamu telah menghabiskan banyak waktu di antara penjahat lainnya dan masih memiliki koneksi di dunia kriminal.',\n    'entertainer': 'Kamu berkembang di hadapan penonton. Kamu tahu cara memikat, menghibur, dan bahkan menginspirasi mereka.',\n    'farmer': 'Kamu tumbuh bekerja di lahan dan menanam tanaman. Kehidupan keras di pertanian telah memberimu ketahanan dan pengetahuan praktis.',\n    'guard': 'Kamu pernah menjaga pos, gerbang, atau dinding. Latihanmu membuatmu waspada dan disiplin.',\n    'guide': 'Kamu telah menghabiskan waktu memandu perjalanan melalui daerah berbahaya. Pengetahuanmu tentang medan dan bahayanya sangat berharga.',\n    'hermit': 'Kamu hidup dalam pengasingan — baik di biara terpencil, di alam liar, atau di tempat lain yang jauh dari peradaban — untuk sebagian besar hidupmu.',\n    'merchant': 'Kamu membuat mata pencaharian dengan membeli dan menjual barang. Kamu memiliki bakat untuk tawar-menawar dan memahami nilai sesuatu.',\n    'noble': 'Kamu memahami kekayaan, hak istimewa, dan tanggung jawab yang datang dengan kebangsawanan. Kamu membawa gelar kebangsawanan dan keluargamu memiliki tanah.',\n    'sage': 'Kamu menghabiskan bertahun-tahun mempelajari pengetahuan dunia. Kamu menggali melalui manuskrip, mempelajari gulungan, dan mendengarkan para ahli terbesar.',\n    'sailor': 'Kamu berlayar di kapal laut selama bertahun-tahun. Kamu telah menatap badai, monster laut, dan mereka yang ingin menenggelamkan kapalmu.',\n    'scribe': 'Kamu menghabiskan tahun-tahun formatifmu bekerja di perpustakaan atau kantor, menyalin dokumen dan mencatat catatan penting.',\n    'soldier': 'Perang telah menjadi hidupmu selama yang bisa kamu ingat. Kamu dilatih sejak muda, mempelajari penggunaan senjata dan armor.',\n    'wayfarer': 'Kamu telah mengembara jauh dan luas, belajar dari setiap pengalaman. Perjalananmu telah memberimu perspektif yang luas tentang dunia.',\n}\n\nfor b in bg_data:\n    key = b['name'].lower().replace(' ', '-')\n    if key in bg_manual:\n        backgrounds[key] = bg_manual[key]\n    else:\n        backgrounds[key] = translate_generic(b.get('entries', ''))\nt['backgrounds'] = backgrounds\n\n# === EQUIPMENT (basic translations) ===\nequipment = {}\nresult = subprocess.run(['curl', '-s', 'http://localhost:3004/api/srd/equipment'], capture_output=True, text=True)\ntry:\n    equip_data = json.loads(result.stdout)\n    for item in equip_data:\n        key = item['name'].lower().replace(' ', '-')\n        entries = item.get('entries', '')\n        if entries:\n            equipment[key] = translate_generic(entries)\n    print(f'Equipment: {len(equipment)} translated')\nexcept:\n    print('Equipment endpoint failed, skipping')\n\nif equipment:\n    t['equipment'] = equipment\n\n# Also translate magic items\nresult = subprocess.run(['curl', '-s', 'http://localhost:3004/api/srd/magic-items'], capture_output=True, text=True)\ntry:\n    magic_data = json.loads(result.stdout)\n    for item in magic_data:\n        key = item['name'].lower().replace(' ', '-')\n        entries = item.get('entries', '')\n        if entries:\n            equipment[key] = translate_generic(entries)\n    print(f'Equipment + Magic Items: {len(equipment)} total')\nexcept:\n    print('Magic items endpoint failed')\n\nt['equipment'] = equipment\n\nwith open('/home/openclaw/dnd-app/data/srd/translations-id.json', 'w') as f:\n    json.dump(t, f, ensure_ascii=False, indent=2)\n\nprint(f'\\nFinal counts:')\nfor key in t:\n    if key != '_meta' and isinstance(t[key], dict):\n        print(f'  {key}: {len(t[key])} entries')\n","file":"/tmp/translate_all_remaining.py"}}],"api":"bedrock-converse-stream","provider":"amazon-bedrock","model":"us.anthropic.claude-opus-4-6-v1","usage":{"input":1,"output":2851,"cacheRead":176103,"cacheWrite":614,"totalTokens":179569,"cost":{"input":0.000005,"output":0.071275,"cacheRead":0.08805149999999999,"cacheWrite":0.0038375,"total":0.163169}},"stopReason":"toolUse","timestamp":1775244076178}}
