{"type":"message","id":"e717177b","parentId":"3958ce0d","timestamp":"2026-04-03T19:15:56.165Z","message":{"role":"toolResult","toolCallId":"tooluse_LBFHgTUieCu58w8PXJerKs","toolName":"read","content":[{"type":"text","text":"  function renderSpellDetail(s) {\n    const isID = _lang === 'id';\n    const school = isID ? tSchool(s.school) : s.school;\n    const lvlText = s.level === 0 ? 'Cantrip' : `${isID ? 'Level' : 'Level'} ${s.level}`;\n    const classes = (s.classes || []).join(', ');\n\n    let badges = '';\n    if (s.concentration) badges += `<span class=\"spell-concentration-badge\">${isID ? 'Konsentrasi' : 'Concentration'}</span>`;\n    if (s.ritual) badges += `<span class=\"spell-ritual-badge\">Ritual</span>`;\n\n    return `\n      <div class=\"comp-detail-title\">${escapeHtml(s.name)}${badges}</div>\n      <div class=\"comp-detail-subtitle\">${lvlText} ${escapeHtml(school)}</div>\n      <dl class=\"spell-detail-props\">\n        <dt>${isID ? 'Waktu Rapal' : 'Casting Time'}</dt><dd>${escapeHtml(s.castingTime || '—')}</dd>\n        <dt>${isID ? 'Jangkauan' : 'Range'}</dt><dd>${escapeHtml(s.range || '—')}</dd>\n        <dt>${isID ? 'Komponen' : 'Components'}</dt><dd>${escapeHtml(s.components || '—')}${s.materialDetail ? ` <em>(${escapeHtml(s.materialDetail)})</em>` : ''}</dd>\n        <dt>${isID ? 'Durasi' : 'Duration'}</dt><dd>${escapeHtml(s.duration || '—')}</dd>\n      </dl>\n      <div class=\"comp-detail-section\">\n        <h3>${isID ? 'Deskripsi' : 'Description'}</h3>\n        <div class=\"comp-desc-text\"><p>${formatDesc(s.description)}</p></div>\n      </div>\n      ${s.higherLevels ? `\n        <div class=\"comp-detail-section\">\n          <h3>${isID ? 'Pada Level Lebih Tinggi' : 'At Higher Levels'}</h3>\n          <div class=\"comp-desc-text\"><p>${formatDesc(s.higherLevels)}</p></div>\n        </div>` : ''}\n      ${classes ? `<div class=\"comp-detail-tags\">${classes.split(', ').map(c => `<span class=\"comp-detail-tag\">${escapeHtml(c)}</span>`).join('')}</div>` : ''}\n    `;\n  }\n\n  function renderClassDetail(c) {\n    const isID = _lang === 'id';\n\n    // Proficiencies section\n    let profHtml = `<div class=\"comp-detail-section\"><h3>${isID ? 'Profisiensi' : 'Proficiencies'}</h3>`;\n    if (c.profArmor?.length) profHtml += `<p><strong>${isID ? 'Armor' : 'Armor'}:</strong> ${escapeHtml(c.profArmor.join(', '))}</p>`;\n    if (c.profWeapons?.length) profHtml += `<p><strong>${isID ? 'Senjata' : 'Weapons'}:</strong> ${escapeHtml(c.profWeapons.join(', '))}</p>`;\n    if (c.profTools?.length) profHtml += `<p><strong>${isID ? 'Alat' : 'Tools'}:</strong> ${escapeHtml(c.profTools.join(', '))}</p>`;\n\n[233 more lines in file. Use offset=9280 to continue.]"}],"isError":false,"timestamp":1775243756151}}
